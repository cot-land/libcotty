/// Terminal grid and state: cell storage, cursor, scroll regions, SGR attributes.
/// Modeled on Ghostty's Terminal.zig and Screen.zig.

import "std/list"
import "std/sys"
import "cell"
import "config"
import "input"

// ============================================================================
// Full 256-color Palette Builder
// ============================================================================

/// Build a full 256-entry palette (768 i64 values = 256 colors × 3 RGB) from
/// a 16-color theme palette (48 values). Colors 16-231 = 6×6×6 cube,
/// colors 232-255 = grayscale ramp.
fn buildFullPalette(theme_pal: *List(i64)) List(i64) {
    var pal: List(i64) = .{}

    // Copy 16 theme colors (indices 0-15)
    for i in 0..48 {
        pal.append(theme_pal.get(i))
    }

    // 6×6×6 color cube (indices 16-231)
    for idx in 16..232 {
        const ci = idx - 16
        const r_level = ci / 36
        const g_level = (ci / 6) % 6
        const b_level = ci % 6
        pal.append(cubeLevel_(r_level))
        pal.append(cubeLevel_(g_level))
        pal.append(cubeLevel_(b_level))
    }

    // Grayscale ramp (indices 232-255)
    for idx in 232..256 {
        const gray = (idx - 232) * 10 + 8
        pal.append(gray)
        pal.append(gray)
        pal.append(gray)
    }

    return pal
}

/// Convert a 6×6×6 cube level (0-5) to an 8-bit color value.
fn cubeLevel_(level: i64) i64 {
    if (level == 0) { return 0 }
    return 55 + level * 40
}

// ============================================================================
// TerminalGrid — flat cell storage (rows * cols)
// ============================================================================

/// Flat grid of cells addressed by (row, col).
/// Cells are stored contiguously in row-major order.
/// row_wrap tracks soft-wrap state per row for resize reflow.
// Semantic prompt markers for OSC 133
const SEMANTIC_NONE: i64 = 0
const SEMANTIC_PROMPT: i64 = 1
const SEMANTIC_INPUT: i64 = 2
const SEMANTIC_OUTPUT: i64 = 3

struct TerminalGrid {
    cells: List(Cell),
    rows: i64,
    cols: i64,
    row_wrap: List(i64),
    row_semantic: List(i64),
    active_start: i64,
    max_scrollback: i64,
    scrollback_enabled: i64,

    /// Create a grid of rows * cols blank cells with default colors.
    static fn init(rows: i64, cols: i64) TerminalGrid {
        var cells: List(Cell) = .{}

        const total = rows * cols
        for i in 0..total {
            cells.append(Cell.init())
        }

        var wraps: List(i64) = .{}
        var semantics: List(i64) = .{}
        for w in 0..rows {
            wraps.append(0)
            semantics.append(0)
        }

        return TerminalGrid {
            cells: cells,
            rows: rows,
            cols: cols,
            row_wrap: wraps,
            row_semantic: semantics,
            active_start: 0,
            max_scrollback: 10000,
            scrollback_enabled: 1,
        }
    }

    /// Get a pointer to the cell at (row, col), offset by active_start.
    fn getCell(row: i64, col: i64) *Cell {
        const idx = (self.active_start + row) * self.cols + col
        return @intToPtr(*Cell, self.cells.items + idx * @sizeOf(Cell))
    }

    /// Get the wrap flag for a row (1 = soft-wrapped into next row).
    fn getRowWrap(row: i64) i64 {
        return @intToPtr(*i64, self.row_wrap.items + (self.active_start + row) * @sizeOf(i64)).*
    }

    /// Set the wrap flag for a row (1 = soft-wrapped, 0 = hard break).
    fn setRowWrap(row: i64, val: i64) void {
        @intToPtr(*i64, self.row_wrap.items + (self.active_start + row) * @sizeOf(i64)).* = val
    }

    /// Get the semantic marker for a row.
    fn getRowSemantic(row: i64) i64 {
        return @intToPtr(*i64, self.row_semantic.items + (self.active_start + row) * @sizeOf(i64)).*
    }

    /// Set the semantic marker for a row.
    fn setRowSemantic(row: i64, val: i64) void {
        @intToPtr(*i64, self.row_semantic.items + (self.active_start + row) * @sizeOf(i64)).* = val
    }

    /// Clear the entire grid to default blank cells.
    fn clear() void {
        for row in 0..self.rows {
            self.clearLine(row)
        }
    }

    /// Clear a single row to default blank cells and reset its wrap flag.
    fn clearLine(row: i64) void {
        var default_cell = Cell.init()
        self.clearLineWith(row, &default_cell)
    }

    /// Clear a single row to a specific blank cell and reset its wrap/semantic flags.
    fn clearLineWith(row: i64, blank: *Cell) void {
        for col in 0..self.cols {
            self.getCell(row, col).* = blank.*
        }
        self.setRowWrap(row, 0)
        self.setRowSemantic(row, 0)
    }

    /// Scroll the region [top..bottom] up by one line.
    /// Full-screen scroll on primary screen: append blank row, increment active_start
    /// (old top row preserved as scrollback). Sub-region: memcpy within active area.
    /// Cleared cells use the provided blank cell (carries current SGR bg).
    fn scrollUp(top: i64, bottom: i64, blank: *Cell) void {
        // Full-screen scroll with scrollback enabled: no memcpy needed
        if (top == 0) {
            if (bottom == self.rows - 1) {
                if (self.scrollback_enabled == 1) {
                    // Append a blank row of cells
                    for i in 0..self.cols {
                        self.cells.append(blank.*)
                    }
                    // Append wrap and semantic flags for the new row
                    self.row_wrap.append(0)
                    self.row_semantic.append(0)
                    // Advance active_start — old top row is now scrollback
                    self.active_start += 1
                    self.trimScrollback()
                    return
                }
            }
        }
        // Sub-region scroll: memcpy within active area
        var row = top
        while (row < bottom) {
            const dst = self.cells.items + ((self.active_start + row) * self.cols) * @sizeOf(Cell)
            const src = self.cells.items + ((self.active_start + row + 1) * self.cols) * @sizeOf(Cell)
            memcpy(dst, src, self.cols * @sizeOf(Cell))
            self.setRowWrap(row, self.getRowWrap(row + 1))
            self.setRowSemantic(row, self.getRowSemantic(row + 1))
            row += 1
        }
        self.clearLineWith(bottom, blank)
    }

    /// Scroll the region [top..bottom] down by one line.
    /// Content and wrap flags shift down, top line is cleared with provided blank cell.
    fn scrollDown(top: i64, bottom: i64, blank: *Cell) void {
        var row = bottom
        while (row > top) {
            const dst = self.cells.items + ((self.active_start + row) * self.cols) * @sizeOf(Cell)
            const src = self.cells.items + ((self.active_start + row - 1) * self.cols) * @sizeOf(Cell)
            memcpy(dst, src, self.cols * @sizeOf(Cell))
            self.setRowWrap(row, self.getRowWrap(row - 1))
            self.setRowSemantic(row, self.getRowSemantic(row - 1))
            row -= 1
        }
        self.clearLineWith(top, blank)
    }

    /// Insert count blank lines at row, shifting content down within [row..bottom].
    fn insertLines(row: i64, count: i64, bottom: i64, blank: *Cell) void {
        var i: i64 = 0
        while (i < count) {
            self.scrollDown(row, bottom, blank)
            i += 1
        }
    }

    /// Delete count lines at row, shifting content up within [row..bottom].
    fn deleteLines(row: i64, count: i64, bottom: i64, blank: *Cell) void {
        var i: i64 = 0
        while (i < count) {
            self.scrollUp(row, bottom, blank)
            i += 1
        }
    }

    /// Trim scrollback when it exceeds max_scrollback rows.
    /// Moves remaining cells/wraps forward and adjusts active_start.
    /// Erase all scrollback — keep only the active screen rows.
    /// Shifts cells/wraps/semantics so active_start becomes 0.
    fn eraseScrollback() void {
        if (self.active_start == 0) { return }
        const active_cells = self.rows * self.cols
        // Move active cells to start
        memcpy(self.cells.items,
               self.cells.items + self.active_start * self.cols * @sizeOf(Cell),
               active_cells * @sizeOf(Cell))
        self.cells.count = active_cells
        // Move row_wrap
        memcpy(self.row_wrap.items,
               self.row_wrap.items + self.active_start * @sizeOf(i64),
               self.rows * @sizeOf(i64))
        self.row_wrap.count = self.rows
        // Move row_semantic
        memcpy(self.row_semantic.items,
               self.row_semantic.items + self.active_start * @sizeOf(i64),
               self.rows * @sizeOf(i64))
        self.row_semantic.count = self.rows
        self.active_start = 0
    }

    fn trimScrollback() void {
        if (self.active_start <= self.max_scrollback) { return }
        const trim = self.active_start - self.max_scrollback
        const total_cells = (self.active_start + self.rows) * self.cols
        const keep_cells = total_cells - trim * self.cols
        // memmove cells forward
        memcpy(self.cells.items, self.cells.items + trim * self.cols * @sizeOf(Cell), keep_cells * @sizeOf(Cell))
        self.cells.count = keep_cells
        // memmove row_wrap forward
        const total_wraps = self.active_start + self.rows
        const keep_wraps = total_wraps - trim
        memcpy(self.row_wrap.items, self.row_wrap.items + trim * @sizeOf(i64), keep_wraps * @sizeOf(i64))
        self.row_wrap.count = keep_wraps
        // memmove row_semantic forward
        memcpy(self.row_semantic.items, self.row_semantic.items + trim * @sizeOf(i64), keep_wraps * @sizeOf(i64))
        self.row_semantic.count = keep_wraps
        self.active_start = self.max_scrollback
    }
}

// ============================================================================
// DEC Special Graphics charset mapping
// ============================================================================

/// Map a codepoint in the DEC Special Graphics range (0x60-0x7E) to its
/// Unicode box-drawing equivalent. From Ghostty's charsets.zig dec_special table.
fn decSpecialMap(cp: i64) i64 {
    return switch (cp) {
        0x60 => 0x25C6,  // ◆
        0x61 => 0x2592,  // ▒
        0x62 => 0x2409,  // HT
        0x63 => 0x240C,  // FF
        0x64 => 0x240D,  // CR
        0x65 => 0x240A,  // LF
        0x66 => 0x00B0,  // °
        0x67 => 0x00B1,  // ±
        0x68 => 0x2424,  // NL
        0x69 => 0x240B,  // VT
        0x6A => 0x2518,  // ┘
        0x6B => 0x2510,  // ┐
        0x6C => 0x250C,  // ┌
        0x6D => 0x2514,  // └
        0x6E => 0x253C,  // ┼
        0x6F => 0x23BA,  // ⎺
        0x70 => 0x23BB,  // ⎻
        0x71 => 0x2500,  // ─
        0x72 => 0x23BC,  // ⎼
        0x73 => 0x23BD,  // ⎽
        0x74 => 0x251C,  // ├
        0x75 => 0x2524,  // ┤
        0x76 => 0x2534,  // ┴
        0x77 => 0x252C,  // ┬
        0x78 => 0x2502,  // │
        0x79 => 0x2264,  // ≤
        0x7A => 0x2265,  // ≥
        0x7B => 0x03C0,  // π
        0x7C => 0x2260,  // ≠
        0x7D => 0x00A3,  // £
        0x7E => 0x00B7,  // ·
        else => cp,
    }
}

/// Map a codepoint using the UK charset (ESC ( A).
/// Only 0x23 (#) maps to 0x00A3 (£ pound sign); everything else is identity.
fn ukCharsetMap(cp: i64) i64 {
    if (cp == 0x23) { return 0x00A3 }
    return cp
}

// ============================================================================
// Tabstop initialization
// ============================================================================

/// Create a tabstop list with stops set every 8 columns.
fn initTabstops(cols: i64) List(i64) {
    var stops: List(i64) = .{}
    for i in 0..cols {
        if (i % 8 == 0) {
            stops.append(1)
        } else {
            stops.append(0)
        }
    }
    return stops
}

// ============================================================================
// Word boundary detection for selection
// ============================================================================

/// Check if a codepoint is a word boundary character for double-click selection.
/// Default separators match Ghostty: |`"'&;:,./<>(){}[]@
fn isWordBoundary(cp: i64) bool {
    return (cp == '|' or cp == '`' or cp == '"' or cp == '\'' or
            cp == '&' or cp == ';' or cp == ':' or cp == ',' or
            cp == '.' or cp == '/' or cp == '<' or cp == '>' or
            cp == '(' or cp == ')' or cp == '{' or cp == '}' or
            cp == '[' or cp == ']' or cp == '@')
}

// ============================================================================
// Base64 decoding for OSC 52
// ============================================================================

/// Decode a single base64 character to its 6-bit value. Returns -1 for invalid/padding.
fn base64CharVal(ch: i64) i64 {
    if (ch >= 'A' and ch <= 'Z') { return ch - 'A' }
    if (ch >= 'a' and ch <= 'z') { return ch - 'a' + 26 }
    if (ch >= '0' and ch <= '9') { return ch - '0' + 52 }
    if (ch == '+') { return 62 }
    if (ch == '/') { return 63 }
    return -1
}

/// Decode base64 data from buf[start..start+len] into out_ptr.
/// Returns the number of decoded bytes written.
fn base64Decode(buf: List(i64), start: i64, len: i64, out_ptr: i64) i64 {
    var pos: i64 = 0
    var i = start
    const end = start + len
    while (i + 3 < end) {
        const a = base64CharVal(buf.get(i))
        const b = base64CharVal(buf.get(i + 1))
        const c = base64CharVal(buf.get(i + 2))
        const d = base64CharVal(buf.get(i + 3))

        if (a < 0 or b < 0) {
            i += 4
            continue
        }

        // First byte always produced
        @intToPtr(*u8, out_ptr + pos).* = @intCast(u8, (a << 2) | (b >> 4))
        pos += 1

        // Second byte if c is valid
        if (c >= 0) {
            @intToPtr(*u8, out_ptr + pos).* = @intCast(u8, ((b & 0x0F) << 4) | (c >> 2))
            pos += 1
        }

        // Third byte if d is valid
        if (d >= 0) {
            @intToPtr(*u8, out_ptr + pos).* = @intCast(u8, ((c & 0x03) << 6) | d)
            pos += 1
        }

        i += 4
    }
    return pos
}

// ============================================================================
// Color spec parsing for OSC 4/10/11/12
// ============================================================================

/// Parse a hex digit character to its value (0-15). Returns -1 for invalid.
fn hexVal(ch: i64) i64 {
    if (ch >= '0' and ch <= '9') { return ch - '0' }
    if (ch >= 'a' and ch <= 'f') { return ch - 'a' + 10 }
    if (ch >= 'A' and ch <= 'F') { return ch - 'A' + 10 }
    return -1
}

/// Parse an X11 color spec from buf[start..start+len].
/// Supports "rgb:RR/GG/BB" and "#RRGGBB" formats.
/// Returns (r, g, b) or (-1, -1, -1) on parse failure.
fn parseColorSpec(buf: List(i64), start: i64, len: i64) (i64, i64, i64) {
    if (len < 7) { return (-1, -1, -1) }

    // Check for "#RRGGBB" format
    if (buf.get(start) == '#' and len >= 7) {
        const r = hexVal(buf.get(start + 1)) * 16 + hexVal(buf.get(start + 2))
        const g = hexVal(buf.get(start + 3)) * 16 + hexVal(buf.get(start + 4))
        const b = hexVal(buf.get(start + 5)) * 16 + hexVal(buf.get(start + 6))
        if (r < 0 or g < 0 or b < 0) { return (-1, -1, -1) }
        return (r, g, b)
    }

    // Check for "rgb:RR/GG/BB" format (len >= 12: "rgb:" + "RR/GG/BB")
    if (len >= 12) {
        if (buf.get(start) == 'r' and buf.get(start + 1) == 'g' and
            buf.get(start + 2) == 'b' and buf.get(start + 3) == ':') {
            const r = hexVal(buf.get(start + 4)) * 16 + hexVal(buf.get(start + 5))
            if (buf.get(start + 6) != '/') { return (-1, -1, -1) }
            const g = hexVal(buf.get(start + 7)) * 16 + hexVal(buf.get(start + 8))
            if (buf.get(start + 9) != '/') { return (-1, -1, -1) }
            const b = hexVal(buf.get(start + 10)) * 16 + hexVal(buf.get(start + 11))
            if (r < 0 or g < 0 or b < 0) { return (-1, -1, -1) }
            return (r, g, b)
        }
    }

    return (-1, -1, -1)
}

// ============================================================================
// TerminalState — cursor, attributes, scroll region, pending wrap
// ============================================================================

/// Full terminal state: grid + cursor + SGR attributes + scroll region.
/// Implements VT100/ANSI escape sequence semantics including deferred wrapping.
struct TerminalState {
    grid: TerminalGrid,
    cursor_row: i64,
    cursor_col: i64,
    saved_row: i64,
    saved_col: i64,
    saved_pending_wrap: bool,
    saved_origin: bool,
    saved_fg_type: i64,
    saved_fg_val: i64,
    saved_bg_type: i64,
    saved_bg_val: i64,
    saved_bold: bool,
    saved_dim: bool,
    saved_italic: bool,
    saved_underline: bool,
    saved_inverse: bool,
    saved_strikethrough: bool,
    saved_blink: bool,
    saved_hidden: bool,
    saved_overline: bool,
    saved_double_underline: bool,
    saved_ul_type: i64,
    saved_ul_val: i64,
    saved_charset_g0: i64,
    saved_charset_g1: i64,
    saved_charset_g2: i64,
    saved_charset_g3: i64,
    saved_active_charset: i64,
    pending_wrap: bool,
    fg_type: i64,
    fg_val: i64,
    bg_type: i64,
    bg_val: i64,
    bold: bool,
    dim: bool,
    italic: bool,
    underline: bool,
    inverse: bool,
    strikethrough: bool,
    blink: bool,
    hidden: bool,
    overline: bool,
    double_underline: bool,
    default_fg_type: i64,
    default_fg_val: i64,
    default_bg_type: i64,
    default_bg_val: i64,
    palette: List(i64),
    scroll_top: i64,
    scroll_bottom: i64,
    pty_fd: i64,
    child_pid: i64,
    sel_active: bool,
    sel_start_row: i64,
    sel_start_col: i64,
    sel_end_row: i64,
    sel_end_col: i64,
    cursor_visible: bool,
    mode_alt_screen: bool,
    mode_app_cursor: bool,
    mode_bracketed_paste: bool,
    mode_mouse_tracking: i64,
    mode_mouse_format: i64,
    mode_focus_events: bool,
    mode_sync_output: bool,
    mode_origin: bool,
    mode_wraparound: bool,
    mode_mouse_alt_scroll: bool,
    mode_insert: bool,
    mode_reverse_video: bool,
    mode_cursor_blinking: bool,
    mode_reverse_wrap: bool,
    mode_app_keypad: bool,
    single_shift: i64,
    charset_g0: i64,
    charset_g1: i64,
    charset_g2: i64,
    charset_g3: i64,
    active_charset: i64,
    tabstops: List(i64),
    cursor_shape: i64,
    previous_char: i64,
    title_buf: i64,
    title_len: i64,
    title_stack_buf: i64,
    title_stack_len: i64,
    pwd_buf: i64,
    pwd_len: i64,
    clipboard_buf: i64,
    clipboard_len: i64,
    clipboard_request: i64,
    bell_pending: bool,
    alt_grid: TerminalGrid,
    alt_cursor_row: i64,
    alt_cursor_col: i64,
    alt_saved_row: i64,
    alt_saved_col: i64,
    alt_saved_pending_wrap: bool,
    alt_saved_origin: bool,
    alt_saved_fg_type: i64,
    alt_saved_fg_val: i64,
    alt_saved_bg_type: i64,
    alt_saved_bg_val: i64,
    alt_saved_bold: bool,
    alt_saved_dim: bool,
    alt_saved_italic: bool,
    alt_saved_underline: bool,
    alt_saved_inverse: bool,
    alt_saved_strikethrough: bool,
    alt_saved_blink: bool,
    alt_saved_hidden: bool,
    alt_saved_overline: bool,
    alt_saved_double_underline: bool,
    alt_saved_ul_type: i64,
    alt_saved_ul_val: i64,
    alt_saved_charset_g0: i64,
    alt_saved_charset_g1: i64,
    alt_saved_charset_g2: i64,
    alt_saved_charset_g3: i64,
    alt_saved_active_charset: i64,
    scroll_accumulator: i64,
    viewport_row: i64,
    kitty_kbd_flags_0: i64,
    kitty_kbd_flags_1: i64,
    kitty_kbd_flags_2: i64,
    kitty_kbd_flags_3: i64,
    kitty_kbd_flags_4: i64,
    kitty_kbd_flags_5: i64,
    kitty_kbd_flags_6: i64,
    kitty_kbd_flags_7: i64,
    kitty_kbd_idx: i64,
    ul_type: i64,
    ul_val: i64,
    mode_backspace_sends_bs: bool,
    mode_left_right_margin: bool,
    mode_sixel_scrolling: bool,
    mode_grapheme_cluster: bool,
    mode_linefeed_newline: bool,
    mode_report_color_scheme: bool,
    mode_modify_other_keys: i64,
    mode_keyboard_action: bool,
    mode_send_receive: bool,

    // XTSAVE/XTRESTORE — saved DEC private mode state (CSI ? s / CSI ? r)
    // Ghostty ref: modes.zig ModeState — parallel saved bitfield
    xtsaved_app_cursor: bool,
    xtsaved_origin: bool,
    xtsaved_wraparound: bool,
    xtsaved_cursor_visible: bool,
    xtsaved_alt_screen: bool,
    xtsaved_mouse_tracking: i64,
    xtsaved_mouse_format: i64,
    xtsaved_focus_events: bool,
    xtsaved_bracketed_paste: bool,
    xtsaved_sync_output: bool,
    xtsaved_mouse_alt_scroll: bool,
    xtsaved_insert: bool,
    xtsaved_reverse_video: bool,
    xtsaved_cursor_blinking: bool,
    xtsaved_reverse_wrap: bool,
    xtsaved_app_keypad: bool,
    xtsaved_backspace_sends_bs: bool,
    xtsaved_left_right_margin: bool,
    xtsaved_sixel_scrolling: bool,
    xtsaved_grapheme_cluster: bool,

    /// Create a terminal with the given dimensions and default state.
    static fn init(rows: i64, cols: i64) TerminalState {
        ensureThemeReady()
        return TerminalState {
            grid: TerminalGrid.init(rows, cols),
            cursor_row: 0,
            cursor_col: 0,
            saved_row: 0,
            saved_col: 0,
            saved_pending_wrap: false,
            saved_origin: false,
            saved_fg_type: COLOR_NONE,
            saved_fg_val: 0,
            saved_bg_type: COLOR_NONE,
            saved_bg_val: 0,
            saved_bold: false,
            saved_dim: false,
            saved_italic: false,
            saved_underline: false,
            saved_inverse: false,
            saved_strikethrough: false,
            saved_blink: false,
            saved_hidden: false,
            saved_overline: false,
            saved_double_underline: false,
            saved_ul_type: COLOR_NONE,
            saved_ul_val: 0,
            saved_charset_g0: 0,
            saved_charset_g1: 0,
            saved_charset_g2: 0,
            saved_charset_g3: 0,
            saved_active_charset: 0,
            pending_wrap: false,
            fg_type: COLOR_NONE,
            fg_val: 0,
            bg_type: COLOR_NONE,
            bg_val: 0,
            bold: false,
            dim: false,
            italic: false,
            underline: false,
            inverse: false,
            strikethrough: false,
            blink: false,
            hidden: false,
            overline: false,
            double_underline: false,
            default_fg_type: COLOR_NONE,
            default_fg_val: 0,
            default_bg_type: COLOR_NONE,
            default_bg_val: 0,
            palette: buildFullPalette(THEME_PALETTE),
            scroll_top: 0,
            scroll_bottom: rows - 1,
            pty_fd: -1,
            child_pid: -1,
            sel_active: false,
            sel_start_row: 0,
            sel_start_col: 0,
            sel_end_row: 0,
            sel_end_col: 0,
            cursor_visible: true,
            mode_alt_screen: false,
            mode_app_cursor: false,
            mode_bracketed_paste: false,
            mode_mouse_tracking: 0,
            mode_mouse_format: 0,
            mode_focus_events: false,
            mode_sync_output: false,
            mode_origin: false,
            mode_wraparound: true,
            mode_mouse_alt_scroll: true,
            mode_insert: false,
            mode_reverse_video: false,
            mode_cursor_blinking: false,
            mode_reverse_wrap: false,
            mode_app_keypad: false,
            single_shift: 0,
            charset_g0: 0,
            charset_g1: 0,
            charset_g2: 0,
            charset_g3: 0,
            active_charset: 0,
            tabstops: initTabstops(cols),
            cursor_shape: 0,
            previous_char: 0,
            title_buf: 0,
            title_len: 0,
            title_stack_buf: 0,
            title_stack_len: 0,
            pwd_buf: 0,
            pwd_len: 0,
            clipboard_buf: 0,
            clipboard_len: 0,
            clipboard_request: 0,
            bell_pending: false,
            alt_grid: TerminalGrid.init(0, 0),
            alt_cursor_row: 0,
            alt_cursor_col: 0,
            alt_saved_row: 0,
            alt_saved_col: 0,
            alt_saved_pending_wrap: false,
            alt_saved_origin: false,
            alt_saved_fg_type: COLOR_NONE,
            alt_saved_fg_val: 0,
            alt_saved_bg_type: COLOR_NONE,
            alt_saved_bg_val: 0,
            alt_saved_bold: false,
            alt_saved_dim: false,
            alt_saved_italic: false,
            alt_saved_underline: false,
            alt_saved_inverse: false,
            alt_saved_strikethrough: false,
            alt_saved_blink: false,
            alt_saved_hidden: false,
            alt_saved_overline: false,
            alt_saved_double_underline: false,
            alt_saved_ul_type: COLOR_NONE,
            alt_saved_ul_val: 0,
            alt_saved_charset_g0: 0,
            alt_saved_charset_g1: 0,
            alt_saved_charset_g2: 0,
            alt_saved_charset_g3: 0,
            alt_saved_active_charset: 0,
            scroll_accumulator: 0,
            viewport_row: -1,
            kitty_kbd_flags_0: 0,
            kitty_kbd_flags_1: 0,
            kitty_kbd_flags_2: 0,
            kitty_kbd_flags_3: 0,
            kitty_kbd_flags_4: 0,
            kitty_kbd_flags_5: 0,
            kitty_kbd_flags_6: 0,
            kitty_kbd_flags_7: 0,
            kitty_kbd_idx: 0,
            ul_type: COLOR_NONE,
            ul_val: 0,
            mode_backspace_sends_bs: false,
            mode_left_right_margin: false,
            mode_sixel_scrolling: false,
            mode_grapheme_cluster: false,
            mode_linefeed_newline: false,
            mode_report_color_scheme: false,
            mode_modify_other_keys: 0,
            mode_keyboard_action: false,
            mode_send_receive: false,
            xtsaved_app_cursor: false,
            xtsaved_origin: false,
            xtsaved_wraparound: true,
            xtsaved_cursor_visible: true,
            xtsaved_alt_screen: false,
            xtsaved_mouse_tracking: 0,
            xtsaved_mouse_format: 0,
            xtsaved_focus_events: false,
            xtsaved_bracketed_paste: false,
            xtsaved_sync_output: false,
            xtsaved_mouse_alt_scroll: true,
            xtsaved_insert: false,
            xtsaved_reverse_video: false,
            xtsaved_cursor_blinking: false,
            xtsaved_reverse_wrap: false,
            xtsaved_app_keypad: false,
            xtsaved_backspace_sends_bs: false,
            xtsaved_left_right_margin: false,
            xtsaved_sixel_scrolling: false,
            xtsaved_grapheme_cluster: false,
        }
    }

    /// Create a blank cell that carries the current SGR background color.
    /// Ghostty ref: clearCells fills with the cursor's current bg style.
    fn blankCell() Cell {
        return Cell {
            codepoint: 0,
            fg_type: COLOR_NONE, fg_val: 0,
            bg_type: self.bg_type, bg_val: self.bg_val,
            flags: 0,
            ul_type: COLOR_NONE, ul_val: 0,
        }
    }

    // -- Character output ---------------------------------------------------

    /// Write a character at the cursor position with current SGR attributes.
    /// Wrapping is deferred: reaching the last column sets pending_wrap,
    /// and the actual wrap (CR + LF) happens on the next printable character.
    fn putChar(cp: i64) void {
        // Apply charset mapping (DEC Special Graphics, UK, etc.)
        var mapped = cp
        var charset: i64 = self.charset_g0
        if (self.single_shift == 2) {
            charset = self.charset_g2
            self.single_shift = 0
        } else if (self.single_shift == 3) {
            charset = self.charset_g3
            self.single_shift = 0
        } else if (self.active_charset == 1) {
            charset = self.charset_g1
        } else if (self.active_charset == 2) {
            charset = self.charset_g2
        } else if (self.active_charset == 3) {
            charset = self.charset_g3
        }
        if (charset == 1 and mapped >= 0x60 and mapped <= 0x7E) {
            mapped = decSpecialMap(mapped)
        } else if (charset == 2) {
            mapped = ukCharsetMap(mapped)
        }

        if (self.pending_wrap) {
            if (self.mode_wraparound) {
                self.grid.setRowWrap(self.cursor_row, 1)
                self.cursor_col = 0
                self.cursor_row += 1
                if (self.cursor_row > self.scroll_bottom) {
                    var blank = self.blankCell()
                    self.grid.scrollUp(self.scroll_top, self.scroll_bottom, &blank)
                    self.cursor_row = self.scroll_bottom
                }
                self.pending_wrap = false
            } else {
                // No wraparound: overwrite last column
                self.pending_wrap = false
            }
        }

        // Insert mode (IRM): shift existing content right before writing
        if (self.mode_insert) {
            if (self.cursor_col < self.grid.cols - 1) {
                self.insertBlanks(1)
            }
        }

        const c = self.grid.getCell(self.cursor_row, self.cursor_col)
        c.codepoint = mapped
        c.fg_type = self.fg_type
        // Bold-as-bright: palette indices 0-7 shift to 8-15 when bold
        // Ghostty ref: style.zig:145-189 — applies at render time, we apply at cell write
        if (self.bold and self.fg_type == COLOR_PALETTE and self.fg_val < 8) {
            c.fg_val = self.fg_val + 8
        } else {
            c.fg_val = self.fg_val
        }
        c.bg_type = self.bg_type
        c.bg_val = self.bg_val
        c.flags = 0
        if (self.bold) { c.flags = c.flags | CELL_BOLD }
        if (self.dim) { c.flags = c.flags | CELL_DIM }
        if (self.italic) { c.flags = c.flags | CELL_ITALIC }
        if (self.underline) { c.flags = c.flags | CELL_UNDERLINE }
        if (self.inverse) { c.flags = c.flags | CELL_INVERSE }
        if (self.strikethrough) { c.flags = c.flags | CELL_STRIKETHROUGH }
        if (self.blink) { c.flags = c.flags | CELL_BLINK }
        if (self.hidden) { c.flags = c.flags | CELL_HIDDEN }
        if (self.overline) { c.flags = c.flags | CELL_OVERLINE }
        if (self.double_underline) { c.flags = c.flags | CELL_DOUBLE_UNDERLINE }
        c.ul_type = self.ul_type
        c.ul_val = self.ul_val
        if (self.ul_type != COLOR_NONE) { c.flags = c.flags | CELL_CUSTOM_UL_COLOR }

        self.previous_char = mapped

        if (self.cursor_col >= self.grid.cols - 1) {
            self.pending_wrap = true
        } else {
            self.cursor_col += 1
        }
    }

    // -- C0 control characters ----------------------------------------------

    /// Linefeed (LF): move cursor down one row, scroll if at bottom of region.
    /// In LNM mode (ANSI mode 20), LF also performs carriage return.
    fn newline() void {
        self.grid.setRowWrap(self.cursor_row, 0)
        self.pending_wrap = false
        if (self.mode_linefeed_newline) {
            self.cursor_col = 0
        }
        self.cursor_row += 1
        if (self.cursor_row > self.scroll_bottom) {
            var blank = self.blankCell()
            self.grid.scrollUp(self.scroll_top, self.scroll_bottom, &blank)
            self.cursor_row = self.scroll_bottom
        }
    }

    /// Carriage return (CR): move cursor to column 0.
    fn carriageReturn() void {
        self.pending_wrap = false
        self.cursor_col = 0
    }

    /// Backspace (BS): move cursor left by one column.
    /// In reverse wrap mode (mode 45), wraps to end of previous soft-wrapped line.
    fn backspace() void {
        self.pending_wrap = false
        if (self.cursor_col > 0) {
            self.cursor_col -= 1
        } else if (self.mode_reverse_wrap) {
            if (self.cursor_row > 0) {
                if (self.grid.getRowWrap(self.cursor_row - 1) == 1) {
                    self.cursor_row -= 1
                    self.cursor_col = self.grid.cols - 1
                }
            }
        }
    }

    /// Horizontal tab (HT): advance to the next tab stop.
    fn tab() void {
        self.pending_wrap = false
        self.tabForward(1)
    }

    /// Set a tab stop at the current cursor column (HTS).
    fn tabSet() void {
        if (self.cursor_col < self.tabstops.count) {
            @intToPtr(*i64, self.tabstops.items + self.cursor_col * @sizeOf(i64)).* = 1
        }
    }

    /// Clear tab stops: mode 0 = current column, mode 3 = all.
    fn tabClear(mode: i64) void {
        if (mode == 0) {
            if (self.cursor_col < self.tabstops.count) {
                @intToPtr(*i64, self.tabstops.items + self.cursor_col * @sizeOf(i64)).* = 0
            }
        } else if (mode == 3) {
            for i in 0..self.tabstops.count {
                @intToPtr(*i64, self.tabstops.items + i * @sizeOf(i64)).* = 0
            }
        }
    }

    /// Move forward count tab stops (CHT).
    fn tabForward(count: i64) void {
        var remaining = count
        var col = self.cursor_col + 1
        while (col < self.grid.cols and remaining > 0) {
            if (col < self.tabstops.count) {
                if (@intToPtr(*i64, self.tabstops.items + col * @sizeOf(i64)).* == 1) {
                    remaining -= 1
                    if (remaining == 0) {
                        self.cursor_col = col
                        return
                    }
                }
            }
            col += 1
        }
        self.cursor_col = self.grid.cols - 1
    }

    /// Move backward count tab stops (CBT).
    fn tabBackward(count: i64) void {
        var remaining = count
        var col = self.cursor_col - 1
        while (col >= 0 and remaining > 0) {
            if (col < self.tabstops.count) {
                if (@intToPtr(*i64, self.tabstops.items + col * @sizeOf(i64)).* == 1) {
                    remaining -= 1
                    if (remaining == 0) {
                        self.cursor_col = col
                        return
                    }
                }
            }
            col -= 1
        }
        self.cursor_col = 0
    }

    /// Reset tabstops to default (every 8 columns).
    fn resetTabstops() void {
        self.tabstops = initTabstops(self.grid.cols)
    }

    // -- Cursor movement (CSI A/B/C/D/H) -----------------------------------

    /// Move cursor up by count rows, clamped to scroll region top (CSI A).
    fn cursorUp(count: i64) void {
        self.pending_wrap = false
        self.cursor_row -= count
        if (self.cursor_row < self.scroll_top) {
            self.cursor_row = self.scroll_top
        }
    }

    /// Move cursor down by count rows, clamped to scroll region bottom (CSI B).
    fn cursorDown(count: i64) void {
        self.pending_wrap = false
        self.cursor_row += count
        if (self.cursor_row > self.scroll_bottom) {
            self.cursor_row = self.scroll_bottom
        }
    }

    /// Move cursor right by count columns, clamped to last column (CSI C).
    fn cursorRight(count: i64) void {
        self.pending_wrap = false
        self.cursor_col += count
        if (self.cursor_col >= self.grid.cols) {
            self.cursor_col = self.grid.cols - 1
        }
    }

    /// Move cursor left by count columns, clamped to column 0 (CSI D).
    fn cursorLeft(count: i64) void {
        self.pending_wrap = false
        self.cursor_col -= count
        if (self.cursor_col < 0) {
            self.cursor_col = 0
        }
    }

    /// Set absolute cursor position (0-indexed), clamped to grid bounds (CSI H).
    /// In origin mode, row is offset by scroll_top and clamped to scroll region.
    fn setCursorPos(row: i64, col: i64) void {
        self.pending_wrap = false
        if (self.mode_origin) {
            self.cursor_row = @max(self.scroll_top, @min(row + self.scroll_top, self.scroll_bottom))
        } else {
            self.cursor_row = @max(0, @min(row, self.grid.rows - 1))
        }
        self.cursor_col = @max(0, @min(col, self.grid.cols - 1))
    }

    // -- Scroll region (CSI r) ----------------------------------------------

    /// Set vertical scroll region (0-indexed, inclusive).
    /// Moves cursor to origin after setting the region.
    fn setScrollingRegion(top: i64, bottom: i64) void {
        var t = top
        var b = bottom
        if (t < 0) { t = 0 }
        if (b >= self.grid.rows) { b = self.grid.rows - 1 }
        if (t >= b) { return }
        self.scroll_top = t
        self.scroll_bottom = b
        self.setCursorPos(0, 0)
    }

    // -- Erase operations (CSI J/K) -----------------------------------------

    /// Erase in display: 0 = below cursor, 1 = above cursor, 2 = entire screen.
    /// Uses current SGR background (Ghostty: clearCells with cursor style bg).
    fn eraseInDisplay(mode: i64) void {
        self.pending_wrap = false
        var blank = self.blankCell()
        if (mode == 0) {
            var col = self.cursor_col
            while (col < self.grid.cols) {
                self.grid.getCell(self.cursor_row, col).* = blank
                col += 1
            }
            self.grid.setRowWrap(self.cursor_row, 0)
            var row = self.cursor_row + 1
            while (row < self.grid.rows) {
                self.clearLineWithBg(row, &blank)
                row += 1
            }
        } else if (mode == 1) {
            var row: i64 = 0
            while (row < self.cursor_row) {
                self.clearLineWithBg(row, &blank)
                row += 1
            }
            var col: i64 = 0
            while (col <= self.cursor_col) {
                self.grid.getCell(self.cursor_row, col).* = blank
                col += 1
            }
        } else if (mode == 2) {
            var row: i64 = 0
            while (row < self.grid.rows) {
                self.clearLineWithBg(row, &blank)
                row += 1
            }
        } else if (mode == 3) {
            // Erase scrollback — Ghostty ref: Terminal.zig eraseDisplay(.scrollback)
            // Keep only the active screen, discard all scrollback rows.
            self.grid.eraseScrollback()
            self.viewport_row = -1
        }
    }

    /// Erase in line: 0 = right of cursor, 1 = left of cursor, 2 = entire line.
    /// Uses current SGR background.
    fn eraseInLine(mode: i64) void {
        self.pending_wrap = false
        var blank = self.blankCell()
        if (mode == 0) {
            var col = self.cursor_col
            while (col < self.grid.cols) {
                self.grid.getCell(self.cursor_row, col).* = blank
                col += 1
            }
            self.grid.setRowWrap(self.cursor_row, 0)
        } else if (mode == 1) {
            var col: i64 = 0
            while (col <= self.cursor_col) {
                self.grid.getCell(self.cursor_row, col).* = blank
                col += 1
            }
        } else if (mode == 2) {
            self.clearLineWithBg(self.cursor_row, &blank)
        }
    }

    /// Clear a single row to the given blank cell and reset wrap/semantic flags.
    fn clearLineWithBg(row: i64, blank: *Cell) void {
        for col in 0..self.grid.cols {
            self.grid.getCell(row, col).* = blank.*
        }
        self.grid.setRowWrap(row, 0)
        self.grid.setRowSemantic(row, 0)
    }

    // -- Index / scroll (IND, RI) -------------------------------------------

    /// Index: move cursor down, scroll up if at bottom of scroll region.
    fn index_() void {
        self.pending_wrap = false
        if (self.cursor_row == self.scroll_bottom) {
            var blank = self.blankCell()
            self.grid.scrollUp(self.scroll_top, self.scroll_bottom, &blank)
        } else if (self.cursor_row < self.grid.rows - 1) {
            self.cursor_row += 1
        }
    }

    /// Reverse index: move cursor up, scroll down if at top of scroll region.
    fn reverseIndex() void {
        self.pending_wrap = false
        if (self.cursor_row == self.scroll_top) {
            var blank = self.blankCell()
            self.grid.scrollDown(self.scroll_top, self.scroll_bottom, &blank)
        } else if (self.cursor_row > 0) {
            self.cursor_row -= 1
        }
    }

    /// Back Index (DECBI): if cursor at col 0, shift scroll region right
    /// and blank col 0; otherwise move cursor left.
    fn backIndex() void {
        self.pending_wrap = false
        if (self.cursor_col == 0) {
            const blank = self.blankCell()
            // Shift all cells in each row of the scroll region right by one
            var row = self.scroll_top
            while (row <= self.scroll_bottom) {
                var col = self.grid.cols - 1
                while (col > 0) {
                    self.grid.getCell(row, col).* = self.grid.getCell(row, col - 1).*
                    col -= 1
                }
                self.grid.getCell(row, 0).* = blank
                row += 1
            }
        } else {
            self.cursor_col -= 1
        }
    }

    /// Forward Index (DECFI): if cursor at right margin, shift scroll region left
    /// and blank last col; otherwise move cursor right.
    fn forwardIndex() void {
        self.pending_wrap = false
        if (self.cursor_col >= self.grid.cols - 1) {
            const blank = self.blankCell()
            // Shift all cells in each row of the scroll region left by one
            var row = self.scroll_top
            while (row <= self.scroll_bottom) {
                var col: i64 = 0
                while (col < self.grid.cols - 1) {
                    self.grid.getCell(row, col).* = self.grid.getCell(row, col + 1).*
                    col += 1
                }
                self.grid.getCell(row, self.grid.cols - 1).* = blank
                row += 1
            }
        } else {
            self.cursor_col += 1
        }
    }

    // -- Insert / delete (CSI @, CSI P) -------------------------------------

    /// Insert count blank cells at cursor, shifting existing cells right (CSI @).
    /// Uses current SGR background for new cells.
    fn insertBlanks(count: i64) void {
        self.pending_wrap = false
        const row = self.cursor_row
        const col = self.cursor_col
        const n = @min(count, self.grid.cols - col)

        // Shift cells right (iterate right-to-left to handle overlap)
        var c = self.grid.cols - 1
        while (c >= col + n) {
            self.grid.getCell(row, c).* = self.grid.getCell(row, c - n).*
            c -= 1
        }

        // Fill inserted positions with blank cells carrying SGR bg
        const blank = self.blankCell()
        for i in 0..n {
            self.grid.getCell(row, col + i).* = blank
        }
    }

    /// Delete count cells at cursor, shifting remaining cells left (CSI P).
    /// Uses current SGR background for vacated cells.
    fn deleteChars(count: i64) void {
        self.pending_wrap = false
        const row = self.cursor_row
        const col = self.cursor_col
        const n = @min(count, self.grid.cols - col)

        // Shift cells left (iterate left-to-right to handle overlap)
        var c = col
        while (c < self.grid.cols - n) {
            self.grid.getCell(row, c).* = self.grid.getCell(row, c + n).*
            c += 1
        }

        // Clear vacated cells at end of line with SGR bg
        const blank = self.blankCell()
        c = self.grid.cols - n
        while (c < self.grid.cols) {
            self.grid.getCell(row, c).* = blank
            c += 1
        }
    }

    /// Insert count blank lines at cursor row (CSI L).
    /// Uses current SGR background. Cursor moves to column 0 per Ghostty.
    fn handleInsertLines(count: i64) void {
        self.pending_wrap = false
        var blank = self.blankCell()
        self.grid.insertLines(self.cursor_row, count, self.scroll_bottom, &blank)
        self.cursor_col = 0
    }

    /// Delete count lines at cursor row (CSI M).
    /// Uses current SGR background. Cursor moves to column 0 per Ghostty.
    fn handleDeleteLines(count: i64) void {
        self.pending_wrap = false
        var blank = self.blankCell()
        self.grid.deleteLines(self.cursor_row, count, self.scroll_bottom, &blank)
        self.cursor_col = 0
    }

    /// Erase N characters at cursor position without moving cursor (ECH).
    /// Uses current SGR background.
    fn eraseChars(count: i64) void {
        self.pending_wrap = false
        const row = self.cursor_row
        const col = self.cursor_col
        const n = @min(count, self.grid.cols - col)
        const blank = self.blankCell()
        for c in 0..n {
            self.grid.getCell(row, col + c).* = blank
        }
    }

    // -- Save / restore cursor (DECSC, DECRC) -------------------------------

    /// Save cursor position and state (DECSC).
    /// Ghostty ref: Screen.SavedCursor — saves pos, style, pending_wrap, origin, charset.
    fn saveCursor() void {
        self.saved_row = self.cursor_row
        self.saved_col = self.cursor_col
        self.saved_pending_wrap = self.pending_wrap
        self.saved_origin = self.mode_origin
        self.saved_fg_type = self.fg_type
        self.saved_fg_val = self.fg_val
        self.saved_bg_type = self.bg_type
        self.saved_bg_val = self.bg_val
        self.saved_bold = self.bold
        self.saved_dim = self.dim
        self.saved_italic = self.italic
        self.saved_underline = self.underline
        self.saved_inverse = self.inverse
        self.saved_strikethrough = self.strikethrough
        self.saved_blink = self.blink
        self.saved_hidden = self.hidden
        self.saved_overline = self.overline
        self.saved_double_underline = self.double_underline
        self.saved_ul_type = self.ul_type
        self.saved_ul_val = self.ul_val
        self.saved_charset_g0 = self.charset_g0
        self.saved_charset_g1 = self.charset_g1
        self.saved_charset_g2 = self.charset_g2
        self.saved_charset_g3 = self.charset_g3
        self.saved_active_charset = self.active_charset
    }

    /// Restore cursor position and state (DECRC).
    /// Ghostty ref: restores pos, style, pending_wrap, origin, charset.
    fn restoreCursor() void {
        self.cursor_row = self.saved_row
        self.cursor_col = self.saved_col
        self.pending_wrap = self.saved_pending_wrap
        self.mode_origin = self.saved_origin
        self.fg_type = self.saved_fg_type
        self.fg_val = self.saved_fg_val
        self.bg_type = self.saved_bg_type
        self.bg_val = self.saved_bg_val
        self.bold = self.saved_bold
        self.dim = self.saved_dim
        self.italic = self.saved_italic
        self.underline = self.saved_underline
        self.inverse = self.saved_inverse
        self.strikethrough = self.saved_strikethrough
        self.blink = self.saved_blink
        self.hidden = self.saved_hidden
        self.overline = self.saved_overline
        self.double_underline = self.saved_double_underline
        self.ul_type = self.saved_ul_type
        self.ul_val = self.saved_ul_val
        self.charset_g0 = self.saved_charset_g0
        self.charset_g1 = self.saved_charset_g1
        self.charset_g2 = self.saved_charset_g2
        self.charset_g3 = self.saved_charset_g3
        self.active_charset = self.saved_active_charset
    }

    // -- SGR attributes -----------------------------------------------------

    /// Reset all SGR attributes to defaults.
    fn resetAttributes() void {
        self.fg_type = self.default_fg_type
        self.fg_val = self.default_fg_val
        self.bg_type = self.default_bg_type
        self.bg_val = self.default_bg_val
        self.bold = false
        self.dim = false
        self.italic = false
        self.underline = false
        self.inverse = false
        self.strikethrough = false
        self.blink = false
        self.hidden = false
        self.overline = false
        self.double_underline = false
        self.ul_type = COLOR_NONE
        self.ul_val = 0
    }

    /// Update terminal colors after a theme change.
    /// With semantic colors, just update the palette — cells store palette indices,
    /// so they automatically reflect the new palette at render time. No cell walking needed.
    fn updateThemeColors() void {
        // Rebuild full 256-entry palette from new theme's 16-color palette
        self.palette = buildFullPalette(THEME_PALETTE)

        // Reset current SGR attributes to new defaults
        self.resetAttributes()
    }

    // -- Bell ---------------------------------------------------------------

    /// Signal a bell event (BEL).
    fn bell() void {
        self.bell_pending = true
    }

    // -- Title / PWD --------------------------------------------------------

    /// Set the terminal title from OSC buffer data.
    fn setTitle(buf: List(i64), start: i64, len: i64) void {
        if (len <= 0) { return }
        // Allocate or reuse title buffer
        if (self.title_buf == 0 or len > self.title_len) {
            self.title_buf = alloc(self.title_buf, len)
        }
        self.title_len = len
        for i in 0..len {
            @intToPtr(*u8, self.title_buf + i).* = @intCast(u8, buf.get(start + i))
        }
    }

    /// Set the icon/tab title (OSC 1). Stored separately from window title.
    fn setIconTitle(buf: List(i64), start: i64, len: i64) void {
        // Icon title is stored but not used for the window titlebar.
        // Modern terminals treat this as a tab-specific label.
    }

    /// Set the working directory from OSC 7 data.
    /// OSC 7 payload is typically "file://hostname/path" — we store the full URI
    /// so the Swift side can use it directly with URL(string:).
    fn setPwd(buf: List(i64), start: i64, len: i64) void {
        if (len <= 0) { return }
        if (self.pwd_buf == 0 or len > self.pwd_len) {
            self.pwd_buf = alloc(self.pwd_buf, len)
        }
        self.pwd_len = len
        for i in 0..len {
            @intToPtr(*u8, self.pwd_buf + i).* = @intCast(u8, buf.get(start + i))
        }
    }

    // -- Soft Reset (DECSTR) ------------------------------------------------

    /// Soft reset: resets modes and attributes without clearing the screen.
    fn softReset() void {
        self.resetAttributes()
        self.cursor_visible = true
        self.mode_app_cursor = false
        self.mode_bracketed_paste = false
        self.mode_mouse_tracking = 0
        self.mode_mouse_format = 0
        self.mode_focus_events = false
        self.mode_sync_output = false
        self.mode_origin = false
        self.mode_wraparound = true
        self.mode_mouse_alt_scroll = true
        self.mode_insert = false
        self.mode_reverse_video = false
        self.mode_cursor_blinking = false
        self.mode_reverse_wrap = false
        self.mode_app_keypad = false
        self.single_shift = 0
        self.scroll_top = 0
        self.scroll_bottom = self.grid.rows - 1
        self.charset_g0 = 0
        self.charset_g1 = 0
        self.charset_g2 = 0
        self.charset_g3 = 0
        self.active_charset = 0
        self.cursor_shape = 0
        self.pending_wrap = false
        self.mode_backspace_sends_bs = false
        self.mode_left_right_margin = false
        self.mode_sixel_scrolling = false
        self.mode_grapheme_cluster = false
        self.kittyKeyboardReset()
    }

    // -- Kitty Keyboard Protocol --------------------------------------------

    /// Get the Kitty keyboard flag at the given stack index.
    fn kittyKbdGet(idx: i64) i64 {
        return switch (idx) {
            0 => self.kitty_kbd_flags_0,
            1 => self.kitty_kbd_flags_1,
            2 => self.kitty_kbd_flags_2,
            3 => self.kitty_kbd_flags_3,
            4 => self.kitty_kbd_flags_4,
            5 => self.kitty_kbd_flags_5,
            6 => self.kitty_kbd_flags_6,
            7 => self.kitty_kbd_flags_7,
            else => 0,
        }
    }

    /// Set the Kitty keyboard flag at the given stack index.
    fn kittyKbdSet(idx: i64, val: i64) void {
        switch (idx) {
            0 => { self.kitty_kbd_flags_0 = val },
            1 => { self.kitty_kbd_flags_1 = val },
            2 => { self.kitty_kbd_flags_2 = val },
            3 => { self.kitty_kbd_flags_3 = val },
            4 => { self.kitty_kbd_flags_4 = val },
            5 => { self.kitty_kbd_flags_5 = val },
            6 => { self.kitty_kbd_flags_6 = val },
            7 => { self.kitty_kbd_flags_7 = val },
            else => {},
        }
    }

    /// Return the current Kitty keyboard flags (top of stack).
    fn kittyKeyboardFlags() i64 {
        if (self.kitty_kbd_idx == 0) { return 0 }
        return self.kittyKbdGet(self.kitty_kbd_idx - 1)
    }

    /// Push flags onto the Kitty keyboard stack.
    /// If stack is full (8), evict the oldest entry by shifting down.
    fn kittyKeyboardPush(flags: i64) void {
        if (self.kitty_kbd_idx >= 8) {
            // Shift everything down — evict oldest
            var i: i64 = 0
            while (i < 7) {
                self.kittyKbdSet(i, self.kittyKbdGet(i + 1))
                i += 1
            }
            self.kitty_kbd_idx = 7
        }
        self.kittyKbdSet(self.kitty_kbd_idx, flags)
        self.kitty_kbd_idx += 1
    }

    /// Pop n entries from the Kitty keyboard stack.
    fn kittyKeyboardPop(n: i64) void {
        self.kitty_kbd_idx -= n
        if (self.kitty_kbd_idx < 0) { self.kitty_kbd_idx = 0 }
    }

    /// Set Kitty keyboard flags with mode:
    /// 1 = replace (set), 2 = OR (union), 3 = NOT (difference).
    fn kittyKeyboardSetFlags(mode: i64, flags: i64) void {
        if (self.kitty_kbd_idx == 0) {
            // No entry on stack — push one
            self.kittyKeyboardPush(0)
        }
        const idx = self.kitty_kbd_idx - 1
        if (mode == 1) {
            self.kittyKbdSet(idx, flags)
        } else if (mode == 2) {
            self.kittyKbdSet(idx, self.kittyKbdGet(idx) | flags)
        } else if (mode == 3) {
            self.kittyKbdSet(idx, self.kittyKbdGet(idx) & (flags ^ 0x1F))
        }
    }

    /// Reset the Kitty keyboard stack.
    fn kittyKeyboardReset() void {
        self.kitty_kbd_flags_0 = 0
        self.kitty_kbd_flags_1 = 0
        self.kitty_kbd_flags_2 = 0
        self.kitty_kbd_flags_3 = 0
        self.kitty_kbd_flags_4 = 0
        self.kitty_kbd_flags_5 = 0
        self.kitty_kbd_flags_6 = 0
        self.kitty_kbd_flags_7 = 0
        self.kitty_kbd_idx = 0
    }

    /// Send a Kitty keyboard flags query response: CSI ? flags u
    fn sendKittyKeyboardReport() void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1b[?")
        self.writeDecimal(self.pty_fd, self.kittyKeyboardFlags())
        writeStr(self.pty_fd, "u")
    }

    // -- DEC Private Modes --------------------------------------------------

    /// Set or reset a DEC private mode.
    fn setDecMode(mode: i64, enable: bool) void {
        switch (mode) {
            1 => { self.mode_app_cursor = enable },
            6 => {
                self.mode_origin = enable
                self.setCursorPos(0, 0)
            },
            7 => { self.mode_wraparound = enable },
            25 => { self.cursor_visible = enable },
            47 => {
                // Mode 47: Legacy alt screen — just switch, no cursor save/restore, no clearing.
                // Ghostty ref: switchScreenMode(.@"47") — copy cursor only.
                if (enable) {
                    self.enterAltScreen()
                } else {
                    self.leaveAltScreen()
                }
            },
            1047 => {
                // Mode 1047: Alt screen — clears alt on exit.
                // Ghostty ref: switchScreenMode(.@"1047") — eraseDisplay on disable while on alt.
                if (enable) {
                    self.enterAltScreen()
                } else {
                    if (self.mode_alt_screen) {
                        self.eraseInDisplay(2)
                    }
                    self.leaveAltScreen()
                }
            },
            1048 => {
                // Save/restore cursor only (used alongside 47/1047)
                if (enable) {
                    self.saveCursor()
                } else {
                    self.restoreCursor()
                }
            },
            1049 => {
                // Mode 1049: Save cursor on enter, clear alt, restore cursor on exit.
                // Ghostty ref: switchScreenMode(.@"1049") — saveCursor on enable,
                // eraseDisplay + copy cursor on enter, restoreCursor on disable.
                if (enable) {
                    self.saveCursor()
                    self.enterAltScreen()
                } else {
                    self.leaveAltScreen()
                    self.restoreCursor()
                }
            },
            1000 => {
                if (enable) { self.mode_mouse_tracking = 1000 } else { self.mode_mouse_tracking = 0 }
            },
            1002 => {
                if (enable) { self.mode_mouse_tracking = 1002 } else { self.mode_mouse_tracking = 0 }
            },
            1003 => {
                if (enable) { self.mode_mouse_tracking = 1003 } else { self.mode_mouse_tracking = 0 }
            },
            1004 => { self.mode_focus_events = enable },
            1006 => {
                if (enable) { self.mode_mouse_format = 1006 } else { self.mode_mouse_format = 0 }
            },
            2004 => { self.mode_bracketed_paste = enable },
            2026 => { self.mode_sync_output = enable },
            1007 => { self.mode_mouse_alt_scroll = enable },
            5 => { self.mode_reverse_video = enable },
            12 => { self.mode_cursor_blinking = enable },
            45 => { self.mode_reverse_wrap = enable },
            3 => {
                // DECCOLM — 132/80 Column Mode (stub: clear + reset)
                self.eraseInDisplay(2)
                self.setCursorPos(0, 0)
                self.scroll_top = 0
                self.scroll_bottom = self.grid.rows - 1
            },
            66 => { self.mode_app_keypad = enable },
            67 => { self.mode_backspace_sends_bs = enable },
            69 => { self.mode_left_right_margin = enable },
            80 => { self.mode_sixel_scrolling = enable },
            2027 => { self.mode_grapheme_cluster = enable },
            2031 => { self.mode_report_color_scheme = enable },
            else => {},
        }
    }

    /// Set or reset a standard ANSI mode (CSI h/l without ? prefix).
    fn setAnsiMode(mode: i64, enable: bool) void {
        switch (mode) {
            2 => { self.mode_keyboard_action = enable },
            4 => { self.mode_insert = enable },
            12 => { self.mode_send_receive = enable },
            20 => { self.mode_linefeed_newline = enable },
            else => {},
        }
    }

    /// XTSAVE — Save a DEC private mode value (CSI ? Ps s).
    /// Ghostty ref: modes.zig save() — copies current value to saved slot.
    fn saveDecMode(mode: i64) void {
        switch (mode) {
            1 => { self.xtsaved_app_cursor = self.mode_app_cursor },
            5 => { self.xtsaved_reverse_video = self.mode_reverse_video },
            6 => { self.xtsaved_origin = self.mode_origin },
            7 => { self.xtsaved_wraparound = self.mode_wraparound },
            12 => { self.xtsaved_cursor_blinking = self.mode_cursor_blinking },
            25 => { self.xtsaved_cursor_visible = self.cursor_visible },
            45 => { self.xtsaved_reverse_wrap = self.mode_reverse_wrap },
            47, 1047, 1049 => { self.xtsaved_alt_screen = self.mode_alt_screen },
            66 => { self.xtsaved_app_keypad = self.mode_app_keypad },
            67 => { self.xtsaved_backspace_sends_bs = self.mode_backspace_sends_bs },
            69 => { self.xtsaved_left_right_margin = self.mode_left_right_margin },
            80 => { self.xtsaved_sixel_scrolling = self.mode_sixel_scrolling },
            1000 => { self.xtsaved_mouse_tracking = self.mode_mouse_tracking },
            1002 => { self.xtsaved_mouse_tracking = self.mode_mouse_tracking },
            1003 => { self.xtsaved_mouse_tracking = self.mode_mouse_tracking },
            1004 => { self.xtsaved_focus_events = self.mode_focus_events },
            1006 => { self.xtsaved_mouse_format = self.mode_mouse_format },
            1007 => { self.xtsaved_mouse_alt_scroll = self.mode_mouse_alt_scroll },
            2004 => { self.xtsaved_bracketed_paste = self.mode_bracketed_paste },
            2026 => { self.xtsaved_sync_output = self.mode_sync_output },
            2027 => { self.xtsaved_grapheme_cluster = self.mode_grapheme_cluster },
            else => {},
        }
    }

    /// XTRESTORE — Restore a DEC private mode value (CSI ? Ps r).
    /// Ghostty ref: modes.zig restore() — copies saved value back and applies side effects.
    fn restoreDecMode(mode: i64) void {
        switch (mode) {
            1 => { self.mode_app_cursor = self.xtsaved_app_cursor },
            5 => { self.mode_reverse_video = self.xtsaved_reverse_video },
            6 => {
                self.mode_origin = self.xtsaved_origin
                self.setCursorPos(0, 0)
            },
            7 => { self.mode_wraparound = self.xtsaved_wraparound },
            12 => { self.mode_cursor_blinking = self.xtsaved_cursor_blinking },
            25 => { self.cursor_visible = self.xtsaved_cursor_visible },
            45 => { self.mode_reverse_wrap = self.xtsaved_reverse_wrap },
            47, 1047, 1049 => {
                if (self.xtsaved_alt_screen and !self.mode_alt_screen) {
                    self.setDecMode(mode, true)
                } else if (!self.xtsaved_alt_screen and self.mode_alt_screen) {
                    self.setDecMode(mode, false)
                }
            },
            66 => { self.mode_app_keypad = self.xtsaved_app_keypad },
            67 => { self.mode_backspace_sends_bs = self.xtsaved_backspace_sends_bs },
            69 => { self.mode_left_right_margin = self.xtsaved_left_right_margin },
            80 => { self.mode_sixel_scrolling = self.xtsaved_sixel_scrolling },
            1000, 1002, 1003 => { self.mode_mouse_tracking = self.xtsaved_mouse_tracking },
            1004 => { self.mode_focus_events = self.xtsaved_focus_events },
            1006 => { self.mode_mouse_format = self.xtsaved_mouse_format },
            1007 => { self.mode_mouse_alt_scroll = self.xtsaved_mouse_alt_scroll },
            2004 => { self.mode_bracketed_paste = self.xtsaved_bracketed_paste },
            2026 => { self.mode_sync_output = self.xtsaved_sync_output },
            2027 => { self.mode_grapheme_cluster = self.xtsaved_grapheme_cluster },
            else => {},
        }
    }

    /// Query DEC private mode value. Returns 1 (set), 2 (reset), 0 (not recognized).
    fn queryDecMode(mode: i64) i64 {
        return switch (mode) {
            1 => { if (self.mode_app_cursor) { return 1 } else { return 2 } },
            5 => { if (self.mode_reverse_video) { return 1 } else { return 2 } },
            6 => { if (self.mode_origin) { return 1 } else { return 2 } },
            7 => { if (self.mode_wraparound) { return 1 } else { return 2 } },
            12 => { if (self.mode_cursor_blinking) { return 1 } else { return 2 } },
            25 => { if (self.cursor_visible) { return 1 } else { return 2 } },
            45 => { if (self.mode_reverse_wrap) { return 1 } else { return 2 } },
            47, 1047 => { if (self.mode_alt_screen) { return 1 } else { return 2 } },
            1000 => { if (self.mode_mouse_tracking == 1000) { return 1 } else { return 2 } },
            1002 => { if (self.mode_mouse_tracking == 1002) { return 1 } else { return 2 } },
            1003 => { if (self.mode_mouse_tracking == 1003) { return 1 } else { return 2 } },
            1004 => { if (self.mode_focus_events) { return 1 } else { return 2 } },
            1006 => { if (self.mode_mouse_format == 1006) { return 1 } else { return 2 } },
            1007 => { if (self.mode_mouse_alt_scroll) { return 1 } else { return 2 } },
            1049 => { if (self.mode_alt_screen) { return 1 } else { return 2 } },
            2004 => { if (self.mode_bracketed_paste) { return 1 } else { return 2 } },
            2026 => { if (self.mode_sync_output) { return 1 } else { return 2 } },
            3 => 2,  // DECCOLM — always report as reset (80-col)
            66 => { if (self.mode_app_keypad) { return 1 } else { return 2 } },
            67 => { if (self.mode_backspace_sends_bs) { return 1 } else { return 2 } },
            69 => { if (self.mode_left_right_margin) { return 1 } else { return 2 } },
            80 => { if (self.mode_sixel_scrolling) { return 1 } else { return 2 } },
            2027 => { if (self.mode_grapheme_cluster) { return 1 } else { return 2 } },
            2031 => { if (self.mode_report_color_scheme) { return 1 } else { return 2 } },
            else => 0,
        }
    }

    /// Send DEC mode report: ESC [ ? Ps ; Pm $ y
    fn sendModeReport(mode: i64, value: i64) void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1b[?")
        self.writeDecimal(self.pty_fd, mode)
        writeStr(self.pty_fd, ";")
        self.writeDecimal(self.pty_fd, value)
        writeStr(self.pty_fd, "$y")
    }

    /// Enter alternate screen buffer: save cursor and swap to a fresh grid.
    fn enterAltScreen() void {
        if (self.mode_alt_screen) { return }
        self.viewport_row = -1
        self.alt_cursor_row = self.cursor_row
        self.alt_cursor_col = self.cursor_col
        // Preserve the primary screen's full saved cursor state
        self.alt_saved_row = self.saved_row
        self.alt_saved_col = self.saved_col
        self.alt_saved_pending_wrap = self.saved_pending_wrap
        self.alt_saved_origin = self.saved_origin
        self.alt_saved_fg_type = self.saved_fg_type
        self.alt_saved_fg_val = self.saved_fg_val
        self.alt_saved_bg_type = self.saved_bg_type
        self.alt_saved_bg_val = self.saved_bg_val
        self.alt_saved_bold = self.saved_bold
        self.alt_saved_dim = self.saved_dim
        self.alt_saved_italic = self.saved_italic
        self.alt_saved_underline = self.saved_underline
        self.alt_saved_inverse = self.saved_inverse
        self.alt_saved_strikethrough = self.saved_strikethrough
        self.alt_saved_blink = self.saved_blink
        self.alt_saved_hidden = self.saved_hidden
        self.alt_saved_overline = self.saved_overline
        self.alt_saved_double_underline = self.saved_double_underline
        self.alt_saved_ul_type = self.saved_ul_type
        self.alt_saved_ul_val = self.saved_ul_val
        self.alt_saved_charset_g0 = self.saved_charset_g0
        self.alt_saved_charset_g1 = self.saved_charset_g1
        self.alt_saved_charset_g2 = self.saved_charset_g2
        self.alt_saved_charset_g3 = self.saved_charset_g3
        self.alt_saved_active_charset = self.saved_active_charset
        self.alt_grid = self.grid
        self.grid = TerminalGrid.init(self.grid.rows, self.grid.cols)
        self.grid.scrollback_enabled = 0
        self.cursor_row = 0
        self.cursor_col = 0
        self.scroll_top = 0
        self.scroll_bottom = self.grid.rows - 1
        self.pending_wrap = false
        self.mode_alt_screen = true
    }

    /// Leave alternate screen buffer: restore saved grid and cursor.
    fn leaveAltScreen() void {
        if (!self.mode_alt_screen) { return }
        self.grid = self.alt_grid
        self.cursor_row = self.alt_cursor_row
        self.cursor_col = self.alt_cursor_col
        // Restore the primary screen's full saved cursor state
        self.saved_row = self.alt_saved_row
        self.saved_col = self.alt_saved_col
        self.saved_pending_wrap = self.alt_saved_pending_wrap
        self.saved_origin = self.alt_saved_origin
        self.saved_fg_type = self.alt_saved_fg_type
        self.saved_fg_val = self.alt_saved_fg_val
        self.saved_bg_type = self.alt_saved_bg_type
        self.saved_bg_val = self.alt_saved_bg_val
        self.saved_bold = self.alt_saved_bold
        self.saved_dim = self.alt_saved_dim
        self.saved_italic = self.alt_saved_italic
        self.saved_underline = self.alt_saved_underline
        self.saved_inverse = self.alt_saved_inverse
        self.saved_strikethrough = self.alt_saved_strikethrough
        self.saved_blink = self.alt_saved_blink
        self.saved_hidden = self.alt_saved_hidden
        self.saved_overline = self.alt_saved_overline
        self.saved_double_underline = self.alt_saved_double_underline
        self.saved_ul_type = self.alt_saved_ul_type
        self.saved_ul_val = self.alt_saved_ul_val
        self.saved_charset_g0 = self.alt_saved_charset_g0
        self.saved_charset_g1 = self.alt_saved_charset_g1
        self.saved_charset_g2 = self.alt_saved_charset_g2
        self.saved_charset_g3 = self.alt_saved_charset_g3
        self.saved_active_charset = self.alt_saved_active_charset
        self.scroll_top = 0
        self.scroll_bottom = self.grid.rows - 1
        self.pending_wrap = false
        self.mode_alt_screen = false
        self.alt_grid = TerminalGrid.init(0, 0)
    }

    // -- Device Status Report / Device Attributes ---------------------------

    /// Send cursor position report: ESC [ row ; col R (1-indexed).
    fn sendCursorPositionReport() void {
        if (self.pty_fd < 0) { return }
        // Build response: ESC [ Pr ; Pc R
        writeStr(self.pty_fd, "\x1b[")
        self.writeDecimal(self.pty_fd, self.cursor_row + 1)
        writeStr(self.pty_fd, ";")
        self.writeDecimal(self.pty_fd, self.cursor_col + 1)
        writeStr(self.pty_fd, "R")
    }

    /// Send primary device attributes response (VT220 + color, matches Ghostty).
    fn sendPrimaryDeviceAttributes() void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1b[?62;22c")
    }

    /// Send secondary device attributes response (matches Ghostty).
    fn sendSecondaryDeviceAttributes() void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1b[>1;10;0c")
    }

    /// Send operating status report: terminal OK.
    fn sendOperatingStatus() void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1b[0n")
    }

    /// DECALN — Fill the entire screen with 'E' for alignment testing.
    fn decaln() void {
        for row in 0..self.grid.rows {
            for col in 0..self.grid.cols {
                var cell = self.grid.getCell(row, col)
                cell.codepoint = 'E'
                cell.fg_type = COLOR_NONE
                cell.fg_val = 0
                cell.bg_type = COLOR_NONE
                cell.bg_val = 0
            }
        }
        self.setCursorPos(0, 0)
    }

    /// Send color scheme report: CSI ? 997 ; Ps n
    /// Ps = 1 (dark), 2 (light). Based on bg luminance.
    fn sendColorSchemeReport() void {
        if (self.pty_fd < 0) { return }
        // Perceptual luminance: 0.299R + 0.587G + 0.114B (scaled by 1000)
        const lum = THEME_BG_R * 299 + THEME_BG_G * 587 + THEME_BG_B * 114
        if (lum < 128000) {
            writeStr(self.pty_fd, "\x1b[?997;1n")
        } else {
            writeStr(self.pty_fd, "\x1b[?997;2n")
        }
    }

    /// Send focus gained/lost event to the PTY (CSI I / CSI O).
    fn sendFocusEvent(focused: bool) void {
        if (self.pty_fd < 0) { return }
        if (!self.mode_focus_events) { return }
        if (focused) {
            writeStr(self.pty_fd, "\x1b[I")
        } else {
            writeStr(self.pty_fd, "\x1b[O")
        }
    }

    /// Send answerback message (ENQ response). Empty like Ghostty default.
    fn sendAnswerback() void {
        if (self.pty_fd < 0) { return }
        // Empty answerback (same as Ghostty default)
    }

    /// Send XTVERSION response: DCS >| cotty 0.1 ST
    fn sendXtversion() void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1bP>|cotty 0.1\x1b\\")
    }

    /// Send terminal size report in cells: ESC [ 8 ; rows ; cols t
    fn sendTerminalSizeReport() void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1b[8;")
        self.writeDecimal(self.pty_fd, self.grid.rows)
        writeStr(self.pty_fd, ";")
        self.writeDecimal(self.pty_fd, self.grid.cols)
        writeStr(self.pty_fd, "t")
    }

    /// Save the current title to the title stack.
    fn saveTitle() void {
        if (self.title_len > 0 and self.title_buf != 0) {
            self.title_stack_buf = alloc(self.title_stack_buf, self.title_len)
            memcpy(self.title_stack_buf, self.title_buf, self.title_len)
            self.title_stack_len = self.title_len
        }
    }

    /// Restore the title from the title stack.
    fn restoreTitle() void {
        if (self.title_stack_len > 0 and self.title_stack_buf != 0) {
            self.title_buf = alloc(self.title_buf, self.title_stack_len)
            memcpy(self.title_buf, self.title_stack_buf, self.title_stack_len)
            self.title_len = self.title_stack_len
        }
    }

    /// Write a 2-digit hex byte value to the PTY.
    fn writeHexByte(fd: i64, val: i64) void {
        const hi = (val >> 4) & 0x0F
        const lo = val & 0x0F
        if (hi < 10) { writeByte(fd, '0' + hi) } else { writeByte(fd, 'a' + hi - 10) }
        if (lo < 10) { writeByte(fd, '0' + lo) } else { writeByte(fd, 'a' + lo - 10) }
    }

    /// Send a color response for OSC queries: ESC ] osc_num ; rgb:RR/GG/BB ESC \
    fn sendColorResponse(osc_num: i64, r: i64, g: i64, b: i64) void {
        if (self.pty_fd < 0) { return }
        writeStr(self.pty_fd, "\x1b]")
        self.writeDecimal(self.pty_fd, osc_num)
        writeStr(self.pty_fd, ";rgb:")
        self.writeHexByte(self.pty_fd, r)
        writeStr(self.pty_fd, "/")
        self.writeHexByte(self.pty_fd, g)
        writeStr(self.pty_fd, "/")
        self.writeHexByte(self.pty_fd, b)
        writeStr(self.pty_fd, "\x1b\\")
    }

    /// Decode base64 clipboard data from OSC 52 and store it.
    fn setClipboard(buf: List(i64), start: i64, len: i64) void {
        // Allocate decode buffer (base64 expands 4:3, so decoded <= len)
        self.clipboard_buf = alloc(self.clipboard_buf, len)
        self.clipboard_len = base64Decode(buf, start, len, self.clipboard_buf)
        self.clipboard_request = 1
    }

    /// Mark that the application is querying the clipboard.
    fn requestClipboard() void {
        self.clipboard_request = 2
    }

    /// Write a decimal integer to an fd as ASCII digits.
    fn writeDecimal(fd: i64, val: i64) void {
        if (val == 0) {
            writeByte(fd, '0')
            return
        }
        // Stack digits (max 5 digits for terminal coords)
        var digits: i64 = 0
        var count: i64 = 0
        var v = val
        while (v > 0) {
            digits = digits * 10 + (v % 10)
            count += 1
            v = v / 10
        }
        // Write digits in correct order
        while (count > 0) {
            writeByte(fd, '0' + (digits % 10))
            digits = digits / 10
            count -= 1
        }
    }

    // -- Resize -------------------------------------------------------------

    /// Resize rows only (no column change), preserving content and wrap flags.
    /// Discards scrollback (active_start resets to 0 in new grid).
    fn resizeRowsOnly(new_rows: i64) void {
        var new_grid = TerminalGrid.init(new_rows, self.grid.cols)
        const copy_rows = @min(self.grid.rows, new_rows)

        var row: i64 = 0
        while (row < copy_rows) {
            const dst = new_grid.cells.items + (row * self.grid.cols) * @sizeOf(Cell)
            const src = self.grid.cells.items + ((self.grid.active_start + row) * self.grid.cols) * @sizeOf(Cell)
            memcpy(dst, src, self.grid.cols * @sizeOf(Cell))
            new_grid.setRowWrap(row, self.grid.getRowWrap(row))
            new_grid.setRowSemantic(row, self.grid.getRowSemantic(row))
            row += 1
        }

        self.grid = new_grid
        self.viewport_row = -1
        self.scroll_top = 0
        self.scroll_bottom = new_rows - 1
        self.cursor_row = @min(self.cursor_row, new_rows - 1)
        self.pending_wrap = false
        self.tabstops = initTabstops(self.grid.cols)
    }

    /// Resize the terminal to new dimensions with content reflow.
    /// Soft-wrapped lines are joined into logical lines and re-wrapped
    /// to the new column width. Cursor position is tracked through reflow.
    fn resize(new_rows: i64, new_cols: i64) void {
        if (new_rows == self.grid.rows and new_cols == self.grid.cols) { return }
        // Alt screen: TUI apps redraw after SIGWINCH, so skip reflow entirely.
        // Just create a blank grid and clamp cursor (like Ghostty).
        if (self.mode_alt_screen) {
            if (self.alt_grid.rows > 0) {
                self.alt_grid = TerminalGrid.init(new_rows, new_cols)
            }
            self.grid = TerminalGrid.init(new_rows, new_cols)
            if (self.cursor_row >= new_rows) { self.cursor_row = new_rows - 1 }
            if (self.cursor_col >= new_cols) { self.cursor_col = new_cols - 1 }
            self.scroll_top = 0
            self.scroll_bottom = new_rows - 1
            self.pending_wrap = false
            self.tabstops = initTabstops(new_cols)
            return
        }
        // When in alt screen, also resize the saved main grid
        if (self.alt_grid.rows > 0) {
            self.alt_grid = TerminalGrid.init(new_rows, new_cols)
        }
        if (new_cols == self.grid.cols) {
            self.resizeRowsOnly(new_rows)
            return
        }

        // Temp storage for reflowed output
        var out_cells: List(Cell) = .{}

        var out_wraps: List(i64) = .{}
        var out_semantics: List(i64) = .{}

        var out_rows: i64 = 0
        var new_cursor_row: i64 = 0
        var new_cursor_col: i64 = 0

        // Process each logical line (sequence of soft-wrapped rows)
        var src_row: i64 = 0
        while (src_row < self.grid.rows) {
            // Find extent of this logical line
            var line_start = src_row
            while (src_row < self.grid.rows - 1 and self.grid.getRowWrap(src_row) == 1) {
                src_row += 1
            }
            var line_end = src_row
            src_row += 1

            // Total cells in logical line
            var total_cells = (line_end - line_start + 1) * self.grid.cols

            // Trim trailing blank cells
            var content_len = total_cells
            while (content_len > 0) {
                var idx = content_len - 1
                var r = line_start + idx / self.grid.cols
                var c = idx % self.grid.cols
                var cell = self.grid.getCell(r, c)
                if (cell.codepoint != 0 and cell.codepoint != ' ') {
                    break
                }
                content_len -= 1
            }

            // Check if cursor is in this logical line
            var cursor_in_line = (self.cursor_row >= line_start and self.cursor_row <= line_end)
            var cursor_abs: i64 = 0
            if (cursor_in_line) {
                cursor_abs = (self.cursor_row - line_start) * self.grid.cols + self.cursor_col
            }

            // Number of output rows for this logical line
            var num_out: i64 = 1
            if (content_len > 0) {
                num_out = (content_len + new_cols - 1) / new_cols
            }

            var first_out = out_rows

            // Emit re-wrapped rows
            var row_idx: i64 = 0
            while (row_idx < num_out) {
                var col: i64 = 0
                while (col < new_cols) {
                    var abs_idx = row_idx * new_cols + col
                    if (abs_idx < total_cells) {
                        var r = line_start + abs_idx / self.grid.cols
                        var c = abs_idx % self.grid.cols
                        out_cells.append(self.grid.getCell(r, c).*)
                    } else {
                        out_cells.append(Cell.init())
                    }
                    col += 1
                }

                if (row_idx < num_out - 1) {
                    out_wraps.append(1)
                } else {
                    out_wraps.append(0)
                }
                // Semantic from first row of logical line propagates
                out_semantics.append(self.grid.getRowSemantic(line_start))

                out_rows += 1
                row_idx += 1
            }

            // Map cursor position within this logical line
            if (cursor_in_line) {
                if (content_len == 0) {
                    new_cursor_row = first_out
                    new_cursor_col = @min(cursor_abs, new_cols - 1)
                } else {
                    var c_row = cursor_abs / new_cols
                    var c_col = cursor_abs % new_cols
                    if (c_row >= num_out) {
                        c_row = num_out - 1
                        c_col = new_cols - 1
                    }
                    new_cursor_row = first_out + c_row
                    new_cursor_col = c_col
                }
            }
        }

        // Build new grid, keeping cursor visible at bottom of view
        var new_grid = TerminalGrid.init(new_rows, new_cols)

        var skip: i64 = 0
        if (out_rows > new_rows) {
            skip = new_cursor_row - new_rows + 1
            if (skip < 0) { skip = 0 }
            if (skip + new_rows > out_rows) { skip = out_rows - new_rows }
        }

        // Copy output rows into new grid
        var dst_row: i64 = 0
        var src_idx = skip
        while (src_idx < out_rows and dst_row < new_rows) {
            var col: i64 = 0
            while (col < new_cols) {
                var cell_idx = src_idx * new_cols + col
                new_grid.getCell(dst_row, col).* = @intToPtr(*Cell, out_cells.items + cell_idx * @sizeOf(Cell)).*
                col += 1
            }
            new_grid.setRowWrap(dst_row, @intToPtr(*i64, out_wraps.items + src_idx * @sizeOf(i64)).*)
            new_grid.setRowSemantic(dst_row, @intToPtr(*i64, out_semantics.items + src_idx * @sizeOf(i64)).*)
            dst_row += 1
            src_idx += 1
        }

        // Adjust cursor for skipped rows
        new_cursor_row -= skip
        if (new_cursor_row < 0) { new_cursor_row = 0 }
        if (new_cursor_row >= new_rows) { new_cursor_row = new_rows - 1 }
        if (new_cursor_col >= new_cols) { new_cursor_col = new_cols - 1 }

        self.grid = new_grid
        self.cursor_row = new_cursor_row
        self.cursor_col = new_cursor_col
        self.viewport_row = -1
        self.scroll_top = 0
        self.scroll_bottom = new_rows - 1
        self.pending_wrap = false
        self.tabstops = initTabstops(new_cols)
    }

    // -- Selection --------------------------------------------------------------

    /// Begin a new selection at (row, col). Marks selection active.
    fn selectionStart(row: i64, col: i64) void {
        self.sel_active = true
        self.sel_start_row = row
        self.sel_start_col = col
        self.sel_end_row = row
        self.sel_end_col = col
        self.markSelection()
    }

    /// Update the selection endpoint to (row, col) and recompute flags.
    fn selectionUpdate(row: i64, col: i64) void {
        self.sel_end_row = row
        self.sel_end_col = col
        self.markSelection()
    }

    /// Clear the selection and remove all CELL_SELECTED flags.
    fn selectionClear() void {
        self.sel_active = false
        self.clearSelectionFlags()
    }

    /// Remove CELL_SELECTED flag from every cell in the grid.
    fn clearSelectionFlags() void {
        var r: i64 = 0
        while (r < self.grid.rows) {
            var c: i64 = 0
            while (c < self.grid.cols) {
                const cell = self.grid.getCell(r, c)
                if ((cell.flags & CELL_SELECTED) != 0) {
                    cell.flags = cell.flags - CELL_SELECTED
                }
                c += 1
            }
            r += 1
        }
    }

    /// Recompute CELL_SELECTED flags on the grid based on current selection.
    fn markSelection() void {
        self.clearSelectionFlags()
        if (!self.sel_active) { return }

        // Normalize: ensure (sr,sc) <= (er,ec) lexicographically
        var sr = self.sel_start_row
        var sc = self.sel_start_col
        var er = self.sel_end_row
        var ec = self.sel_end_col
        if (sr > er or (sr == er and sc > ec)) {
            const tr = sr
            const tc = sc
            sr = er
            sc = ec
            er = tr
            ec = tc
        }

        // Clamp to grid bounds
        if (sr < 0) { sr = 0 }
        if (er >= self.grid.rows) { er = self.grid.rows - 1 }

        var row = sr
        while (row <= er) {
            var col_start: i64 = 0
            var col_end = self.grid.cols - 1

            if (row == sr) { col_start = sc }
            if (row == er) { col_end = ec }

            // Clamp columns
            if (col_start < 0) { col_start = 0 }
            if (col_end >= self.grid.cols) { col_end = self.grid.cols - 1 }

            var col = col_start
            while (col <= col_end) {
                self.grid.getCell(row, col).flags = self.grid.getCell(row, col).flags | CELL_SELECTED
                col += 1
            }
            row += 1
        }
    }

    /// Select the word around (row, col). Double-click behavior.
    /// A "word" is consecutive non-boundary codepoints. Space/null selects whitespace.
    fn selectWord(row: i64, col: i64) void {
        if (row < 0 or row >= self.grid.rows) { return }
        if (col < 0 or col >= self.grid.cols) { return }

        const cp = self.grid.getCell(row, col).codepoint
        const is_space = (cp == 0 or cp == ' ' or cp == '\t')

        // Expand left
        var left_col = col
        while (left_col > 0) {
            const prev = self.grid.getCell(row, left_col - 1).codepoint
            if (is_space) {
                if (prev != 0 and prev != ' ' and prev != '\t') { break }
            } else {
                if (prev == 0 or prev == ' ' or prev == '\t' or isWordBoundary(prev)) { break }
            }
            left_col -= 1
        }

        // Expand right
        var right_col = col
        while (right_col < self.grid.cols - 1) {
            const next = self.grid.getCell(row, right_col + 1).codepoint
            if (is_space) {
                if (next != 0 and next != ' ' and next != '\t') { break }
            } else {
                if (next == 0 or next == ' ' or next == '\t' or isWordBoundary(next)) { break }
            }
            right_col += 1
        }

        self.selectionStart(row, left_col)
        self.selectionUpdate(row, right_col)
    }

    /// Select the entire line at row. Triple-click behavior.
    /// For soft-wrapped lines, extends across wrap boundaries.
    fn selectLine(row: i64) void {
        if (row < 0 or row >= self.grid.rows) { return }

        // Find the start of the logical line (go back through soft-wraps)
        var start_row = row
        while (start_row > 0 and self.grid.getRowWrap(start_row - 1) == 1) {
            start_row -= 1
        }

        // Find the end of the logical line (go forward through soft-wraps)
        var end_row = row
        while (end_row < self.grid.rows - 1 and self.grid.getRowWrap(end_row) == 1) {
            end_row += 1
        }

        self.selectionStart(start_row, 0)
        self.selectionUpdate(end_row, self.grid.cols - 1)
    }

    /// Write selected text into a byte buffer. Returns number of bytes written.
    /// Codepoints are written as single bytes (ASCII). Rows separated by newlines.
    /// Trailing spaces on each row are trimmed.
    fn writeSelectedText(buf_ptr: i64, buf_cap: i64) i64 {
        if (!self.sel_active) { return 0 }

        // Normalize
        var sr = self.sel_start_row
        var sc = self.sel_start_col
        var er = self.sel_end_row
        var ec = self.sel_end_col
        if (sr > er or (sr == er and sc > ec)) {
            const tr = sr
            const tc = sc
            sr = er
            sc = ec
            er = tr
            ec = tc
        }

        if (sr < 0) { sr = 0 }
        if (er >= self.grid.rows) { er = self.grid.rows - 1 }

        var pos: i64 = 0
        var row = sr
        while (row <= er) {
            var col_start: i64 = 0
            var col_end = self.grid.cols - 1

            if (row == sr) { col_start = sc }
            if (row == er) { col_end = ec }

            if (col_start < 0) { col_start = 0 }
            if (col_end >= self.grid.cols) { col_end = self.grid.cols - 1 }

            // Find last non-blank column in this row's selection range
            var last_nonblank = col_start - 1
            var scan = col_start
            while (scan <= col_end) {
                const cp = self.grid.getCell(row, scan).codepoint
                if (cp != 0 and cp != ' ') {
                    last_nonblank = scan
                }
                scan += 1
            }

            // Write characters up to last non-blank
            var col = col_start
            while (col <= last_nonblank) {
                if (pos >= buf_cap) { return pos }
                var cp = self.grid.getCell(row, col).codepoint
                if (cp == 0) { cp = ' ' }
                @intToPtr(*u8, buf_ptr + pos).* = @intCast(u8, cp)
                pos += 1
                col += 1
            }

            // Add newline between rows (not after last)
            if (row < er) {
                if (pos >= buf_cap) { return pos }
                @intToPtr(*u8, buf_ptr + pos).* = @intCast(u8, '\n')
                pos += 1
            }
            row += 1
        }
        return pos
    }

    /// Scroll the viewport by delta rows. delta > 0 = show older content (scroll up).
    /// Ported from Ghostty's scrollViewport.
    fn scrollViewport(delta: i64) void {
        if (self.mode_alt_screen) { return }
        if (self.grid.active_start == 0) { return }

        if (delta > 0) {
            // Scroll up — show older content
            if (self.viewport_row < 0) {
                self.viewport_row = self.grid.active_start - delta
            } else {
                self.viewport_row = self.viewport_row - delta
            }
            if (self.viewport_row < 0) { self.viewport_row = 0 }
        } else if (delta < 0) {
            // Scroll down — show newer content
            if (self.viewport_row >= 0) {
                self.viewport_row = self.viewport_row - delta
                if (self.viewport_row >= self.grid.active_start) {
                    self.viewport_row = -1
                }
            }
        }

        if (self.sel_active) { self.selectionClear() }
    }

    /// Snap viewport to bottom (follow active).
    fn scrollToBottom() void {
        self.viewport_row = -1
    }

    /// Return true if viewport is at bottom (following active output).
    fn viewportIsBottom() bool {
        return self.viewport_row < 0
    }

    // -- Semantic prompts (OSC 133) -----------------------------------------

    /// Handle OSC 133 semantic prompt markers.
    /// 'A' = prompt start, 'B' = input start, 'C' = output start, 'D' = command end.
    fn handleSemanticPrompt(marker: i64) void {
        if (marker == 'A') {
            // Prompt start — if cursor not at col 0, do CR+LF first
            if (self.cursor_col > 0) {
                self.carriageReturn()
                self.newline()
            }
            self.grid.setRowSemantic(self.cursor_row, SEMANTIC_PROMPT)
        } else if (marker == 'B') {
            self.grid.setRowSemantic(self.cursor_row, SEMANTIC_INPUT)
        } else if (marker == 'C') {
            self.grid.setRowSemantic(self.cursor_row, SEMANTIC_OUTPUT)
        } else if (marker == 'D') {
            self.grid.setRowSemantic(self.cursor_row, SEMANTIC_OUTPUT)
        }
    }

    /// Jump to the previous prompt (scan upward for SEMANTIC_PROMPT).
    /// Returns the row found, or -1 if none.
    fn jumpToPreviousPrompt() i64 {
        var row = self.cursor_row - 1
        while (row >= 0) {
            if (self.grid.getRowSemantic(row) == SEMANTIC_PROMPT) {
                self.cursor_row = row
                self.cursor_col = 0
                self.pending_wrap = false
                self.scrollToBottom()
                return row
            }
            row -= 1
        }
        return -1
    }

    /// Jump to the next prompt (scan downward for SEMANTIC_PROMPT).
    /// Returns the row found, or -1 if none.
    fn jumpToNextPrompt() i64 {
        var row = self.cursor_row + 1
        while (row < self.grid.rows) {
            if (self.grid.getRowSemantic(row) == SEMANTIC_PROMPT) {
                self.cursor_row = row
                self.cursor_col = 0
                self.pending_wrap = false
                self.scrollToBottom()
                return row
            }
            row += 1
        }
        return -1
    }

    /// Handle a scroll wheel event. Ported from Ghostty's Surface.scrollCallback.
    /// Normalizes pixel deltas to cell-row units, accumulates fractional scroll,
    /// and dispatches as SGR mouse wheel events when mouse reporting is active.
    /// delta: scroll delta in millipoints (points * 1000, fixed-point).
    /// precise: 1 for trackpad (pixel deltas), 0 for discrete mouse wheel.
    /// cell_height: cell height in millipoints (points * 1000).
    /// col, row: 1-indexed terminal grid position.
    fn scrollEvent(fd: i64, delta: i64, precise: i64, cell_height: i64, col: i64, row: i64) void {
        if (cell_height <= 0) { return }

        // Normalize delta to millipoints.
        // Ghostty: precision scrolls use raw pixel deltas (Swift already 2x'd).
        // Discrete scrolls convert "line ticks" to pixels: tick * cell_height * 3.
        var adjusted = delta
        if (precise == 0) {
            adjusted = delta * cell_height * 3 / 1000
        }

        // Accumulate fractional scroll (Ghostty: mouse.pending_scroll_y)
        self.scroll_accumulator = self.scroll_accumulator + adjusted

        // Not enough for a full cell yet
        if (self.scroll_accumulator < 0) {
            if (self.scroll_accumulator > 0 - cell_height) { return }
        } else {
            if (self.scroll_accumulator < cell_height) { return }
        }

        // Calculate row delta (Ghostty: amount = poff / cell_size)
        var rows = self.scroll_accumulator / cell_height
        self.scroll_accumulator = self.scroll_accumulator - rows * cell_height

        // If mouse reporting active, send SGR wheel events
        // (Ghostty: self.isMouseReporting() → mouseReport)
        if (self.mode_mouse_tracking != 0) {
            var button: i64 = 65
            if (rows > 0) { button = 64 }
            if (rows < 0) { rows = 0 - rows }
            var i: i64 = 0
            while (i < rows) {
                mouseToTerminalBytes(fd, button, col, row, 1, self.mode_mouse_format, 0)
                i += 1
            }
            return
        }

        // Ghostty: alt screen + mouse_alternate_scroll mode → cursor keys
        if (self.mode_alt_screen and self.mode_mouse_alt_scroll) {
            // Convert scroll to cursor up/down keys
            var key_rows = rows
            if (key_rows < 0) { key_rows = 0 - key_rows }
            var j: i64 = 0
            while (j < key_rows) {
                if (rows > 0) {
                    writeStr(fd, "\x1b[A")
                } else {
                    writeStr(fd, "\x1b[B")
                }
                j += 1
            }
            return
        }

        // Scroll viewport (scrollback buffer)
        self.scrollViewport(rows)
    }
}

// ============================================================================
// PTY byte capture — records bytes sent by keyToTerminalBytes for inspector
// ============================================================================

var g_capture_active: bool = false
var g_capture_bytes: List(i64) = undefined
var g_capture_init: bool = false

fn captureBegin() void {
    if (!g_capture_init) {
        var init_bytes: List(i64) = .{}
        g_capture_bytes = init_bytes
        g_capture_init = true
    }
    g_capture_bytes.count = 0
    g_capture_active = true
}

fn captureEnd() List(i64) {
    g_capture_active = false
    return g_capture_bytes.clone()
}

// ============================================================================
// Terminal key input → VT100 bytes
// ============================================================================

/// Write a string to an fd.
fn writeStr(fd: i64, s: string) void {
    if (g_capture_active) {
        var i: i64 = 0
        while (i < @lenOf(s)) {
            g_capture_bytes.append(@intToPtr(*u8, @ptrOf(s) + i).*)
            i += 1
        }
    }
    fd_write(fd, @ptrOf(s), @lenOf(s))
}

/// Write a single byte to an fd.
var g_key_byte: i64 = 0

fn writeByte(fd: i64, val: i64) void {
    if (g_key_byte == 0) { g_key_byte = alloc(0, 1) }
    @intToPtr(*u8, g_key_byte).* = @intCast(u8, val)
    if (g_capture_active) {
        g_capture_bytes.append(val)
    }
    fd_write(fd, g_key_byte, 1)
}

/// Write a decimal integer to an fd as ASCII digits (free function version).
fn writeDecimalFree(fd: i64, val: i64) void {
    if (val == 0) {
        writeByte(fd, '0')
        return
    }
    var digits: i64 = 0
    var count: i64 = 0
    var v = val
    while (v > 0) {
        digits = digits * 10 + (v % 10)
        count += 1
        v = v / 10
    }
    while (count > 0) {
        writeByte(fd, '0' + (digits % 10))
        digits = digits / 10
        count -= 1
    }
}

/// Encode a mouse event and write to PTY fd.
/// Dispatches to SGR format (mode 1006) or classic X10 format based on format mode.
/// button: 0=left, 1=middle, 2=right, 32=drag, 64=wheel up, 65=wheel down.
/// col, row: 1-indexed terminal coordinates.
/// pressed: 1 for press/wheel, 0 for release.
/// mods: modifier bitmask (MOD_CTRL=1, MOD_SHIFT=2, MOD_ALT=4).
/// Ghostty ref: mouse.zig — shift adds 4, alt adds 8, ctrl adds 16 to button code.
fn mouseToTerminalBytes(fd: i64, button: i64, col: i64, row: i64, pressed: i64, format: i64, mods: i64) void {
    // Add modifier bits to button code per X10/SGR spec
    var btn = button
    if ((mods & MOD_SHIFT) != 0) { btn = btn + 4 }
    if ((mods & MOD_ALT) != 0) { btn = btn + 8 }
    if ((mods & MOD_CTRL) != 0) { btn = btn + 16 }

    if (format == 1006) {
        // SGR format: ESC [ < button ; col ; row M/m
        writeStr(fd, "\x1b[<")
        writeDecimalFree(fd, btn)
        writeStr(fd, ";")
        writeDecimalFree(fd, col)
        writeStr(fd, ";")
        writeDecimalFree(fd, row)
        if (pressed == 1) {
            writeStr(fd, "M")
        } else {
            writeStr(fd, "m")
        }
    } else {
        // X10 classic format: ESC [ M cb cx cy
        // Ghostty ref: input/mouse.zig — X10 encoding
        var cb = btn
        if (pressed == 0) { cb = 3 }  // All releases encoded as button 3 (but keep modifier bits)
        // Clamp coords to X10 range (max 223 = 255 - 32)
        var cx = col
        var cy = row
        if (cx > 223) { cx = 223 }
        if (cy > 223) { cy = 223 }
        writeStr(fd, "\x1b[M")
        writeByte(fd, @intCast(i64, cb + 32))
        writeByte(fd, @intCast(i64, cx + 32))
        writeByte(fd, @intCast(i64, cy + 32))
    }
}

/// Translate a key event into VT100 bytes and write to the given fd.
/// Handles modifiers (Shift, Alt, Ctrl) using xterm-style encoding:
///   modifier param = 1 + (shift?1:0) + (alt?2:0) + (ctrl?4:0)
fn keyToTerminalBytes(fd: i64, key: i64, mods: i64, app_cursor: bool) void {
    const has_ctrl = (mods & MOD_CTRL) != 0
    const has_shift = (mods & MOD_SHIFT) != 0
    const has_alt = (mods & MOD_ALT) != 0
    const has_mods = has_ctrl or has_shift or has_alt

    // Compute xterm modifier parameter: 1 + shift?1 + alt?2 + ctrl?4
    var mod_param: i64 = 1
    if (has_shift) { mod_param = mod_param + 1 }
    if (has_alt) { mod_param = mod_param + 2 }
    if (has_ctrl) { mod_param = mod_param + 4 }

    // Ctrl+key → control character
    // Ghostty ref: key_encode.zig ctrlSeq() — Kitty-compatible mapping
    if (has_ctrl and !has_shift and !has_alt) {
        if (key >= 'a' and key <= 'z') { writeByte(fd, key - 0x60); return }
        if (key >= 'A' and key <= 'Z') { writeByte(fd, key - 0x40); return }
        // Ctrl+special characters
        if (key == ' ' or key == '2' or key == '@') { writeByte(fd, 0); return }     // NUL
        if (key == '3') { writeByte(fd, 27); return }                                 // ESC
        if (key == '4' or key == '\\') { writeByte(fd, 28); return }                  // FS
        if (key == '5' or key == ']') { writeByte(fd, 29); return }                   // GS
        if (key == '6' or key == '^' or key == '~') { writeByte(fd, 30); return }     // RS
        if (key == '7' or key == '_' or key == '/') { writeByte(fd, 31); return }     // US
        if (key == '8' or key == '?') { writeByte(fd, 127); return }                  // DEL
    }

    // Shift+Tab → backtab (ESC [ Z)
    if (key == KEY_TAB and has_shift) {
        writeStr(fd, "\x1b[Z")
        return
    }

    // Arrow keys
    if (key == KEY_ARROW_UP or key == KEY_ARROW_DOWN or key == KEY_ARROW_RIGHT or key == KEY_ARROW_LEFT) {
        var letter: i64 = 'A'
        if (key == KEY_ARROW_DOWN) { letter = 'B' }
        if (key == KEY_ARROW_RIGHT) { letter = 'C' }
        if (key == KEY_ARROW_LEFT) { letter = 'D' }

        if (has_mods) {
            // Modified arrows: ESC [ 1 ; mod letter
            writeStr(fd, "\x1b[1;")
            writeDecimalFree(fd, mod_param)
            writeByte(fd, letter)
        } else if (app_cursor) {
            // App cursor mode: ESC O letter
            writeStr(fd, "\x1b")
            writeByte(fd, 'O')
            writeByte(fd, letter)
        } else {
            // Normal mode: ESC [ letter
            writeStr(fd, "\x1b[")
            writeByte(fd, letter)
        }
        return
    }

    // Home / End
    if (key == KEY_HOME or key == KEY_END) {
        var letter: i64 = 'H'
        if (key == KEY_END) { letter = 'F' }

        if (has_mods) {
            writeStr(fd, "\x1b[1;")
            writeDecimalFree(fd, mod_param)
            writeByte(fd, letter)
        } else if (app_cursor) {
            writeStr(fd, "\x1b")
            writeByte(fd, 'O')
            writeByte(fd, letter)
        } else {
            writeStr(fd, "\x1b[")
            writeByte(fd, letter)
        }
        return
    }

    // Insert (2~), Delete (3~), PageUp (5~), PageDown (6~) — tilde-encoded
    if (key == KEY_INSERT or key == KEY_DELETE or key == KEY_PAGE_UP or key == KEY_PAGE_DOWN) {
        var num: i64 = 3
        if (key == KEY_INSERT) { num = 2 }
        if (key == KEY_PAGE_UP) { num = 5 }
        if (key == KEY_PAGE_DOWN) { num = 6 }

        if (has_mods) {
            writeStr(fd, "\x1b[")
            writeDecimalFree(fd, num)
            writeStr(fd, ";")
            writeDecimalFree(fd, mod_param)
            writeStr(fd, "~")
        } else {
            writeStr(fd, "\x1b[")
            writeDecimalFree(fd, num)
            writeStr(fd, "~")
        }
        return
    }

    // Function keys F1-F4 (SS3: ESC O P/Q/R/S)
    if (key >= KEY_F1 and key <= KEY_F4) {
        var letter: i64 = 'P'
        if (key == KEY_F2) { letter = 'Q' }
        if (key == KEY_F3) { letter = 'R' }
        if (key == KEY_F4) { letter = 'S' }

        if (has_mods) {
            writeStr(fd, "\x1b[1;")
            writeDecimalFree(fd, mod_param)
            writeByte(fd, letter)
        } else {
            writeStr(fd, "\x1b")
            writeByte(fd, 'O')
            writeByte(fd, letter)
        }
        return
    }

    // Function keys F5-F12 (tilde encoding)
    if (key >= KEY_F5 and key <= KEY_F12) {
        // F5=15, F6=17, F7=18, F8=19, F9=20, F10=21, F11=23, F12=24
        var num: i64 = 15
        if (key == KEY_F6) { num = 17 }
        if (key == KEY_F7) { num = 18 }
        if (key == KEY_F8) { num = 19 }
        if (key == KEY_F9) { num = 20 }
        if (key == KEY_F10) { num = 21 }
        if (key == KEY_F11) { num = 23 }
        if (key == KEY_F12) { num = 24 }

        if (has_mods) {
            writeStr(fd, "\x1b[")
            writeDecimalFree(fd, num)
            writeStr(fd, ";")
            writeDecimalFree(fd, mod_param)
            writeStr(fd, "~")
        } else {
            writeStr(fd, "\x1b[")
            writeDecimalFree(fd, num)
            writeStr(fd, "~")
        }
        return
    }

    // Function keys F13-F20 (tilde encoding)
    // F13=25, F14=26, F15=28, F16=29, F17=31, F18=32, F19=33, F20=34
    if (key >= KEY_F13 and key <= KEY_F20) {
        var num: i64 = 25
        if (key == KEY_F14) { num = 26 }
        if (key == KEY_F15) { num = 28 }
        if (key == KEY_F16) { num = 29 }
        if (key == KEY_F17) { num = 31 }
        if (key == KEY_F18) { num = 32 }
        if (key == KEY_F19) { num = 33 }
        if (key == KEY_F20) { num = 34 }

        if (has_mods) {
            writeStr(fd, "\x1b[")
            writeDecimalFree(fd, num)
            writeStr(fd, ";")
            writeDecimalFree(fd, mod_param)
            writeStr(fd, "~")
        } else {
            writeStr(fd, "\x1b[")
            writeDecimalFree(fd, num)
            writeStr(fd, "~")
        }
        return
    }

    // Numpad keys — application keypad mode sends SS3 codes, normal mode sends characters
    if (key == KEY_KP_ENTER) { writeStr(fd, "\r"); return }
    if (key >= KEY_KP_0 and key <= KEY_KP_9) {
        writeByte(fd, '0' + (key - KEY_KP_0))
        return
    }
    if (key == KEY_KP_DECIMAL) { writeByte(fd, '.'); return }
    if (key == KEY_KP_MULTIPLY) { writeByte(fd, '*'); return }
    if (key == KEY_KP_PLUS) { writeByte(fd, '+'); return }
    if (key == KEY_KP_DIVIDE) { writeByte(fd, '/'); return }
    if (key == KEY_KP_MINUS) { writeByte(fd, '-'); return }

    // Backspace/Enter/Tab/Escape — with modifier encoding
    // Ghostty ref: key_encode.zig — modified special keys use CSI code;mod ~
    if (key == KEY_BACKSPACE) {
        if (has_alt and !has_ctrl) { writeStr(fd, "\x1b\x7f"); return }  // Alt+BS = ESC DEL
        if (has_ctrl) { writeStr(fd, "\x08"); return }                     // Ctrl+BS = BS (0x08)
        writeStr(fd, "\x7f"); return
    }
    if (key == KEY_ENTER) {
        if (has_alt and !has_ctrl) { writeStr(fd, "\x1b\r"); return }    // Alt+Enter = ESC CR
        if (has_ctrl) { writeStr(fd, "\x1b\r"); return }                   // Ctrl+Enter = ESC CR
        writeStr(fd, "\r"); return
    }
    if (key == KEY_TAB) {
        if (has_ctrl) {
            // Ctrl+Tab — no standard legacy encoding, send as-is
            writeStr(fd, "\t"); return
        }
        writeStr(fd, "\t"); return
    }
    if (key == KEY_ESCAPE) {
        if (has_alt) { writeStr(fd, "\x1b\x1b"); return }               // Alt+Esc = ESC ESC
        writeStr(fd, "\x1b"); return
    }

    // Alt+printable → ESC + key (meta prefix)
    if (has_alt and !has_ctrl and key >= 32 and key <= 126) {
        writeStr(fd, "\x1b")
        writeByte(fd, key)
        return
    }

    // Printable ASCII → write the byte directly
    if (key >= 32 and key <= 126) {
        writeByte(fd, key)
    }
}

// ============================================================================
// Kitty keyboard encoding
// ============================================================================

/// Map a KEY_* constant to its Kitty legacy codepoint and final byte.
/// Returns (codepoint, final_byte). Final 'u' means CSI codepoint;mods u format.
/// Other finals use legacy CSI code;mods final format (arrows, F-keys, etc).
fn kittyMapping(key: i64) (i64, i64) {
    return switch (key) {
        KEY_ESCAPE => (27, 'u'),
        KEY_ENTER => (13, 'u'),
        KEY_TAB => (9, 'u'),
        KEY_BACKSPACE => (127, 'u'),
        KEY_ARROW_UP => (1, 'A'),
        KEY_ARROW_DOWN => (1, 'B'),
        KEY_ARROW_RIGHT => (1, 'C'),
        KEY_ARROW_LEFT => (1, 'D'),
        KEY_HOME => (1, 'H'),
        KEY_END => (1, 'F'),
        KEY_F1 => (1, 'P'),
        KEY_F2 => (1, 'Q'),
        KEY_F3 => (1, 'R'),
        KEY_F4 => (1, 'S'),
        KEY_F5 => (15, '~'),
        KEY_F6 => (17, '~'),
        KEY_F7 => (18, '~'),
        KEY_F8 => (19, '~'),
        KEY_F9 => (20, '~'),
        KEY_F10 => (21, '~'),
        KEY_F11 => (23, '~'),
        KEY_F12 => (24, '~'),
        KEY_INSERT => (2, '~'),
        KEY_DELETE => (3, '~'),
        KEY_PAGE_UP => (5, '~'),
        KEY_PAGE_DOWN => (6, '~'),
        KEY_F13 => (25, '~'),
        KEY_F14 => (26, '~'),
        KEY_F15 => (28, '~'),
        KEY_F16 => (29, '~'),
        KEY_F17 => (31, '~'),
        KEY_F18 => (32, '~'),
        KEY_F19 => (33, '~'),
        KEY_F20 => (34, '~'),
        KEY_KP_ENTER => (57414, 'u'),
        KEY_KP_0 => (57399, 'u'),
        KEY_KP_1 => (57400, 'u'),
        KEY_KP_2 => (57401, 'u'),
        KEY_KP_3 => (57402, 'u'),
        KEY_KP_4 => (57403, 'u'),
        KEY_KP_5 => (57404, 'u'),
        KEY_KP_6 => (57405, 'u'),
        KEY_KP_7 => (57406, 'u'),
        KEY_KP_8 => (57407, 'u'),
        KEY_KP_9 => (57408, 'u'),
        KEY_KP_DECIMAL => (57409, 'u'),
        KEY_KP_DIVIDE => (57410, 'u'),
        KEY_KP_MULTIPLY => (57411, 'u'),
        KEY_KP_MINUS => (57412, 'u'),
        KEY_KP_PLUS => (57413, 'u'),
        else => {
            // Printable ASCII uses 'u' final with the codepoint itself
            if (key >= 32 and key <= 126) {
                return (key, 'u')
            }
            return (0, 0)
        },
    }
}

/// Encode a key event using the Kitty keyboard protocol and write to PTY.
/// flags: current kitty keyboard flags from the stack.
/// event_type: 0=press, 1=repeat, 2=release.
fn keyToTerminalBytesKitty(fd: i64, key: i64, mods: i64, flags: i64, event_type: i64, app_cursor: bool) void {
    // If no kitty flags active, fall through to legacy encoding
    if (flags == 0) {
        if (event_type != 0) { return }  // Legacy doesn't support repeat/release
        keyToTerminalBytes(fd, key, mods, app_cursor)
        return
    }

    const codepoint, final = kittyMapping(key)
    if (codepoint == 0) { return }

    // Skip non-press events unless report_events (bit 1) is set
    if (event_type != 0 and (flags & 2) == 0) { return }

    // Build kitty modifier value: 1 + shift(1) + alt(2) + ctrl(4) + super(8)
    var kitty_mods: i64 = 1
    if ((mods & MOD_SHIFT) != 0) { kitty_mods = kitty_mods + 1 }
    if ((mods & MOD_ALT) != 0) { kitty_mods = kitty_mods + 2 }
    if ((mods & MOD_CTRL) != 0) { kitty_mods = kitty_mods + 4 }
    if ((mods & MOD_SUPER) != 0) { kitty_mods = kitty_mods + 8 }

    const has_mods = kitty_mods > 1
    const has_event = event_type > 0

    // Unless report_all_keys (bit 3), special-case unmodified simple keys
    if ((flags & 8) == 0) {
        if (!has_mods and !has_event) {
            if (codepoint == 13 and final == 'u') { writeStr(fd, "\r"); return }
            if (codepoint == 9 and final == 'u') { writeStr(fd, "\t"); return }
            if (codepoint == 127 and final == 'u') { writeStr(fd, "\x7f"); return }
            if (codepoint == 27 and final == 'u') { writeStr(fd, "\x1b"); return }
            // Unmodified printable → send raw byte
            if (final == 'u' and codepoint >= 32 and codepoint <= 126) {
                writeByte(fd, codepoint)
                return
            }
        }
    }

    // Build CSI sequence
    writeStr(fd, "\x1b[")

    if (final == 'u') {
        // CSI codepoint [;mods[:event]] u
        writeDecimalFree(fd, codepoint)
        if (has_mods or has_event) {
            writeStr(fd, ";")
            writeDecimalFree(fd, kitty_mods)
            if (has_event) {
                writeStr(fd, ":")
                writeDecimalFree(fd, event_type + 1)  // 1=press, 2=repeat, 3=release
            }
        }
        writeByte(fd, 'u')
    } else {
        // Legacy final: CSI [code] [;mods[:event]] final
        // For keys where code==1, omit it when no mods (matches xterm behavior)
        if (codepoint != 1 or has_mods or has_event) {
            writeDecimalFree(fd, codepoint)
        }
        if (has_mods or has_event) {
            writeStr(fd, ";")
            writeDecimalFree(fd, kitty_mods)
            if (has_event) {
                writeStr(fd, ":")
                writeDecimalFree(fd, event_type + 1)
            }
        }
        writeByte(fd, final)
    }
}

// ============================================================================
// Tests — Grid
// ============================================================================

test "grid init" {
    var g = TerminalGrid.init(24, 80)
    @assertEq(g.rows, 24)
    @assertEq(g.cols, 80)
    @assertEq(g.cells.count, 1920)
}

test "grid getCell read write" {
    var g = TerminalGrid.init(3, 4)
    const c = g.getCell(1, 2)
    @assert(c.isBlank())
    c.codepoint = 'X'
    @assertEq(g.getCell(1, 2).codepoint, 'X')
}

test "grid clear" {
    var g = TerminalGrid.init(3, 4)
    g.getCell(0, 0).codepoint = 'A'
    g.getCell(2, 3).codepoint = 'Z'
    g.clear()
    @assert(g.getCell(0, 0).isBlank())
    @assert(g.getCell(2, 3).isBlank())
}

test "grid clearLine leaves other rows" {
    var g = TerminalGrid.init(3, 4)
    g.getCell(0, 0).codepoint = 'K'
    g.getCell(1, 0).codepoint = 'A'
    g.getCell(1, 3).codepoint = 'Z'
    g.clearLine(1)
    @assert(g.getCell(1, 0).isBlank())
    @assert(g.getCell(1, 3).isBlank())
    @assertEq(g.getCell(0, 0).codepoint, 'K')
}

test "grid scrollUp shifts content" {
    var g = TerminalGrid.init(3, 4)
    g.getCell(0, 0).codepoint = 'A'
    g.getCell(1, 0).codepoint = 'B'
    g.getCell(2, 0).codepoint = 'C'
    var su_blank = Cell.init()
    g.scrollUp(0, 2, &su_blank)
    @assertEq(g.getCell(0, 0).codepoint, 'B')
    @assertEq(g.getCell(1, 0).codepoint, 'C')
    @assert(g.getCell(2, 0).isBlank())
}

test "grid scrollUp preserves default colors" {
    var g = TerminalGrid.init(3, 4)
    g.getCell(0, 0).codepoint = 'A'
    var su_blank = Cell.init()
    g.scrollUp(0, 2, &su_blank)
    @assertEq(g.getCell(2, 0).fg_type, COLOR_NONE)
    @assertEq(g.getCell(2, 0).bg_type, COLOR_NONE)
}

test "grid scrollDown shifts content" {
    var g = TerminalGrid.init(3, 4)
    g.getCell(0, 0).codepoint = 'A'
    g.getCell(1, 0).codepoint = 'B'
    g.getCell(2, 0).codepoint = 'C'
    var sd_blank = Cell.init()
    g.scrollDown(0, 2, &sd_blank)
    @assert(g.getCell(0, 0).isBlank())
    @assertEq(g.getCell(1, 0).codepoint, 'A')
    @assertEq(g.getCell(2, 0).codepoint, 'B')
}

// ============================================================================
// Tests — State: character output
// ============================================================================

test "putChar basic" {
    var t = TerminalState.init(24, 80)
    t.putChar('H')
    t.putChar('i')
    @assertEq(t.cursor_col, 2)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'H')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'i')
}

test "putChar applies SGR attributes" {
    var t = TerminalState.init(24, 80)
    t.fg_type = COLOR_RGB
    t.fg_val = packRgb(255, 0, 0)
    t.bold = true
    t.putChar('X')
    const c = t.grid.getCell(0, 0)
    @assertEq(c.fg_type, COLOR_RGB)
    @assertEq(c.fg_val, packRgb(255, 0, 0))
    @assertEq(c.flags & CELL_BOLD, CELL_BOLD)
}

test "putChar deferred wrap at last column" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    // Cursor stays at last column with pending wrap
    @assertEq(t.cursor_col, 3)
    @assertEq(t.pending_wrap, true)
    // Next character triggers the deferred wrap
    t.putChar('E')
    @assertEq(t.cursor_row, 1)
    @assertEq(t.cursor_col, 1)
    @assertEq(t.grid.getCell(1, 0).codepoint, 'E')
    @assertEq(t.pending_wrap, false)
}

test "putChar wrap scrolls at bottom" {
    var t = TerminalState.init(3, 4)
    t.cursor_row = 2
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    // pending_wrap is set at end of last row
    @assertEq(t.pending_wrap, true)
    t.putChar('E')
    // Should have scrolled: cursor still on row 2
    @assertEq(t.cursor_row, 2)
    @assertEq(t.grid.getCell(2, 0).codepoint, 'E')
}

// ============================================================================
// Tests — State: C0 controls
// ============================================================================

test "newline moves down" {
    var t = TerminalState.init(24, 80)
    t.putChar('A')
    t.newline()
    @assertEq(t.cursor_row, 1)
    // LF only moves down, does not reset column (VT100)
    @assertEq(t.cursor_col, 1)
}

test "newline scrolls at bottom" {
    var t = TerminalState.init(3, 4)
    t.cursor_row = 2
    t.putChar('X')
    t.newline()
    @assertEq(t.cursor_row, 2)
    @assert(t.grid.getCell(0, 0).isBlank())
}

test "carriageReturn resets column" {
    var t = TerminalState.init(24, 80)
    t.putChar('A')
    t.putChar('B')
    t.carriageReturn()
    @assertEq(t.cursor_col, 0)
    @assertEq(t.pending_wrap, false)
}

test "backspace clamps at zero" {
    var t = TerminalState.init(24, 80)
    t.putChar('A')
    t.putChar('B')
    t.backspace()
    @assertEq(t.cursor_col, 1)
    t.backspace()
    @assertEq(t.cursor_col, 0)
    t.backspace()
    @assertEq(t.cursor_col, 0)
}

test "tab advances to next stop" {
    var t = TerminalState.init(24, 80)
    t.tab()
    @assertEq(t.cursor_col, 8)
    t.putChar('A')
    t.tab()
    @assertEq(t.cursor_col, 16)
}

// ============================================================================
// Tests — State: cursor movement
// ============================================================================

test "cursorUp clamps at scroll top" {
    var t = TerminalState.init(24, 80)
    t.cursor_row = 5
    t.cursorUp(3)
    @assertEq(t.cursor_row, 2)
    t.cursorUp(100)
    @assertEq(t.cursor_row, 0)
}

test "cursorDown clamps at scroll bottom" {
    var t = TerminalState.init(24, 80)
    t.cursorDown(10)
    @assertEq(t.cursor_row, 10)
    t.cursorDown(100)
    @assertEq(t.cursor_row, 23)
}

test "cursorRight clamps at last column" {
    var t = TerminalState.init(24, 80)
    t.cursorRight(10)
    @assertEq(t.cursor_col, 10)
    t.cursorRight(100)
    @assertEq(t.cursor_col, 79)
}

test "cursorLeft clamps at zero" {
    var t = TerminalState.init(24, 80)
    t.cursor_col = 10
    t.cursorLeft(3)
    @assertEq(t.cursor_col, 7)
    t.cursorLeft(100)
    @assertEq(t.cursor_col, 0)
}

test "setCursorPos clamps to bounds" {
    var t = TerminalState.init(24, 80)
    t.setCursorPos(5, 10)
    @assertEq(t.cursor_row, 5)
    @assertEq(t.cursor_col, 10)
    t.setCursorPos(100, 200)
    @assertEq(t.cursor_row, 23)
    @assertEq(t.cursor_col, 79)
}

test "setCursorPos clears pending wrap" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    @assertEq(t.pending_wrap, true)
    t.setCursorPos(0, 0)
    @assertEq(t.pending_wrap, false)
}

// ============================================================================
// Tests — State: scroll region
// ============================================================================

test "setScrollingRegion" {
    var t = TerminalState.init(24, 80)
    t.cursor_row = 10
    t.cursor_col = 40
    t.setScrollingRegion(5, 20)
    @assertEq(t.scroll_top, 5)
    @assertEq(t.scroll_bottom, 20)
    // Cursor moves to origin after setting region
    @assertEq(t.cursor_row, 0)
    @assertEq(t.cursor_col, 0)
}

test "cursorUp respects scroll region" {
    var t = TerminalState.init(24, 80)
    t.setScrollingRegion(5, 20)
    t.setCursorPos(7, 0)
    t.cursorUp(100)
    @assertEq(t.cursor_row, 5)
}

// ============================================================================
// Tests — State: erase operations
// ============================================================================

test "eraseInDisplay all" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.eraseInDisplay(2)
    @assert(t.grid.getCell(0, 0).isBlank())
    @assert(t.grid.getCell(0, 1).isBlank())
}

test "eraseInDisplay below" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.newline()
    t.carriageReturn()
    t.putChar('E')
    t.putChar('F')
    // Cursor at (1, 2), erase from cursor to end
    t.eraseInDisplay(0)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(1, 0).codepoint, 'E')
    @assertEq(t.grid.getCell(1, 1).codepoint, 'F')
    @assert(t.grid.getCell(1, 2).isBlank())
    @assert(t.grid.getCell(2, 0).isBlank())
}

test "eraseInLine right" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.setCursorPos(0, 2)
    t.eraseInLine(0)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'B')
    @assert(t.grid.getCell(0, 2).isBlank())
    @assert(t.grid.getCell(0, 3).isBlank())
}

test "eraseInLine left" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.setCursorPos(0, 2)
    t.eraseInLine(1)
    @assert(t.grid.getCell(0, 0).isBlank())
    @assert(t.grid.getCell(0, 1).isBlank())
    @assert(t.grid.getCell(0, 2).isBlank())
    @assertEq(t.grid.getCell(0, 3).codepoint, 'D')
}

// ============================================================================
// Tests — State: index / reverse index
// ============================================================================

test "index moves down" {
    var t = TerminalState.init(3, 4)
    t.cursor_row = 1
    t.index_()
    @assertEq(t.cursor_row, 2)
}

test "index at bottom scrolls" {
    var t = TerminalState.init(3, 4)
    t.cursor_row = 2
    t.grid.getCell(0, 0).codepoint = 'A'
    t.index_()
    @assertEq(t.cursor_row, 2)
    @assert(t.grid.getCell(0, 0).isBlank())
}

test "reverseIndex at top scrolls" {
    var t = TerminalState.init(3, 4)
    t.grid.getCell(0, 0).codepoint = 'A'
    t.reverseIndex()
    @assertEq(t.cursor_row, 0)
    @assertEq(t.grid.getCell(1, 0).codepoint, 'A')
}

// ============================================================================
// Tests — State: insert / delete
// ============================================================================

test "insertBlanks shifts cells right" {
    var t = TerminalState.init(3, 6)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.setCursorPos(0, 1)
    t.insertBlanks(2)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assert(t.grid.getCell(0, 1).isBlank())
    @assert(t.grid.getCell(0, 2).isBlank())
    @assertEq(t.grid.getCell(0, 3).codepoint, 'B')
    @assertEq(t.grid.getCell(0, 4).codepoint, 'C')
    @assertEq(t.grid.getCell(0, 5).codepoint, 'D')
}

test "deleteChars shifts cells left" {
    var t = TerminalState.init(3, 6)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.putChar('E')
    t.putChar('F')
    t.setCursorPos(0, 1)
    t.deleteChars(2)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'D')
    @assertEq(t.grid.getCell(0, 2).codepoint, 'E')
    @assertEq(t.grid.getCell(0, 3).codepoint, 'F')
    @assert(t.grid.getCell(0, 4).isBlank())
    @assert(t.grid.getCell(0, 5).isBlank())
}

// ============================================================================
// Tests — State: save/restore, attributes, resize
// ============================================================================

test "saveCursor restoreCursor" {
    var t = TerminalState.init(24, 80)
    t.setCursorPos(5, 10)
    t.saveCursor()
    t.setCursorPos(0, 0)
    t.restoreCursor()
    @assertEq(t.cursor_row, 5)
    @assertEq(t.cursor_col, 10)
}

test "resetAttributes restores defaults" {
    var t = TerminalState.init(3, 4)
    t.fg_type = COLOR_RGB
    t.fg_val = packRgb(255, 0, 0)
    t.bold = true
    t.resetAttributes()
    @assertEq(t.fg_type, t.default_fg_type)
    @assertEq(t.fg_val, t.default_fg_val)
    @assertEq(t.bold, false)
}

test "resize preserves content" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.resize(5, 6)
    @assertEq(t.grid.rows, 5)
    @assertEq(t.grid.cols, 6)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'B')
    @assertEq(t.scroll_bottom, 4)
}

test "resize shrink clamps cursor" {
    var t = TerminalState.init(24, 80)
    t.setCursorPos(20, 70)
    t.resize(10, 40)
    @assertEq(t.cursor_row, 9)
    @assertEq(t.cursor_col, 39)
    @assertEq(t.pending_wrap, false)
}

// ============================================================================
// Tests — Resize reflow
// ============================================================================

test "reflow shrink wraps long line" {
    // "ABCDEF" on a 6-col terminal, resize to 3 cols → 2 rows
    var t = TerminalState.init(3, 6)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.putChar('E')
    t.putChar('F')
    t.resize(3, 3)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'B')
    @assertEq(t.grid.getCell(0, 2).codepoint, 'C')
    @assertEq(t.grid.getCell(1, 0).codepoint, 'D')
    @assertEq(t.grid.getCell(1, 1).codepoint, 'E')
    @assertEq(t.grid.getCell(1, 2).codepoint, 'F')
    @assertEq(t.grid.getRowWrap(0), 1)
    @assertEq(t.grid.getRowWrap(1), 0)
}

test "reflow grow unwraps soft-wrapped line" {
    // Write 8 chars on a 4-col terminal (soft-wraps to 2 rows), widen to 8 cols
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.putChar('E')
    t.putChar('F')
    t.putChar('G')
    t.putChar('H')
    // Row 0: "ABCD" (wrap), Row 1: "EFGH"
    @assertEq(t.grid.getRowWrap(0), 1)

    t.resize(3, 8)
    // Should unwrap into one row: "ABCDEFGH"
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'B')
    @assertEq(t.grid.getCell(0, 2).codepoint, 'C')
    @assertEq(t.grid.getCell(0, 3).codepoint, 'D')
    @assertEq(t.grid.getCell(0, 4).codepoint, 'E')
    @assertEq(t.grid.getCell(0, 5).codepoint, 'F')
    @assertEq(t.grid.getCell(0, 6).codepoint, 'G')
    @assertEq(t.grid.getCell(0, 7).codepoint, 'H')
    @assertEq(t.grid.getRowWrap(0), 0)
}

test "reflow preserves hard newlines" {
    // Row 0: "AB" + LF, Row 1: "CD" — two logical lines
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.newline()
    t.carriageReturn()
    t.putChar('C')
    t.putChar('D')
    @assertEq(t.grid.getRowWrap(0), 0)

    t.resize(3, 8)
    // Two separate logical lines, not joined
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'B')
    @assert(t.grid.getCell(0, 2).isBlank())
    @assertEq(t.grid.getCell(1, 0).codepoint, 'C')
    @assertEq(t.grid.getCell(1, 1).codepoint, 'D')
}

test "reflow cursor tracks through wrap" {
    // 6 chars on 6-col, cursor at col 5, resize to 3 cols
    var t = TerminalState.init(3, 6)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.putChar('E')
    t.putChar('F')
    // cursor at (0, 5) with pending_wrap, but cursor_col is 5
    t.setCursorPos(0, 5)
    t.resize(3, 3)
    // cursor_abs = 5, 5/3 = 1, 5%3 = 2 → row 1, col 2
    @assertEq(t.cursor_row, 1)
    @assertEq(t.cursor_col, 2)
}

test "reflow rows only preserves wrap flags" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.putChar('E')
    // Row 0 soft-wraps into row 1
    @assertEq(t.grid.getRowWrap(0), 1)
    t.resize(5, 4)
    // Same cols → resizeRowsOnly path, wrap flag preserved
    @assertEq(t.grid.getRowWrap(0), 1)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(1, 0).codepoint, 'E')
}

test "scrollUp shifts wrap flags" {
    var g = TerminalGrid.init(3, 4)
    g.getCell(0, 0).codepoint = 'A'
    g.getCell(1, 0).codepoint = 'B'
    g.getCell(2, 0).codepoint = 'C'
    g.setRowWrap(0, 1)
    g.setRowWrap(1, 0)
    g.setRowWrap(2, 1)
    var su_blank = Cell.init()
    g.scrollUp(0, 2, &su_blank)
    @assertEq(g.getRowWrap(0), 0)
    @assertEq(g.getRowWrap(1), 1)
    @assertEq(g.getRowWrap(2), 0)
}

test "scrollDown shifts wrap flags" {
    var g = TerminalGrid.init(3, 4)
    g.getCell(0, 0).codepoint = 'A'
    g.getCell(1, 0).codepoint = 'B'
    g.getCell(2, 0).codepoint = 'C'
    g.setRowWrap(0, 1)
    g.setRowWrap(1, 0)
    g.setRowWrap(2, 1)
    var sd_blank = Cell.init()
    g.scrollDown(0, 2, &sd_blank)
    @assertEq(g.getRowWrap(0), 0)
    @assertEq(g.getRowWrap(1), 1)
    @assertEq(g.getRowWrap(2), 0)
}

// ============================================================================
// Tests — Selection
// ============================================================================

test "selection marks and clears flags" {
    var t = TerminalState.init(3, 4)
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.newline()
    t.carriageReturn()
    t.putChar('E')
    t.putChar('F')

    // Select from (0,1) to (0,3)
    t.selectionStart(0, 1)
    t.selectionUpdate(0, 3)
    @assertEq((t.grid.getCell(0, 0).flags & CELL_SELECTED), 0)
    @assertEq((t.grid.getCell(0, 1).flags & CELL_SELECTED), CELL_SELECTED)
    @assertEq((t.grid.getCell(0, 2).flags & CELL_SELECTED), CELL_SELECTED)
    @assertEq((t.grid.getCell(0, 3).flags & CELL_SELECTED), CELL_SELECTED)
    @assertEq((t.grid.getCell(1, 0).flags & CELL_SELECTED), 0)

    // Clear selection
    t.selectionClear()
    @assertEq((t.grid.getCell(0, 1).flags & CELL_SELECTED), 0)
    @assertEq((t.grid.getCell(0, 2).flags & CELL_SELECTED), 0)
    @assertEq(t.sel_active, false)
}

test "selection across rows and text extraction" {
    var t = TerminalState.init(3, 4)
    // Row 0: "ABCD"
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    // Row 1: "EF"
    t.newline()
    t.carriageReturn()
    t.putChar('E')
    t.putChar('F')

    // Select from (0,2) to (1,1)
    t.selectionStart(0, 2)
    t.selectionUpdate(1, 1)

    // Row 0: cols 2-3 selected, Row 1: cols 0-1 selected
    @assertEq((t.grid.getCell(0, 0).flags & CELL_SELECTED), 0)
    @assertEq((t.grid.getCell(0, 1).flags & CELL_SELECTED), 0)
    @assertEq((t.grid.getCell(0, 2).flags & CELL_SELECTED), CELL_SELECTED)
    @assertEq((t.grid.getCell(0, 3).flags & CELL_SELECTED), CELL_SELECTED)
    @assertEq((t.grid.getCell(1, 0).flags & CELL_SELECTED), CELL_SELECTED)
    @assertEq((t.grid.getCell(1, 1).flags & CELL_SELECTED), CELL_SELECTED)
    @assertEq((t.grid.getCell(1, 2).flags & CELL_SELECTED), 0)

    // Extract text: "CD\nEF"
    var buf: List(u8) = .{}
    var i: i64 = 0
    while (i < 64) {
        buf.append(0)
        i += 1
    }
    const len = t.writeSelectedText(buf.items, 64)
    @assertEq(len, 5)
    @assertEq(@intToPtr(*u8, buf.items + 0).*, 'C')
    @assertEq(@intToPtr(*u8, buf.items + 1).*, 'D')
    @assertEq(@intToPtr(*u8, buf.items + 2).*, '\n')
    @assertEq(@intToPtr(*u8, buf.items + 3).*, 'E')
    @assertEq(@intToPtr(*u8, buf.items + 4).*, 'F')
}

// ============================================================================
// Tests — Kitty Keyboard Encoding
// ============================================================================

/// Helper: capture bytes from keyToTerminalBytesKitty and return them as a string.
fn captureKittyKey(key: i64, mods: i64, flags: i64, event_type: i64) List(i64) {
    captureBegin()
    keyToTerminalBytesKitty(-1, key, mods, flags, event_type, false)
    return captureEnd()
}

/// Helper: compare captured bytes with expected string.
fn capturedEquals(bytes: List(i64), expected: string) bool {
    if (bytes.count != @lenOf(expected)) { return false }
    var i: i64 = 0
    while (i < bytes.count) {
        if (bytes.get(i) != @intToPtr(*u8, @ptrOf(expected) + i).*) { return false }
        i += 1
    }
    return true
}

test "kitty key encode basic disambiguate" {
    // With disambiguate (flag=1) but no report_all, unmodified 'a' → raw 'a'
    const bytes = captureKittyKey('a', 0, 1, 0)
    @assertEq(bytes.count, 1)
    @assertEq(bytes.get(0), 'a')
}

test "kitty key encode report all printable" {
    // With report_all_keys (flag=8+1=9), unmodified 'a' → CSI 97 u
    const bytes = captureKittyKey('a', 0, 9, 0)
    @assert(capturedEquals(bytes, "\x1b[97u"))
}

test "kitty key encode mods" {
    // Ctrl+A with disambiguate: CSI 97;5u (mods = 1 + ctrl(4) = 5)
    const bytes = captureKittyKey('a', MOD_CTRL, 1, 0)
    @assert(capturedEquals(bytes, "\x1b[97;5u"))
}

test "kitty key encode report all" {
    // Enter with report_all_keys (flag=8): CSI 13 u (no mods section needed)
    const bytes = captureKittyKey(KEY_ENTER, 0, 9, 0)
    @assert(capturedEquals(bytes, "\x1b[13u"))
}

test "kitty key encode arrow" {
    // Up arrow with disambiguate: CSI 1;1A (kitty format)
    const bytes = captureKittyKey(KEY_ARROW_UP, 0, 1, 0)
    @assert(capturedEquals(bytes, "\x1b[A"))
}

test "kitty key encode arrow with mods" {
    // Shift+Up with disambiguate: CSI 1;2A
    const bytes = captureKittyKey(KEY_ARROW_UP, MOD_SHIFT, 1, 0)
    @assert(capturedEquals(bytes, "\x1b[1;2A"))
}

test "kitty key encode release" {
    // Release 'a' with report_events (flag=3): CSI 97;1:3u
    const bytes = captureKittyKey('a', 0, 3, 2)
    @assert(capturedEquals(bytes, "\x1b[97;1:3u"))
}

test "kitty key encode no flags fallback" {
    // No kitty flags → falls through to legacy
    // Press 'a' → just the byte 'a'
    const bytes = captureKittyKey('a', 0, 0, 0)
    @assertEq(bytes.count, 1)
    @assertEq(bytes.get(0), 'a')
}

test "kitty key encode no release without flag" {
    // Release event with flags=1 (no report_events) → nothing
    const bytes = captureKittyKey('a', 0, 1, 2)
    @assertEq(bytes.count, 0)
}

test "kitty key encode unmodified enter without report all" {
    // Unmodified Enter with disambiguate only (flag=1) → \r (legacy pass-through)
    const bytes = captureKittyKey(KEY_ENTER, 0, 1, 0)
    @assertEq(bytes.count, 1)
    @assertEq(bytes.get(0), 13)
}

test "kitty key encode F5" {
    // F5 with disambiguate: CSI 15~ (legacy tilde format)
    const bytes = captureKittyKey(KEY_F5, 0, 1, 0)
    @assert(capturedEquals(bytes, "\x1b[15~"))
}

test "kitty key encode F5 with mods" {
    // Ctrl+F5 with disambiguate: CSI 15;5~
    const bytes = captureKittyKey(KEY_F5, MOD_CTRL, 1, 0)
    @assert(capturedEquals(bytes, "\x1b[15;5~"))
}
