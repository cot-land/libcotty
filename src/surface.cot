/// Surface: a single view — either a text editor or a terminal emulator.
/// Maps to Ghostty's Surface.zig.

import "std/os"
import "std/fs"
import "std/sys"
import "std/string"
import "std/thread"
import "std/list"
import "buffer"
import "cursor"
import "input"
import "terminal"
import "cell"
import "config"
import "vt_parser"
import "pty"
import "inspector"
import "selection"
import "transaction"
import "history"
import "document"
import "movement"
import "search"
import "syntax"
import "treesitter"

// ============================================================================
// Pipe fd unpacking (same bit ops as pty.cot)
// ============================================================================

fn pipeReadFd(fds: i64) i64 {
    return fds & 4294967295
}

fn pipeWriteFd(fds: i64) i64 {
    return (fds >> 32) & 4294967295
}

// ============================================================================
// IO Reader Thread
// ============================================================================

/// Top-level function for the IO reader thread.
/// Reads from PTY fd in a blocking loop, feeds bytes through VT parser
/// under mutex, then signals main thread via notification pipe.
fn ioReaderMain(arg: i64) void {
    const surface = @intToPtr(*Surface, arg)
    const fd = surface.shell.master_fd
    var buf = alloc(0, 4096)
    defer dealloc(buf)
    while (true) {
        const n = fd_read(fd, buf, 4096)
        if (n <= 0) {
            // Child process exited — set atomic flag and signal main thread
            surface.markChildExited()
            fd_write(surface.notify_pipe_write, @ptrOf("!"), 1)
            break
        }
        surface.terminal_mutex.lock()
        for i in 0..n {
            const b = @intToPtr(*u8, buf + i).*
            surface.parser.feed(surface.terminal, b)
        }
        surface.terminal_mutex.unlock()
        // Set atomic dirty flag for VSync-driven rendering
        surface.markRenderDirty()
        // Notify main thread via pipe (for title/bell/child-exit signals)
        fd_write(surface.notify_pipe_write, @ptrOf("!"), 1)
    }
}

// ============================================================================
// Surface Kind
// ============================================================================

const SurfaceKind = enum(u8) {
    Editor,
    Terminal,
}

// ============================================================================
// Bracket pair helpers
// ============================================================================

/// Return the closing bracket for an opening bracket, or 0 if not an opener.
fn closingBracketFor(ch: int) int {
    if (ch == '(') { return ')' }
    if (ch == '[') { return ']' }
    if (ch == '{') { return '}' }
    if (ch == '"') { return '"' }
    if (ch == '\'') { return '\'' }
    if (ch == '`') { return '`' }
    return 0
}

/// Return the opening bracket for a closing bracket, or 0 if not a closer.
fn openingBracketFor(ch: int) int {
    if (ch == ')') { return '(' }
    if (ch == ']') { return '[' }
    if (ch == '}') { return '{' }
    return 0
}

/// Whether a character is a closing bracket (not including quotes).
fn isClosingBracket(ch: int) bool {
    return ch == ')' or ch == ']' or ch == '}'
}

/// Whether a character is a paired quote.
fn isPairedQuote(ch: int) bool {
    return ch == '"' or ch == '\'' or ch == '`'
}

/// A single surface (tab/window).
struct Surface {
    kind: SurfaceKind,
    document: Document,
    cursor: Cursor,
    scroll_offset: int,
    scroll_accumulator: i64,
    h_scroll_offset: int,
    h_scroll_accumulator: i64,
    mode: Mode,
    viewport_rows: int,
    viewport_cols: int,
    terminal: TerminalState,
    parser: VtParser,
    shell: Pty,
    terminal_mutex: Mutex,
    io_thread: Thread,
    notify_pipe_read: i64,
    notify_pipe_write: i64,
    render_dirty: i64,
    child_exited: i64,
    inspector: Inspector,
    render_grid: TerminalGrid,
    cursor_visible: bool,
    yank_buf: List(u8),
    last_edit_kind: int,  // 0=none, 1=insert, 2=delete — for undo grouping
    scroll_anchor: int,   // byte offset of first visible line (Zed: ScrollAnchor)
    yank_is_linewise: bool,  // true if yank buffer represents full lines (Zed: clipboard_kind)
    search: *SearchState,  // Find & replace overlay (Zed: BufferSearchBar)
    wrap_counts: List(i64),    // display rows per logical line (soft wrap)
    wrap_cum_rows: List(i64),  // prefix sum: first display row of each logical line
    wrap_total_rows: i64,      // total display rows across all lines
    hl_tokens: List(i64),      // per-byte-offset token types (tree-sitter, rebuilt each frame)

    /// Create an empty, untitled editor surface (heap-allocated with ARC).
    static fn init() *Surface {
        var dummy_mutex: Mutex = undefined
        dummy_mutex.ptr = 0
        var dummy_thread: Thread = undefined
        dummy_thread.handle = 0
        var yank: List(u8) = .{}
        var wc: List(i64) = .{}
        var wcr: List(i64) = .{}
        var hlt: List(i64) = .{}

        return new Surface {
            kind: SurfaceKind.Editor,
            document: Document.init(),
            cursor: Cursor.init(),
            scroll_offset: 0,
            scroll_accumulator: 0,
            h_scroll_offset: 0,
            h_scroll_accumulator: 0,
            mode: Mode.Insert,
            viewport_rows: 0,
            viewport_cols: 0,
            terminal: TerminalState.init(0, 0),
            parser: VtParser.init(),
            shell: Pty { master_fd: -1, child_pid: -1 },
            terminal_mutex: dummy_mutex,
            io_thread: dummy_thread,
            notify_pipe_read: -1,
            notify_pipe_write: -1,
            render_dirty: 0,
            child_exited: 0,
            inspector: Inspector.init(24, 80),
            render_grid: TerminalGrid.init(0, 0),
            cursor_visible: true,
            yank_buf: yank,
            last_edit_kind: 0,
            scroll_anchor: 0,
            yank_is_linewise: false,
            search: SearchState.init(),
            wrap_counts: wc,
            wrap_cum_rows: wcr,
            wrap_total_rows: 0,
            hl_tokens: hlt,
        }
    }

    /// Create an editor surface from a file path (heap-allocated with ARC).
    static fn initFromFile(path: string) *Surface {
        var dummy_mutex: Mutex = undefined
        dummy_mutex.ptr = 0
        var dummy_thread: Thread = undefined
        dummy_thread.handle = 0
        var yank: List(u8) = .{}
        const content = readFile(path) catch {
            // File doesn't exist yet — create empty surface with path
            var yank2: List(u8) = .{}
            var wc2: List(i64) = .{}
            var wcr2: List(i64) = .{}
            var hlt2: List(i64) = .{}

            var s = new Surface {
                kind: SurfaceKind.Editor,
                document: Document.init(),
                cursor: Cursor.init(),
                scroll_offset: 0,
                scroll_accumulator: 0,
                h_scroll_offset: 0,
                h_scroll_accumulator: 0,
                mode: Mode.Insert,
                viewport_rows: 0,
                viewport_cols: 0,
                terminal: TerminalState.init(0, 0),
                parser: VtParser.init(),
                shell: Pty { master_fd: -1, child_pid: -1 },
                terminal_mutex: dummy_mutex,
                io_thread: dummy_thread,
                notify_pipe_read: -1,
                notify_pipe_write: -1,
                render_dirty: 0,
                child_exited: 0,
                inspector: Inspector.init(24, 80),
                render_grid: TerminalGrid.init(0, 0),
                cursor_visible: true,
                yank_buf: yank2,
                last_edit_kind: 0,
                scroll_anchor: 0,
                yank_is_linewise: false,
                search: SearchState.init(),
                wrap_counts: wc2,
                wrap_cum_rows: wcr2,
                wrap_total_rows: 0,
                hl_tokens: hlt2,
            }
            s.document.filepath = path

            return s
        }

        var wc3: List(i64) = .{}
        var wcr3: List(i64) = .{}
        var hlt3: List(i64) = .{}

        var s = new Surface {
            kind: SurfaceKind.Editor,
            document: Document.initWithContent(content),
            cursor: Cursor.init(),
            scroll_offset: 0,
            scroll_accumulator: 0,
            h_scroll_offset: 0,
            h_scroll_accumulator: 0,
            mode: Mode.Insert,
            viewport_rows: 0,
            viewport_cols: 0,
            terminal: TerminalState.init(0, 0),
            parser: VtParser.init(),
            shell: Pty { master_fd: -1, child_pid: -1 },
            terminal_mutex: dummy_mutex,
            io_thread: dummy_thread,
            notify_pipe_read: -1,
            notify_pipe_write: -1,
            render_dirty: 0,
            child_exited: 0,
            inspector: Inspector.init(24, 80),
            render_grid: TerminalGrid.init(0, 0),
            cursor_visible: true,
            yank_buf: yank,
            last_edit_kind: 0,
            scroll_anchor: 0,
            yank_is_linewise: false,
            search: SearchState.init(),
            wrap_counts: wc3,
            wrap_cum_rows: wcr3,
            wrap_total_rows: 0,
            hl_tokens: hlt3,
        }
        s.document.filepath = path
        return s
    }

    /// Create a terminal surface with a shell spawned via Cot's PTY.
    /// Sets up IO reader thread: mutex, notification pipe, and spawns thread.
    /// Heap-allocated with ARC for pointer stability (IO thread holds raw pointer).
    static fn initTerminal(rows: i64, cols: i64) *Surface {
        const pty = Pty.spawn(rows, cols)
        var term = TerminalState.init(rows, cols)
        term.pty_fd = pty.master_fd

        // Create mutex to protect terminal state + parser
        var mtx = Mutex.init()

        // Create notification pipe for IO thread → main thread signaling
        const pipe_fds = pipe()
        const pipe_r = pipeReadFd(pipe_fds)
        const pipe_w = pipeWriteFd(pipe_fds)

        var dummy_thread: Thread = undefined
        dummy_thread.handle = 0
        var yank: List(u8) = .{}
        var wc4: List(i64) = .{}
        var wcr4: List(i64) = .{}
        var hlt4: List(i64) = .{}

        return new Surface {
            kind: SurfaceKind.Terminal,
            document: Document.init(),
            cursor: Cursor.init(),
            scroll_offset: 0,
            scroll_accumulator: 0,
            h_scroll_offset: 0,
            h_scroll_accumulator: 0,
            mode: Mode.Insert,
            viewport_rows: 0,
            viewport_cols: 0,
            terminal: term,
            parser: VtParser.init(),
            shell: pty,
            terminal_mutex: mtx,
            io_thread: dummy_thread,
            notify_pipe_read: pipe_r,
            notify_pipe_write: pipe_w,
            render_dirty: 0,
            child_exited: 0,
            inspector: Inspector.init(rows, cols),
            render_grid: TerminalGrid.init(0, 0),
            cursor_visible: true,
            yank_buf: yank,
            last_edit_kind: 0,
            scroll_anchor: 0,
            yank_is_linewise: false,
            search: SearchState.init(),
            wrap_counts: wc4,
            wrap_cum_rows: wcr4,
            wrap_total_rows: 0,
            hl_tokens: hlt4,
        }
    }

    /// Spawn the IO reader thread. Must be called after surface is at its
    /// final memory location (i.e., after being added to the surface list).
    fn startIoThread() void {
        self.io_thread = Thread.spawn(@ptrToInt(ioReaderMain), @ptrToInt(self))
    }

    /// Initialize tree-sitter context based on file extension.
    /// Check if this surface should have syntax highlighting.
    fn hasTreeSitter() bool {
        if (self.document.filepath) |path| {
            return endsWith(path, ".md") and tsHasMarkdown()
        }
        return false
    }

    /// Handle an input action, dispatching by current mode.
    /// Handle input — standard editor (non-modal).
    /// All keys type characters, Shift+movement extends selection.
    fn handleInput(action: InputAction, key: int) void {
        switch (action) {
            InputAction.insert_char => {
                self.cursor.clearGoal()
                // Validate buffer before building changeset
                if (g_buffer_debug) {
                    if (!self.document.buffer.validate()) {
                        self.document.buffer.dumpState("CORRUPT before insert_char")
                        @trap()
                    }
                }
                // Break undo group if switching from delete to insert
                if (self.last_edit_kind != 1) { self.document.history.breakGroup() }
                self.last_edit_kind = 1
                // Multi-cursor: simple insert at all positions (no bracket features)
                if (self.hasMultipleCursors()) {
                    // Delete any non-empty selections first
                    self.deleteSelection()
                    self.insertAtAllCursors(key)
                    return
                }
                // Single cursor: full feature set
                const primary = self.document.selection.primary()
                if (!primary.isEmpty()) {
                    const surround_close = closingBracketFor(key)
                    if (surround_close > 0) {
                        self.document.history.breakGroup()
                        self.surroundSelection(key, surround_close)
                        return
                    }
                    self.document.history.breakGroup()
                    self.deleteSelection()
                    self.document.selection = Selection.point(self.cursor.offset)
                }
                const cursor_before = self.cursor.offset
                if (key == '\n') {
                    self.insertNewlineWithIndent()
                } else {
                    const closing = closingBracketFor(key)
                    if (closing == 0 and isClosingBracket(key)) {
                        if (cursor_before < self.document.buffer.len()) {
                            if (self.document.buffer.charAt(cursor_before) == key) {
                                self.cursor.offset = cursor_before + 1
                                self.cursor.col += 1
                                self.document.selection = Selection.point(self.cursor.offset)
                                return
                            }
                        }
                    }
                    if (closing > 0) {
                        var cs = ChangeSet.init()
                        if (cursor_before > 0) { cs.retain(cursor_before) }
                        cs.insertCodepoint(key)
                        cs.insertByte(closing)
                        const rest = self.document.buffer.len() - cursor_before
                        if (rest > 0) { cs.retain(rest) }
                        var txn = Transaction { changes: cs }
                        const key_bytes = utf8CodepointLen(key)
                        const cursor_after = cursor_before + key_bytes
                        self.applyEdit(txn, cursor_before, cursor_after)
                        self.cursor.offset = cursor_after
                        self.cursor.col += key_bytes
                    } else {
                        var cs = ChangeSet.init()
                        if (cursor_before > 0) { cs.retain(cursor_before) }
                        cs.insertCodepoint(key)
                        const rest = self.document.buffer.len() - cursor_before
                        if (rest > 0) { cs.retain(rest) }
                        var txn = Transaction { changes: cs }
                        const key_bytes = utf8CodepointLen(key)
                        const cursor_after = cursor_before + key_bytes
                        self.applyEdit(txn, cursor_before, cursor_after)
                        self.cursor.offset = cursor_after
                        self.cursor.col += key_bytes
                    }
                }
            },
            InputAction.delete_back => {
                self.cursor.clearGoal()
                if (self.last_edit_kind != 2) { self.document.history.breakGroup() }
                self.last_edit_kind = 2
                // Multi-cursor: simple delete at all positions
                if (self.hasMultipleCursors()) {
                    self.deleteSelection()
                    self.deleteBackAtAllCursors()
                    return
                }
                // Single cursor: full feature set (bracket pair delete)
                const primary_del = self.document.selection.primary()
                if (!primary_del.isEmpty()) {
                    self.deleteSelection()
                    self.document.selection = Selection.point(self.cursor.offset)
                    return
                }
                if (self.cursor.offset > 0) {
                    const cursor_before = self.cursor.offset
                    // Find start of the codepoint to delete
                    const cp_start = prevCodepointStart(&self.document.buffer, cursor_before)
                    const cp_len = cursor_before - cp_start
                    const deleted_cp = utf8DecodeAt(&self.document.buffer, cp_start)
                    const expected_close = closingBracketFor(deleted_cp)
                    var delete_pair = false
                    if (expected_close > 0 and cursor_before < self.document.buffer.len()) {
                        if (self.document.buffer.charAt(cursor_before) == expected_close) {
                            delete_pair = true
                        }
                    }
                    var cs = ChangeSet.init()
                    if (cp_start > 0) { cs.retain(cp_start) }
                    if (delete_pair) {
                        cs.delete(cp_len + 1)
                        const rest = self.document.buffer.len() - cursor_before - 1
                        if (rest > 0) { cs.retain(rest) }
                    } else {
                        cs.delete(cp_len)
                        const rest = self.document.buffer.len() - cursor_before
                        if (rest > 0) { cs.retain(rest) }
                    }
                    var txn = Transaction { changes: cs }
                    const cursor_after = cp_start
                    self.applyEdit(txn, cursor_before, cursor_after)
                    self.cursor.offset = cursor_after
                    if (deleted_cp == '\n') {
                        self.recomputeLineCol()
                    } else {
                        self.cursor.col -= cp_len
                    }
                }
            },
            InputAction.move_left => { self.moveAllCursors(InputAction.move_left) },
            InputAction.move_right => { self.moveAllCursors(InputAction.move_right) },
            InputAction.move_up => { self.moveAllCursors(InputAction.move_up) },
            InputAction.move_down => { self.moveAllCursors(InputAction.move_down) },
            InputAction.move_line_start => { self.moveAllCursors(InputAction.move_line_start) },
            InputAction.move_line_end => { self.moveAllCursors(InputAction.move_line_end) },
            InputAction.delete_forward => {
                self.cursor.clearGoal()
                if (self.last_edit_kind != 2) { self.document.history.breakGroup() }
                self.last_edit_kind = 2
                if (self.hasMultipleCursors()) {
                    self.deleteSelection()
                    self.deleteForwardAtAllCursors()
                    return
                }
                const primary_df = self.document.selection.primary()
                if (!primary_df.isEmpty()) {
                    self.deleteSelection()
                    self.document.selection = Selection.point(self.cursor.offset)
                    return
                }
                if (self.cursor.offset < self.document.buffer.len()) {
                    const cursor_before = self.cursor.offset
                    const cp_len = utf8ByteLen(self.document.buffer.charAt(cursor_before))
                    var cs = ChangeSet.init()
                    if (cursor_before > 0) { cs.retain(cursor_before) }
                    cs.delete(cp_len)
                    const rest = self.document.buffer.len() - cursor_before - cp_len
                    if (rest > 0) { cs.retain(rest) }
                    var txn = Transaction { changes: cs }
                    self.applyEdit(txn, cursor_before, cursor_before)
                }
            },
            InputAction.delete_selection => {
                self.deleteSelection()
                self.document.selection = Selection.point(self.cursor.offset)
            },
            InputAction.yank => {
                self.yankSelection()
            },
            InputAction.change_selection => {
                self.deleteSelection()
                self.document.selection = Selection.point(self.cursor.offset)
            },
            InputAction.undo => {
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.performUndo()
                self.document.selection = Selection.point(self.cursor.offset)
            },
            InputAction.redo => {
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.performRedo()
                self.document.selection = Selection.point(self.cursor.offset)
            },
            // Select actions — extend selection from anchor (multi-cursor aware)
            InputAction.select_left => { self.extendAllSelections(InputAction.move_left) },
            InputAction.select_right => { self.extendAllSelections(InputAction.move_right) },
            InputAction.select_up => { self.extendAllSelections(InputAction.move_up) },
            InputAction.select_down => { self.extendAllSelections(InputAction.move_down) },
            InputAction.select_line_start => { self.extendAllSelections(InputAction.move_line_start) },
            InputAction.select_line_end => { self.extendAllSelections(InputAction.move_line_end) },
            InputAction.select_word_forward => { self.extendAllSelections(InputAction.move_word_forward) },
            InputAction.select_word_backward => { self.extendAllSelections(InputAction.move_word_backward) },
            InputAction.select_all => {
                const buf_len = self.document.buffer.len()
                self.document.selection = Selection.init(0, buf_len)
                self.cursor.offset = buf_len
                self.recomputeLineCol()
            },
            InputAction.move_word_forward => { self.moveAllCursors(InputAction.move_word_forward) },
            InputAction.move_word_backward => { self.moveAllCursors(InputAction.move_word_backward) },
            InputAction.move_word_end => { self.moveAllCursors(InputAction.move_word_forward) },
            InputAction.move_doc_start => { self.moveAllCursors(InputAction.move_doc_start) },
            InputAction.move_doc_end => { self.moveAllCursors(InputAction.move_doc_end) },
            InputAction.select_doc_start => { self.extendAllSelections(InputAction.move_doc_start) },
            InputAction.select_doc_end => { self.extendAllSelections(InputAction.move_doc_end) },
            InputAction.select_to_line_start => { self.extendAllSelections(InputAction.move_line_start) },
            InputAction.select_to_line_end => { self.extendAllSelections(InputAction.move_line_end) },
            InputAction.delete_to_line_start => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 2
                // Delete from cursor to start of line
                const line_start = self.moveOffsetLineStart(self.cursor.offset)
                if (line_start < self.cursor.offset) {
                    var cs = ChangeSet.init()
                    if (line_start > 0) { cs.retain(line_start) }
                    cs.delete(self.cursor.offset - line_start)
                    const rest = self.document.buffer.len() - self.cursor.offset
                    if (rest > 0) { cs.retain(rest) }
                    var txn = Transaction { changes: cs }
                    self.applyEdit(txn, self.cursor.offset, line_start)
                    self.cursor.offset = line_start
                    self.recomputeLineCol()
                    self.document.selection = Selection.point(self.cursor.offset)
                }
            },
            InputAction.add_next_occurrence => {
                self.addNextOccurrence()
            },
            InputAction.collapse_cursors => {
                // Escape: collapse to single primary cursor, collapse selection
                if (self.hasMultipleCursors()) {
                    self.collapseToPrimaryCursor()
                } else {
                    // Single cursor: just collapse selection
                    self.document.selection = Selection.point(self.cursor.offset)
                }
            },
            InputAction.delete_word_backward => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 2
                // Delete any selection first
                const primary_dwb = self.document.selection.primary()
                if (!primary_dwb.isEmpty()) {
                    self.deleteSelection()
                    self.document.selection = Selection.point(self.cursor.offset)
                    return
                }
                self.deleteWordBackward()
            },
            InputAction.delete_word_forward => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 2
                const primary_dwf = self.document.selection.primary()
                if (!primary_dwf.isEmpty()) {
                    self.deleteSelection()
                    self.document.selection = Selection.point(self.cursor.offset)
                    return
                }
                self.deleteWordForward()
            },
            InputAction.delete_line => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 2
                self.deleteLine()
            },
            InputAction.move_line_up => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.moveLineUp()
            },
            InputAction.move_line_down => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.moveLineDown()
            },
            InputAction.duplicate_line => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.duplicateLine()
            },
            InputAction.join_lines => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.joinLines()
            },
            InputAction.indent_selection => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.indentSelection()
            },
            InputAction.outdent_selection => {
                self.cursor.clearGoal()
                self.document.history.breakGroup()
                self.last_edit_kind = 0
                self.outdentSelection()
            },
            InputAction.select_line => {
                self.selectLine()
            },
            else => {},
        }
    }

    // =====================================================================
    // Multi-cursor support
    // =====================================================================

    /// Sync self.cursor (line/col/offset) from the primary selection range.
    fn syncCursorFromPrimary() void {
        const primary = self.document.selection.primary()
        self.cursor.offset = primary.head
        self.recomputeLineCol()
    }

    /// Move a byte offset left by one position.
    /// Delegates to movePosLeft() in movement.cot.
    fn moveOffsetLeft(offset: int) int {
        return movePosLeft(&self.document.buffer, offset)
    }

    /// Move a byte offset right by one position.
    /// Delegates to movePosRight() in movement.cot.
    fn moveOffsetRight(offset: int) int {
        return movePosRight(&self.document.buffer, offset)
    }

    /// Move a byte offset up one line, targeting the same column.
    /// Delegates to moveUp() in movement.cot.
    fn moveOffsetUp(offset: int) int {
        const line = self.offsetToLine(offset)
        const col = offset - self.document.buffer.lineStartOffset(line)
        const result = moveUp(&self.document.buffer, line, col, col)
        return result.offset
    }

    /// Move a byte offset down one line, targeting the same column.
    /// Delegates to moveDown() in movement.cot.
    fn moveOffsetDown(offset: int) int {
        const line = self.offsetToLine(offset)
        const col = offset - self.document.buffer.lineStartOffset(line)
        const total = self.document.buffer.lineCount()
        const result = moveDown(&self.document.buffer, line, col, col, total)
        return result.offset
    }

    /// Move a byte offset to the start of its line.
    /// Delegates to moveLineStart() in movement.cot.
    fn moveOffsetLineStart(offset: int) int {
        const line = self.offsetToLine(offset)
        return moveLineStart(&self.document.buffer, line)
    }

    /// Move a byte offset to the end of its line.
    /// Delegates to moveLineEnd() in movement.cot.
    fn moveOffsetLineEnd(offset: int) int {
        const line = self.offsetToLine(offset)
        return moveLineEnd(&self.document.buffer, line)
    }

    /// Move to start of document.
    /// Delegates to moveToBufferStart() in movement.cot.
    fn moveOffsetDocStart(offset: int) int {
        return moveToBufferStart()
    }

    /// Move to end of document.
    /// Delegates to moveToBufferEnd() in movement.cot.
    fn moveOffsetDocEnd(offset: int) int {
        return moveToBufferEnd(&self.document.buffer)
    }

    /// Move a byte offset forward by one word.
    /// Delegates to moveWordForward() in movement.cot.
    fn moveOffsetWordForward(offset: int) int {
        return moveWordForward(&self.document.buffer, offset)
    }

    /// Move a byte offset backward by one word.
    /// Delegates to moveWordBackward() in movement.cot.
    fn moveOffsetWordBackward(offset: int) int {
        return moveWordBackward(&self.document.buffer, offset)
    }

    /// Move a byte offset up one line using a specific goal column.
    /// Delegates to moveUp() in movement.cot.
    fn moveOffsetUpWithGoal(offset: int, goal_col: int) int {
        const line = self.offsetToLine(offset)
        const col = offset - self.document.buffer.lineStartOffset(line)
        const result = moveUp(&self.document.buffer, line, col, goal_col)
        return result.offset
    }

    /// Move a byte offset down one line using a specific goal column.
    /// Delegates to moveDown() in movement.cot.
    fn moveOffsetDownWithGoal(offset: int, goal_col: int) int {
        const line = self.offsetToLine(offset)
        const col = offset - self.document.buffer.lineStartOffset(line)
        const total = self.document.buffer.lineCount()
        const result = moveDown(&self.document.buffer, line, col, goal_col, total)
        return result.offset
    }

    /// Apply a movement action to ALL selection ranges (multi-cursor aware).
    /// Each range head is moved independently, ranges collapse to points.
    /// Selection is normalized after (overlapping cursors merge).
    /// Primary cursor uses goal_col for vertical movement.
    fn moveAllCursors(action: InputAction) void {
        self.document.history.breakGroup()
        self.last_edit_kind = 0
        // For vertical movement, use goal_col on primary cursor
        const is_vertical = (action == InputAction.move_up or action == InputAction.move_down)
        if (is_vertical) {
            self.cursor.ensureGoal()
        } else {
            self.cursor.clearGoal()
        }
        const primary_idx = self.document.selection.primary_index
        const goal = self.cursor.effectiveGoal()
        var i: i64 = 0
        while (i < self.document.selection.ranges.count) {
            const r = self.document.selection.ranges.get(i)
            const head = r.head
            var new_head = head
            switch (action) {
                InputAction.move_left => { new_head = self.moveOffsetLeft(head) },
                InputAction.move_right => { new_head = self.moveOffsetRight(head) },
                InputAction.move_up => {
                    if (i == primary_idx) {
                        new_head = self.moveOffsetUpWithGoal(head, goal)
                    } else {
                        new_head = self.moveOffsetUp(head)
                    }
                },
                InputAction.move_down => {
                    if (i == primary_idx) {
                        new_head = self.moveOffsetDownWithGoal(head, goal)
                    } else {
                        new_head = self.moveOffsetDown(head)
                    }
                },
                InputAction.move_line_start => { new_head = self.moveOffsetLineStart(head) },
                InputAction.move_line_end => { new_head = self.moveOffsetLineEnd(head) },
                InputAction.move_word_forward => { new_head = self.moveOffsetWordForward(head) },
                InputAction.move_word_backward => { new_head = self.moveOffsetWordBackward(head) },
                InputAction.move_doc_start => { new_head = self.moveOffsetDocStart(head) },
                InputAction.move_doc_end => { new_head = self.moveOffsetDocEnd(head) },
                else => {},
            }
            self.document.selection.replace(i, Range { anchor: new_head, head: new_head })
            i += 1
        }
        self.document.selection.normalize()
        self.syncCursorFromPrimary()
        // Preserve goal_col state through vertical movement
        if (!is_vertical) { self.cursor.clearGoal() }
    }

    /// Extend selection at ALL ranges by a movement action (multi-cursor aware).
    /// Each range head moves, anchor stays. Normalized after.
    fn extendAllSelections(action: InputAction) void {
        self.document.history.breakGroup()
        self.last_edit_kind = 0
        var i: i64 = 0
        while (i < self.document.selection.ranges.count) {
            const r = self.document.selection.ranges.get(i)
            var anchor = r.anchor
            if (r.isEmpty()) {
                anchor = r.head
            }
            const head = r.head
            var new_head = head
            switch (action) {
                InputAction.move_left => { new_head = self.moveOffsetLeft(head) },
                InputAction.move_right => { new_head = self.moveOffsetRight(head) },
                InputAction.move_up => { new_head = self.moveOffsetUp(head) },
                InputAction.move_down => { new_head = self.moveOffsetDown(head) },
                InputAction.move_line_start => { new_head = self.moveOffsetLineStart(head) },
                InputAction.move_line_end => { new_head = self.moveOffsetLineEnd(head) },
                InputAction.move_word_forward => { new_head = self.moveOffsetWordForward(head) },
                InputAction.move_word_backward => { new_head = self.moveOffsetWordBackward(head) },
                InputAction.move_doc_start => { new_head = self.moveOffsetDocStart(head) },
                InputAction.move_doc_end => { new_head = self.moveOffsetDocEnd(head) },
                else => {},
            }
            self.document.selection.replace(i, Range { anchor: anchor, head: new_head })
            i += 1
        }
        self.document.selection.normalize()
        self.syncCursorFromPrimary()
    }

    /// Insert a character at ALL cursor positions (multi-cursor aware).
    /// Builds a single transaction with inserts at all cursor offsets (sorted ascending).
    fn insertAtAllCursors(key: int) void {
        const range_count = self.document.selection.ranges.count
        if (range_count == 0) { return }
        var cs = ChangeSet.init()
        var prev_offset: i64 = 0
        var i: i64 = 0
        while (i < range_count) {
            const r = self.document.selection.ranges.get(i)
            const pos = r.head
            const gap = pos - prev_offset
            if (gap > 0) { cs.retain(gap) }
            cs.insertCodepoint(key)
            prev_offset = pos
            i += 1
        }
        const rest = self.document.buffer.len() - prev_offset
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        const cursor_before = self.cursor.offset
        const key_bytes = utf8CodepointLen(key)
        self.applyEdit(txn, cursor_before, cursor_before + key_bytes)
        self.syncCursorFromPrimary()
    }

    /// Delete one codepoint backward at ALL cursor positions (multi-cursor aware).
    /// Builds a single transaction with deletes at all cursor offsets.
    fn deleteBackAtAllCursors() void {
        const range_count = self.document.selection.ranges.count
        if (range_count == 0) { return }
        var cs = ChangeSet.init()
        var prev_offset: i64 = 0
        var any_deleted = false
        var i: i64 = 0
        while (i < range_count) {
            const r = self.document.selection.ranges.get(i)
            const pos = r.head
            if (pos > 0) {
                const cp_start = prevCodepointStart(&self.document.buffer, pos)
                const cp_len = pos - cp_start
                const gap = cp_start - prev_offset
                if (gap > 0) { cs.retain(gap) }
                cs.delete(cp_len)
                prev_offset = pos
                any_deleted = true
            }
            i += 1
        }
        if (!any_deleted) { return }
        const rest = self.document.buffer.len() - prev_offset
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        const cursor_before = self.cursor.offset
        var cursor_after = prevCodepointStart(&self.document.buffer, cursor_before)
        self.applyEdit(txn, cursor_before, cursor_after)
        self.syncCursorFromPrimary()
    }

    /// Delete one codepoint forward at ALL cursor positions (multi-cursor aware).
    fn deleteForwardAtAllCursors() void {
        const range_count = self.document.selection.ranges.count
        if (range_count == 0) { return }
        var cs = ChangeSet.init()
        var prev_offset: i64 = 0
        var any_deleted = false
        const buf_len = self.document.buffer.len()
        var i: i64 = 0
        while (i < range_count) {
            const r = self.document.selection.ranges.get(i)
            const pos = r.head
            if (pos < buf_len) {
                const cp_len = utf8ByteLen(self.document.buffer.charAt(pos))
                const gap = pos - prev_offset
                if (gap > 0) { cs.retain(gap) }
                cs.delete(cp_len)
                prev_offset = pos + cp_len
                any_deleted = true
            }
            i += 1
        }
        if (!any_deleted) { return }
        const rest = buf_len - prev_offset
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        const cursor_before = self.cursor.offset
        self.applyEdit(txn, cursor_before, cursor_before)
        self.syncCursorFromPrimary()
    }

    // =====================================================================
    // Phase 1 Editor Operations
    // =====================================================================

    /// Delete the word before the cursor (Alt+Backspace).
    fn deleteWordBackward() void {
        if (self.cursor.offset == 0) { return }
        const cursor_before = self.cursor.offset
        const target = moveWordBackward(&self.document.buffer, cursor_before)
        const del_len = cursor_before - target
        if (del_len == 0) { return }
        var cs = ChangeSet.init()
        if (target > 0) { cs.retain(target) }
        cs.delete(del_len)
        const rest = self.document.buffer.len() - cursor_before
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        self.applyEdit(txn, cursor_before, target)
        self.cursor.offset = target
        self.recomputeLineCol()
        self.document.selection = Selection.point(self.cursor.offset)
    }

    /// Delete the word after the cursor (Alt+Delete).
    fn deleteWordForward() void {
        const buf_len = self.document.buffer.len()
        if (self.cursor.offset >= buf_len) { return }
        const cursor_before = self.cursor.offset
        const target = moveWordForward(&self.document.buffer, cursor_before)
        const del_len = target - cursor_before
        if (del_len == 0) { return }
        var cs = ChangeSet.init()
        if (cursor_before > 0) { cs.retain(cursor_before) }
        cs.delete(del_len)
        const rest = buf_len - target
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        self.applyEdit(txn, cursor_before, cursor_before)
        self.document.selection = Selection.point(self.cursor.offset)
    }

    /// Delete the current line (Cmd+Shift+K).
    fn deleteLine() void {
        const buf_len = self.document.buffer.len()
        if (buf_len == 0) { return }
        const line = self.cursor.line
        const line_start = self.document.buffer.lineStartOffset(line)
        const line_len = self.document.buffer.lineLength(line)
        const total_lines = self.document.buffer.lineCount()
        // Calculate range to delete: line content + newline (or preceding newline if last line)
        var del_start = line_start
        var del_end = line_start + line_len
        if (del_end < buf_len and self.document.buffer.charAt(del_end) == '\n') {
            // Not the last line — include trailing newline
            del_end += 1
        } else if (del_start > 0) {
            // Last line — include preceding newline
            del_start -= 1
        }
        const del_len = del_end - del_start
        if (del_len == 0) { return }
        var cs = ChangeSet.init()
        if (del_start > 0) { cs.retain(del_start) }
        cs.delete(del_len)
        const rest = buf_len - del_end
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        // Place cursor at same column on next line (or line above if last)
        const goal_col = self.cursor.col
        self.applyEdit(txn, self.cursor.offset, del_start)
        self.cursor.offset = del_start
        self.recomputeLineCol()
        // Clamp to new line length
        const new_line_len = self.document.buffer.lineLength(self.cursor.line)
        if (self.cursor.col > new_line_len) {
            self.cursor.col = new_line_len
        } else if (goal_col <= new_line_len) {
            self.cursor.col = goal_col
        }
        self.cursor.offset = self.document.buffer.lineStartOffset(self.cursor.line) + self.cursor.col
        self.document.selection = Selection.point(self.cursor.offset)
    }

    /// Move the current line up (Alt+Up).
    fn moveLineUp() void {
        const line = self.cursor.line
        if (line == 0) { return }
        const buf_len = self.document.buffer.len()
        // Current line range
        const cur_start = self.document.buffer.lineStartOffset(line)
        const cur_len = self.document.buffer.lineLength(line)
        // Previous line range
        const prev_start = self.document.buffer.lineStartOffset(line - 1)
        const prev_len = self.document.buffer.lineLength(line - 1)
        // Extract current line text
        var cur_text: List(u8) = .{}
        var ci: i64 = 0
        while (ci < cur_len) {
            cur_text.append(@intCast(u8, self.document.buffer.charAt(cur_start + ci)))
            ci += 1
        }
        // Extract previous line text
        var prev_text: List(u8) = .{}
        var pi: i64 = 0
        while (pi < prev_len) {
            prev_text.append(@intCast(u8, self.document.buffer.charAt(prev_start + pi)))
            pi += 1
        }
        // Build changeset: replace [prev_line\ncur_line] with [cur_line\nprev_line]
        var cs = ChangeSet.init()
        if (prev_start > 0) { cs.retain(prev_start) }
        // Delete both lines + the newline between them
        const total_del = prev_len + 1 + cur_len
        cs.delete(total_del)
        // Insert current line, newline, previous line
        cs.insert(@string(cur_text.items, cur_text.count))
        cs.insertByte('\n')
        cs.insert(@string(prev_text.items, prev_text.count))
        // Handle trailing newline or rest of buffer
        const after_cur = cur_start + cur_len
        if (after_cur < buf_len and self.document.buffer.charAt(after_cur) == '\n') {
            // Cur line had a trailing newline — it's already accounted for by the structure
            const rest = buf_len - after_cur
            if (rest > 0) { cs.retain(rest) }
        } else {
            // Last line, no trailing newline
            const rest = buf_len - (prev_start + total_del)
            if (rest > 0) { cs.retain(rest) }
        }
        var txn = Transaction { changes: cs }
        const goal_col = self.cursor.col
        self.applyEdit(txn, self.cursor.offset, prev_start + goal_col)
        self.cursor.offset = prev_start + goal_col
        self.recomputeLineCol()
        // Clamp column
        const new_line_len = self.document.buffer.lineLength(self.cursor.line)
        if (self.cursor.col > new_line_len) {
            self.cursor.col = new_line_len
            self.cursor.offset = self.document.buffer.lineStartOffset(self.cursor.line) + self.cursor.col
        }
        self.document.selection = Selection.point(self.cursor.offset)
    }

    /// Move the current line down (Alt+Down).
    fn moveLineDown() void {
        const line = self.cursor.line
        const total_lines = self.document.buffer.lineCount()
        if (line >= total_lines - 1) { return }
        const buf_len = self.document.buffer.len()
        // Current line range
        const cur_start = self.document.buffer.lineStartOffset(line)
        const cur_len = self.document.buffer.lineLength(line)
        // Next line range
        const next_start = self.document.buffer.lineStartOffset(line + 1)
        const next_len = self.document.buffer.lineLength(line + 1)
        // Extract current line text
        var cur_text: List(u8) = .{}
        var ci: i64 = 0
        while (ci < cur_len) {
            cur_text.append(@intCast(u8, self.document.buffer.charAt(cur_start + ci)))
            ci += 1
        }
        // Extract next line text
        var next_text: List(u8) = .{}
        var ni: i64 = 0
        while (ni < next_len) {
            next_text.append(@intCast(u8, self.document.buffer.charAt(next_start + ni)))
            ni += 1
        }
        // Build changeset: replace [cur_line\nnext_line] with [next_line\ncur_line]
        var cs = ChangeSet.init()
        if (cur_start > 0) { cs.retain(cur_start) }
        // Delete both lines + newline between them
        const total_del = cur_len + 1 + next_len
        cs.delete(total_del)
        // Insert next line, newline, current line
        cs.insert(@string(next_text.items, next_text.count))
        cs.insertByte('\n')
        cs.insert(@string(cur_text.items, cur_text.count))
        // Rest of buffer after next line
        const after_next = next_start + next_len
        const rest = buf_len - after_next
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        const goal_col = self.cursor.col
        const new_offset = cur_start + next_len + 1 + goal_col
        self.applyEdit(txn, self.cursor.offset, new_offset)
        self.cursor.offset = new_offset
        self.recomputeLineCol()
        // Clamp column
        const new_line_len = self.document.buffer.lineLength(self.cursor.line)
        if (self.cursor.col > new_line_len) {
            self.cursor.col = new_line_len
            self.cursor.offset = self.document.buffer.lineStartOffset(self.cursor.line) + self.cursor.col
        }
        self.document.selection = Selection.point(self.cursor.offset)
    }

    /// Duplicate the current line (Cmd+Shift+D).
    fn duplicateLine() void {
        const line = self.cursor.line
        const line_start = self.document.buffer.lineStartOffset(line)
        const line_len = self.document.buffer.lineLength(line)
        const line_end = line_start + line_len
        const buf_len = self.document.buffer.len()
        // Extract line text
        var line_text: List(u8) = .{}
        var i: i64 = 0
        while (i < line_len) {
            line_text.append(@intCast(u8, self.document.buffer.charAt(line_start + i)))
            i += 1
        }
        // Insert \n + line text after current line end
        var cs = ChangeSet.init()
        if (line_end > 0) { cs.retain(line_end) }
        cs.insertByte('\n')
        cs.insert(@string(line_text.items, line_text.count))
        const rest = buf_len - line_end
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        // Move cursor to same column on the new (duplicated) line
        const new_offset = line_end + 1 + self.cursor.col
        self.applyEdit(txn, self.cursor.offset, new_offset)
        self.cursor.offset = new_offset
        self.recomputeLineCol()
        self.document.selection = Selection.point(self.cursor.offset)
    }

    /// Join current line with the next line (Ctrl+J).
    fn joinLines() void {
        const line = self.cursor.line
        const total_lines = self.document.buffer.lineCount()
        if (line >= total_lines - 1) { return }
        const buf_len = self.document.buffer.len()
        const line_start = self.document.buffer.lineStartOffset(line)
        const line_len = self.document.buffer.lineLength(line)
        const newline_pos = line_start + line_len
        if (newline_pos >= buf_len) { return }
        // Find leading whitespace on next line
        var ws_len: i64 = 0
        var scan = newline_pos + 1
        while (scan < buf_len) {
            const ch = self.document.buffer.charAt(scan)
            if (ch != ' ' and ch != '\t') { break }
            ws_len += 1
            scan += 1
        }
        // Delete newline + leading whitespace, insert single space
        const del_len = 1 + ws_len
        var cs = ChangeSet.init()
        if (newline_pos > 0) { cs.retain(newline_pos) }
        cs.delete(del_len)
        cs.insertByte(' ')
        const rest = buf_len - newline_pos - del_len
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        // Cursor goes to the join point (where the space is)
        self.applyEdit(txn, self.cursor.offset, newline_pos)
        self.cursor.offset = newline_pos
        self.recomputeLineCol()
        self.document.selection = Selection.point(self.cursor.offset)
    }

    /// Indent all lines touched by the selection (Tab with selection).
    fn indentSelection() void {
        const primary = self.document.selection.primary()
        const sel_from = primary.from()
        const sel_to = primary.to()
        const buf_len = self.document.buffer.len()
        // Find first and last lines
        const first_line = self.document.buffer.lineFromOffset(sel_from)
        var last_line = self.document.buffer.lineFromOffset(sel_to)
        // If selection ends at start of a line, don't include that line
        if (sel_to > sel_from and sel_to == self.document.buffer.lineStartOffset(last_line) and last_line > first_line) {
            last_line -= 1
        }
        // Build changeset: for each line, insert 4 spaces at line start
        var cs = ChangeSet.init()
        var prev_offset: i64 = 0
        var line = first_line
        while (line <= last_line) {
            const ls = self.document.buffer.lineStartOffset(line)
            const gap = ls - prev_offset
            if (gap > 0) { cs.retain(gap) }
            cs.insert("    ")
            prev_offset = ls
            line += 1
        }
        const rest = buf_len - prev_offset
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        const num_lines = last_line - first_line + 1
        // Adjust selection: expand by 4 bytes per line
        const new_from = sel_from + 4
        const new_to = sel_to + num_lines * 4
        self.applyEdit(txn, self.cursor.offset, new_from)
        self.document.selection = Selection.init(new_from, new_to)
        self.cursor.offset = new_to
        self.recomputeLineCol()
    }

    /// Outdent all lines touched by the selection (Shift+Tab).
    fn outdentSelection() void {
        const primary = self.document.selection.primary()
        const sel_from = primary.from()
        const sel_to = primary.to()
        const buf_len = self.document.buffer.len()
        const first_line = self.document.buffer.lineFromOffset(sel_from)
        var last_line = self.document.buffer.lineFromOffset(sel_to)
        if (sel_to > sel_from and sel_to == self.document.buffer.lineStartOffset(last_line) and last_line > first_line) {
            last_line -= 1
        }
        // Build changeset: for each line, remove up to 4 leading spaces
        var cs = ChangeSet.init()
        var prev_offset: i64 = 0
        var total_removed: i64 = 0
        var first_line_removed: i64 = 0
        var line = first_line
        while (line <= last_line) {
            const ls = self.document.buffer.lineStartOffset(line)
            const ll = self.document.buffer.lineLength(line)
            // Count leading spaces (up to 4)
            var spaces: i64 = 0
            while (spaces < 4 and spaces < ll) {
                if (self.document.buffer.charAt(ls + spaces) != ' ') { break }
                spaces += 1
            }
            if (spaces > 0) {
                const gap = ls - prev_offset
                if (gap > 0) { cs.retain(gap) }
                cs.delete(spaces)
                prev_offset = ls + spaces
                total_removed += spaces
                if (line == first_line) { first_line_removed = spaces }
            }
            line += 1
        }
        if (total_removed == 0) { return }
        const rest = buf_len - prev_offset
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        // Adjust selection
        var new_from = sel_from - first_line_removed
        if (new_from < self.document.buffer.lineStartOffset(first_line)) {
            new_from = self.document.buffer.lineStartOffset(first_line)
        }
        const new_to = sel_to - total_removed
        self.applyEdit(txn, self.cursor.offset, new_from)
        self.document.selection = Selection.init(new_from, new_to)
        self.cursor.offset = new_to
        self.recomputeLineCol()
    }

    /// Select the current line (Cmd+L). Repeated invocations extend by one line.
    fn selectLine() void {
        const buf_len = self.document.buffer.len()
        if (buf_len == 0) { return }
        const primary = self.document.selection.primary()
        const total_lines = self.document.buffer.lineCount()
        // If already at a full-line selection, extend by one more line
        const sel_from = primary.from()
        const sel_to = primary.to()
        const from_line = self.document.buffer.lineFromOffset(sel_from)
        const from_line_start = self.document.buffer.lineStartOffset(from_line)
        if (!primary.isEmpty() and sel_from == from_line_start) {
            // Selection starts at line start — check if it ends at a line boundary
            const to_line = self.document.buffer.lineFromOffset(sel_to)
            const to_line_start = self.document.buffer.lineStartOffset(to_line)
            if (sel_to == to_line_start or sel_to == buf_len) {
                // Already a full-line selection — extend to next line
                if (to_line < total_lines) {
                    var new_to = buf_len
                    if (to_line < total_lines - 1) {
                        new_to = self.document.buffer.lineStartOffset(to_line + 1)
                    }
                    self.document.selection = Selection.init(sel_from, new_to)
                    self.cursor.offset = new_to
                    self.recomputeLineCol()
                    return
                }
            }
        }
        // Select current line (from line start to start of next line)
        const line = self.cursor.line
        const line_start = self.document.buffer.lineStartOffset(line)
        var line_end = line_start + self.document.buffer.lineLength(line)
        if (line_end < buf_len) { line_end += 1 }  // Include newline
        self.document.selection = Selection.init(line_start, line_end)
        self.cursor.offset = line_end
        self.recomputeLineCol()
    }

    /// Go to a specific line number (1-indexed, from Cmd+G dialog).
    fn gotoLine(line_num: int) void {
        var target = line_num - 1  // Convert to 0-indexed
        if (target < 0) { target = 0 }
        const total_lines = self.document.buffer.lineCount()
        if (target >= total_lines) { target = total_lines - 1 }
        const offset = self.document.buffer.lineStartOffset(target)
        self.cursor.offset = offset
        self.cursor.line = target
        self.cursor.col = 0
        self.cursor.clearGoal()
        self.document.selection = Selection.point(offset)
    }

    /// Add a new cursor at the given byte offset.
    fn addCursorAt(offset: int) void {
        self.document.selection.push(Range { anchor: offset, head: offset })
        self.syncCursorFromPrimary()
    }

    /// Find next occurrence of the selected text (or word under cursor) and add a selection.
    /// Used by Cmd+D. If nothing is selected, selects the word under cursor first.
    fn addNextOccurrence() void {
        const primary = self.document.selection.primary()
        if (primary.isEmpty()) {
            // Select word under cursor first
            const offset = self.cursor.offset
            const buf_len = self.document.buffer.len()
            if (buf_len == 0) { return }
            var pos = offset
            if (pos >= buf_len) { pos = buf_len - 1 }
            const cat = charCategory(self.document.buffer.charAt(pos))
            if (cat == 0) { return }  // On whitespace, do nothing
            // Find word start
            var word_start = pos
            while (word_start > 0) {
                if (charCategory(self.document.buffer.charAt(word_start - 1)) != cat) { break }
                word_start -= 1
            }
            // Find word end
            var word_end = pos + 1
            while (word_end < buf_len) {
                if (charCategory(self.document.buffer.charAt(word_end)) != cat) { break }
                word_end += 1
            }
            // Select this word
            self.document.selection.replace(self.document.selection.primary_index,
                Range { anchor: word_start, head: word_end })
            self.syncCursorFromPrimary()
            return
        }
        // Find next occurrence of selected text after the last range
        const sel_from = primary.from()
        const sel_to = primary.to()
        const sel_len = sel_to - sel_from
        if (sel_len == 0) { return }
        // Search starting after the last selection range's end
        var last_end: i64 = 0
        var i: i64 = 0
        while (i < self.document.selection.ranges.count) {
            const r = self.document.selection.ranges.get(i)
            if (r.to() > last_end) { last_end = r.to() }
            i += 1
        }
        const buf_len = self.document.buffer.len()
        var search_pos = last_end
        while (search_pos + sel_len <= buf_len) {
            // Check if text at search_pos matches
            var match = true
            var j: i64 = 0
            while (j < sel_len) {
                if (self.document.buffer.charAt(search_pos + j) != self.document.buffer.charAt(sel_from + j)) {
                    match = false
                    break
                }
                j += 1
            }
            if (match) {
                // Add this occurrence as a new selection
                self.document.selection.push(Range { anchor: search_pos, head: search_pos + sel_len })
                self.syncCursorFromPrimary()
                return
            }
            search_pos += 1
        }
        // Wrap around: search from beginning
        search_pos = 0
        while (search_pos + sel_len <= last_end) {
            var match = true
            var j: i64 = 0
            while (j < sel_len) {
                if (self.document.buffer.charAt(search_pos + j) != self.document.buffer.charAt(sel_from + j)) {
                    match = false
                    break
                }
                j += 1
            }
            if (match) {
                self.document.selection.push(Range { anchor: search_pos, head: search_pos + sel_len })
                self.syncCursorFromPrimary()
                return
            }
            search_pos += 1
        }
    }

    /// Check if we have multiple cursors.
    fn hasMultipleCursors() bool {
        return self.document.selection.ranges.count > 1
    }

    /// Collapse to single primary cursor (Escape key).
    fn collapseToPrimaryCursor() void {
        self.document.selection.intoSingle()
        self.syncCursorFromPrimary()
    }

    /// Delete the text covered by the primary selection range.
    /// Builds a transaction: retain(from), delete(to-from), retain(rest).
    fn deleteSelection() void {
        const primary = self.document.selection.primary()
        if (primary.isEmpty()) { return }
        const from = primary.from()
        const to = primary.to()
        const del_len = to - from
        const cursor_before = self.cursor.offset
        var cs = ChangeSet.init()
        if (from > 0) { cs.retain(from) }
        cs.delete(del_len)
        const rest = self.document.buffer.len() - to
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        self.applyEdit(txn, cursor_before, from)
        self.cursor.offset = from
        self.recomputeLineCol()
    }

    /// Copy the primary selection text into yank_buf.
    /// Detects linewise selections (starts at line start, ends at line start/end-of-buffer).
    fn yankSelection() void {
        const primary = self.document.selection.primary()
        if (primary.isEmpty()) { return }
        const from = primary.from()
        const to = primary.to()
        // Clear and fill yank buffer
        self.yank_buf.count = 0
        var i = from
        while (i < to) {
            const ch = self.document.buffer.charAt(i)
            self.yank_buf.append(@intCast(u8, ch))
            i += 1
        }
        // Detect linewise: selection starts at col 0 and ends at a line boundary
        var starts_at_line_start = false
        if (from == 0) {
            starts_at_line_start = true
        } else if (self.document.buffer.charAt(from - 1) == '\n') {
            starts_at_line_start = true
        }
        var ends_at_line_boundary = false
        if (to == self.document.buffer.len()) {
            // End of buffer counts if there's content
            if (to > from) { ends_at_line_boundary = true }
        } else if (to > 0 and self.document.buffer.charAt(to - 1) == '\n') {
            ends_at_line_boundary = true
        }
        self.yank_is_linewise = starts_at_line_start and ends_at_line_boundary
    }

    /// Smart paste: single-transaction insert with linewise and indent awareness.
    /// - If selection is non-empty, deletes it first.
    /// - If the yank buffer is linewise, inserts on a new line below cursor.
    /// - Adjusts indentation of pasted text to match cursor context.
    fn editorPaste(text_ptr: *u8, text_len: int) void {
        if (text_len == 0) { return }
        self.document.history.breakGroup()
        self.last_edit_kind = 0
        self.cursor.clearGoal()
        // Delete selection if non-empty
        const primary = self.document.selection.primary()
        if (!primary.isEmpty()) {
            self.deleteSelection()
            self.document.selection = Selection.point(self.cursor.offset)
        }
        // Determine indentation context at cursor
        const cursor_line_start = self.document.buffer.lineStartOffset(self.cursor.line)
        var target_indent = 0
        var scan = cursor_line_start
        while (scan < self.document.buffer.len()) {
            const ch = self.document.buffer.charAt(scan)
            if (ch != ' ' and ch != '\t') { break }
            target_indent += 1
            scan += 1
        }
        // Find base indentation of pasted text (minimum non-empty line indent)
        var paste_base_indent = 9999
        var line_indent = 0
        var line_has_content = false
        var at_line_start = true
        for pi in 0..text_len {
            const ch = @intToPtr(*u8, @ptrToInt(text_ptr) + pi).*
            if (ch == '\n') {
                if (line_has_content and line_indent < paste_base_indent) {
                    paste_base_indent = line_indent
                }
                line_indent = 0
                line_has_content = false
                at_line_start = true
            } else if (at_line_start and (ch == ' ' or ch == '\t')) {
                line_indent += 1
            } else {
                line_has_content = true
                at_line_start = false
            }
        }
        // Handle last line (no trailing newline)
        if (line_has_content and line_indent < paste_base_indent) {
            paste_base_indent = line_indent
        }
        if (paste_base_indent == 9999) { paste_base_indent = 0 }
        // Build the adjusted paste content into a temporary buffer
        var paste_buf: List(u8) = .{}
        if (self.yank_is_linewise) {
            // Linewise: insert newline, then adjusted text on new lines
            paste_buf.append('\n')
        }
        var p_at_line_start = true
        var p_indent_skipped = 0
        for pi in 0..text_len {
            const ch = @intCast(int, @intToPtr(*u8, @ptrToInt(text_ptr) + pi).*)
            if (ch == '\n') {
                paste_buf.append('\n')
                p_at_line_start = true
                p_indent_skipped = 0
            } else if (p_at_line_start and (ch == ' ' or ch == '\t') and p_indent_skipped < paste_base_indent) {
                // Skip base indent characters
                p_indent_skipped += 1
            } else {
                if (p_at_line_start) {
                    // Emit target indentation
                    for ti in 0..target_indent {
                        paste_buf.append(' ')
                    }
                    p_at_line_start = false
                }
                paste_buf.append(@intCast(u8, ch))
            }
        }
        // Handle linewise: strip trailing newline if text already ends with one
        if (self.yank_is_linewise and paste_buf.count > 0) {
            const last = paste_buf.get(paste_buf.count - 1)
            if (last == '\n') {
                paste_buf.count -= 1
            }
        }
        // Build transaction: retain(before) + insert(paste_buf) + retain(rest)
        const cursor_before = self.cursor.offset
        var insert_at = cursor_before
        if (self.yank_is_linewise) {
            // Insert after current line end
            insert_at = self.document.buffer.lineStartOffset(self.cursor.line) + self.document.buffer.lineLength(self.cursor.line)
        }
        var cs = ChangeSet.init()
        if (insert_at > 0) { cs.retain(insert_at) }
        for bi in 0..paste_buf.count {
            cs.insertByte(paste_buf.get(bi))
        }
        const rest = self.document.buffer.len() - insert_at
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        const cursor_after = insert_at + paste_buf.count
        self.applyEdit(txn, cursor_before, cursor_after)
        self.cursor.offset = cursor_after
        self.recomputeLineCol()
        self.document.selection = Selection.point(self.cursor.offset)
        self.document.history.breakGroup()
    }

    /// Surround the current selection with opening and closing characters.
    /// E.g., selecting "hello" and typing ( produces "(hello)" with selection preserved.
    fn surroundSelection(open: int, close: int) void {
        const primary = self.document.selection.primary()
        if (primary.isEmpty()) { return }
        const from = primary.from()
        const to = primary.to()
        const cursor_before = self.cursor.offset
        // Build transaction: retain(from), insert(open), retain(sel_len), insert(close), retain(rest)
        var cs = ChangeSet.init()
        if (from > 0) { cs.retain(from) }
        cs.insertByte(open)
        cs.retain(to - from)
        cs.insertByte(close)
        const rest = self.document.buffer.len() - to
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        self.applyEdit(txn, cursor_before, to + 2)
        // Update selection to cover the wrapped text (between brackets)
        self.document.selection = Selection.init(from + 1, to + 1)
        self.cursor.offset = to + 1
        self.recomputeLineCol()
    }

    /// Insert a newline with auto-indentation (Zed-style).
    /// Inherits whitespace from current line. Adds indent after { ( [ :.
    /// If closing bracket follows cursor, adds dedented closing line.
    fn insertNewlineWithIndent() void {
        const cursor_before = self.cursor.offset
        // Get leading whitespace of current line
        const line_start = self.document.buffer.lineStartOffset(self.cursor.line)
        var indent_len = 0
        var scan = line_start
        while (scan < self.document.buffer.len()) {
            const ch = self.document.buffer.charAt(scan)
            if (ch != ' ' and ch != '\t') { break }
            indent_len += 1
            scan += 1
        }
        // Check if char before cursor is an indent-opener
        var extra_indent = false
        if (cursor_before > 0) {
            const prev_ch = self.document.buffer.charAt(cursor_before - 1)
            if (prev_ch == '{' or prev_ch == '(' or prev_ch == '[' or prev_ch == ':') {
                extra_indent = true
            }
        }
        // Check if char after cursor is a closing bracket
        var close_bracket = false
        if (extra_indent and cursor_before < self.document.buffer.len()) {
            const next_ch = self.document.buffer.charAt(cursor_before)
            if (next_ch == '}' or next_ch == ')' or next_ch == ']') {
                close_bracket = true
            }
        }
        // Build insertion text: \n + indent [+ extra spaces] [+ \n + indent]
        var insert_text: List(u8) = .{}
        insert_text.append('\n')
        // Copy base indentation
        var j = 0
        while (j < indent_len) {
            insert_text.append(@intCast(u8, self.document.buffer.charAt(line_start + j)))
            j += 1
        }
        if (extra_indent) {
            // Add one indent level (4 spaces)
            insert_text.append(' ')
            insert_text.append(' ')
            insert_text.append(' ')
            insert_text.append(' ')
        }
        const cursor_after = cursor_before + insert_text.count
        if (close_bracket) {
            // Add closing line: \n + base indent
            insert_text.append('\n')
            var k = 0
            while (k < indent_len) {
                insert_text.append(@intCast(u8, self.document.buffer.charAt(line_start + k)))
                k += 1
            }
        }
        // Build changeset
        var cs = ChangeSet.init()
        if (cursor_before > 0) { cs.retain(cursor_before) }
        cs.insert(@string(insert_text.items, insert_text.count))
        const rest = self.document.buffer.len() - cursor_before
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        self.applyEdit(txn, cursor_before, cursor_after)
        self.cursor.offset = cursor_after
        self.recomputeLineCol()
    }

    /// Apply a transaction and update the scroll anchor through the changeset.
    /// This keeps the viewport stable when edits happen above the visible area.
    fn applyEdit(txn: Transaction, cursor_before: int, cursor_after: int) void {
        self.document.apply(txn, cursor_before, cursor_after)
        // Map scroll anchor through the changeset (ASSOC_BEFORE: stay at same visual position)
        self.scroll_anchor = txn.mapPos(self.scroll_anchor, ASSOC_BEFORE)
        // Rebuild wrap map and convert anchor → display row
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        self.rebuildWrapMap(content_cols)
        const anchor_line = self.document.buffer.lineFromOffset(self.scroll_anchor)
        self.scroll_offset = self.wrapLineToDisplayRow(anchor_line)
    }

    // ========================================================================
    // Search (Cmd+F)
    // ========================================================================

    /// Open the search overlay. If text is selected, use it as initial query.
    fn searchOpen() void {
        self.search.open()
        // Populate query from selection if non-empty
        const primary = self.document.selection.primary()
        if (!primary.isEmpty()) {
            self.search.query.count = 0
            self.search.query_cursor = 0
            const from = primary.from()
            const to = primary.to()
            var i = from
            while (i < to) {
                self.search.query.append(@intCast(u8, self.document.buffer.charAt(i)))
                i += 1
            }
            self.search.query_cursor = self.search.query.count
            self.search.dirty = true
        }
        self.searchUpdate()
    }

    /// Close the search overlay.
    fn searchClose() void {
        self.search.close()
    }

    /// Handle a key event while search overlay is active.
    /// Returns true if the key was consumed, false if it should pass through.
    fn handleSearchKey(key: int, mods: int) bool {
        const has_ctrl = (mods & MOD_CTRL) != 0
        const has_shift = (mods & MOD_SHIFT) != 0
        const has_super = (mods & MOD_SUPER) != 0

        // Escape — close search
        if (key == KEY_ESCAPE) {
            self.searchClose()
            return true
        }

        // Enter — next match (Shift+Enter = prev)
        if (key == KEY_ENTER) {
            if (has_shift) {
                self.search.prevMatch()
            } else {
                self.search.nextMatch()
            }
            self.searchJumpToMatch()
            return true
        }

        // Tab — toggle focus between query and replace
        if (key == KEY_TAB) {
            if (self.search.replace_active) {
                self.search.toggleFocus()
            }
            return true
        }

        // Arrow keys
        if (key == KEY_ARROW_LEFT) {
            self.search.moveCursorLeft()
            return true
        }
        if (key == KEY_ARROW_RIGHT) {
            self.search.moveCursorRight()
            return true
        }
        // Up/Down — navigate matches
        if (key == KEY_ARROW_UP) {
            self.search.prevMatch()
            self.searchJumpToMatch()
            return true
        }
        if (key == KEY_ARROW_DOWN) {
            self.search.nextMatch()
            self.searchJumpToMatch()
            return true
        }

        // Home/End
        if (key == KEY_HOME or (has_super and key == KEY_ARROW_LEFT)) {
            self.search.moveCursorHome()
            return true
        }
        if (key == KEY_END or (has_super and key == KEY_ARROW_RIGHT)) {
            self.search.moveCursorEnd()
            return true
        }

        // Backspace
        if (key == KEY_BACKSPACE) {
            self.search.deleteBack()
            if (self.search.dirty) { self.searchUpdate() }
            return true
        }
        // Delete
        if (key == KEY_DELETE) {
            self.search.deleteForward()
            if (self.search.dirty) { self.searchUpdate() }
            return true
        }

        // Cmd+Shift+H — toggle replace
        if (has_super and has_shift and key == 'H') {
            self.search.toggleReplace()
            return true
        }

        // Ctrl+Shift+C — toggle case sensitivity
        if (has_ctrl and has_shift and key == 'C') {
            self.search.toggleCaseSensitive()
            self.searchUpdate()
            return true
        }

        // Cmd+G / Cmd+Shift+G — next/prev match (Zed keybindings)
        if (has_super and !has_ctrl and key == 'g') {
            if (has_shift) {
                self.search.prevMatch()
            } else {
                self.search.nextMatch()
            }
            self.searchJumpToMatch()
            return true
        }
        if (has_super and !has_ctrl and key == 'G') {
            self.search.prevMatch()
            self.searchJumpToMatch()
            return true
        }

        // Printable characters
        if (key >= 32 and key <= 126 and !has_ctrl and !has_super) {
            self.search.insertChar(key)
            if (self.search.dirty) { self.searchUpdate() }
            return true
        }

        return false
    }

    /// Re-run the search and select the nearest match.
    fn searchUpdate() void {
        findAllMatches(&self.search.matches, &self.document.buffer, &self.search.query, self.search.case_sensitive)
        self.search.dirty = false
        if (self.search.matches.count > 0) {
            self.search.current_match = findNearestMatch(&self.search.matches, self.cursor.offset)
            self.searchJumpToMatch()
        } else {
            self.search.current_match = -1
        }
    }

    /// Jump the cursor to the current match and scroll it into view.
    fn searchJumpToMatch() void {
        const m = self.search.currentMatchRange()
        if (m.start < 0) { return }
        self.cursor.offset = m.start
        self.recomputeLineCol()
        // Select the match text
        self.document.selection = Selection.init(m.start, m.end)
    }

    /// Replace the current match with the replacement text.
    fn searchReplaceCurrent() void {
        const m = self.search.currentMatchRange()
        if (m.start < 0) { return }
        const match_len = m.end - m.start
        const cursor_before = self.cursor.offset
        // Build changeset: retain(start), delete(match_len), insert(replace), retain(rest)
        var cs = ChangeSet.init()
        if (m.start > 0) { cs.retain(m.start) }
        cs.delete(match_len)
        // Insert replacement text
        var ri = 0
        while (ri < self.search.replace_text.count) {
            cs.insertByte(self.search.replace_text.get(ri))
            ri += 1
        }
        const rest = self.document.buffer.len() - m.end
        if (rest > 0) { cs.retain(rest) }
        var txn = Transaction { changes: cs }
        self.document.history.breakGroup()
        self.applyEdit(txn, cursor_before, m.start + self.search.replace_text.count)
        self.cursor.offset = m.start + self.search.replace_text.count
        self.recomputeLineCol()
        self.document.selection = Selection.point(self.cursor.offset)
        // Re-search after replacement
        self.searchUpdate()
    }

    /// Replace all matches with the replacement text.
    fn searchReplaceAll() void {
        if (self.search.matches.count == 0) { return }
        if (self.search.query.count == 0) { return }
        const cursor_before = self.cursor.offset
        self.document.history.breakGroup()
        // Build single transaction for all replacements
        var changes: List(Change) = .{}
        var i = 0
        while (i < self.search.matches.count) {
            const m = self.search.matches.get(i)
            // Build replacement string from replace_text List
            var replace_str: List(u8) = .{}
            var ri = 0
            while (ri < self.search.replace_text.count) {
                replace_str.append(self.search.replace_text.get(ri))
                ri += 1
            }
            changes.append(Change {
                from: m.start,
                to: m.end,
                text: @string(replace_str.items, replace_str.count),
            })
            i += 1
        }
        var txn = Transaction.fromChanges(self.document.buffer.len(), &changes)
        self.applyEdit(txn, cursor_before, cursor_before)
        self.recomputeLineCol()
        self.document.selection = Selection.point(self.cursor.offset)
        // Re-search (should find 0 matches now)
        self.searchUpdate()
    }

    /// Whether the search overlay is active (for FFI query).
    fn isSearchActive() bool {
        return self.search.active
    }

    /// Perform undo via Document, update cursor.
    fn performUndo() void {
        const cursor = self.document.undo()
        if (cursor >= 0) {
            self.cursor.offset = cursor
            if (self.cursor.offset > self.document.buffer.len()) {
                self.cursor.offset = self.document.buffer.len()
            }
            self.recomputeLineCol()
        }
    }

    /// Perform redo via Document, update cursor.
    fn performRedo() void {
        const cursor = self.document.redo()
        if (cursor >= 0) {
            self.cursor.offset = cursor
            if (self.cursor.offset > self.document.buffer.len()) {
                self.cursor.offset = self.document.buffer.len()
            }
            self.recomputeLineCol()
        }
    }

    // ========================================================================
    // Editor Grid Rendering
    // ========================================================================

    /// Write a string into the render grid at (row, col) with RGB color.
    /// Returns the column after the last character written.
    fn gridWriteStr(row: i64, col: i64, s: string, r: i64, g: i64, b: i64) i64 {
        if (row < 0 or row >= self.viewport_rows) { return col }
        for i in 0..s.len {
            if (col + i >= self.viewport_cols) { return col + i }
            const c = self.render_grid.getCell(row, col + i)
            c.codepoint = s[i]
            c.fg_type = COLOR_RGB
            c.fg_val = packRgb(r, g, b)
        }
        return col + s.len
    }

    /// Fill cells in a row with a background color.
    fn gridFillBg(row: i64, col_start: i64, col_end: i64, r: i64, g: i64, b: i64) void {
        if (row < 0 or row >= self.viewport_rows) { return }
        const end = if (col_end > self.viewport_cols) { self.viewport_cols } else { col_end }
        for col in col_start..end {
            const c = self.render_grid.getCell(row, col)
            c.bg_type = COLOR_RGB
            c.bg_val = packRgb(r, g, b)
        }
    }

    /// Resize the editor render grid and re-render.
    fn resizeEditorGrid(rows: i64, cols: i64) void {
        self.viewport_rows = rows
        self.viewport_cols = cols
        self.render_grid = TerminalGrid.init(rows, cols)
        self.ensureCursorInView()
        self.renderEditorGrid()
    }

    /// Scroll to keep cursor visible, with scrolloff margin.
    /// Uses display rows for soft-wrapped content.
    fn ensureCursorInView() void {
        const scrolloff: i64 = 5
        const content_rows = self.viewport_rows - self.search.overlayRows()
        if (content_rows <= 0) { return }
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        // Rebuild wrap map to get current display row mapping
        self.rebuildWrapMap(content_cols)
        const cursor_dr = self.wrapBufToDisplayRow(self.cursor.line, self.cursor.col, content_cols)
        if (cursor_dr < self.scroll_offset + scrolloff) {
            self.scroll_offset = cursor_dr - scrolloff
            if (self.scroll_offset < 0) { self.scroll_offset = 0 }
        }
        if (cursor_dr >= self.scroll_offset + content_rows - scrolloff) {
            self.scroll_offset = cursor_dr - content_rows + scrolloff + 1
        }
        // Sync scroll anchor from display row
        const anchor_line = self.wrapDisplayRowToLine(self.scroll_offset)
        self.scroll_anchor = self.document.buffer.lineStartOffset(anchor_line)
        // No horizontal scroll with soft wrapping
        self.h_scroll_offset = 0
    }

    /// Compute gutter width (digits + 1 space padding + 1 gap + 1 separator).
    fn gutterWidth(total_lines: i64) i64 {
        var digits: i64 = 1
        var n = total_lines
        while (n >= 10) {
            n = n / 10
            digits += 1
        }
        const width = digits + 3
        if (width < 5) { return 5 }
        return width
    }

    /// Render search overlay bar at top of editor grid.
    /// Row 0: "Find: [query]    N/M  Aa"
    /// Row 1 (if replace active): "Replace: [text]"
    fn renderSearchOverlay(overlay_rows: i64) void {
        // Search bar background — slightly lighter than editor bg
        var bar_bg_r = THEME_BG_R + 30
        var bar_bg_g = THEME_BG_G + 30
        var bar_bg_b = THEME_BG_B + 30
        if (bar_bg_r > 255) { bar_bg_r = 255 }
        if (bar_bg_g > 255) { bar_bg_g = 255 }
        if (bar_bg_b > 255) { bar_bg_b = 255 }

        // Row 0: Find row
        self.gridFillBg(0, 0, self.viewport_cols, bar_bg_r, bar_bg_g, bar_bg_b)
        var col: i64 = 1
        col = self.gridWriteStr(0, col, "Find: ", THEME_FG_R, THEME_FG_G, THEME_FG_B)
        const query_start_col = col
        // Write query text from List(u8)
        var qi: i64 = 0
        while (qi < self.search.query.count) {
            if (col >= self.viewport_cols - 15) { break }  // leave room for match count
            const ch: i64 = self.search.query.get(qi)
            const c = self.render_grid.getCell(0, col)
            c.codepoint = ch
            c.fg_type = COLOR_RGB
            c.fg_val = packRgb(THEME_FG_R, THEME_FG_G, THEME_FG_B)
            col += 1
            qi += 1
        }
        // Mark cursor position in query field
        if (self.search.focus == SearchFocus.Query) {
            const cursor_col = query_start_col + self.search.query_cursor
            if (cursor_col >= 0 and cursor_col < self.viewport_cols) {
                const cc = self.render_grid.getCell(0, cursor_col)
                cc.flags = cc.flags | CELL_CURSOR
            }
        }
        // Match count "N/M" at right side
        if (self.search.matches.count > 0) {
            var match_sb: StringBuilder = .{}
            if (self.search.current_match >= 0) {
                match_sb.appendInt(self.search.current_match + 1)
            } else {
                match_sb.append("0")
            }
            match_sb.append("/")
            match_sb.appendInt(self.search.matches.count)
            const match_str = match_sb.toString()
            const match_col = self.viewport_cols - match_str.len - 2
            if (match_col > col) {
                self.gridWriteStr(0, match_col, match_str, 180, 180, 190)
            }
        } else if (self.search.query.count > 0) {
            // No matches found
            const no_col = self.viewport_cols - 12
            if (no_col > col) {
                self.gridWriteStr(0, no_col, "No results", 180, 100, 100)
            }
        }
        // Case sensitivity indicator
        if (self.search.case_sensitive) {
            const aa_col = self.viewport_cols - 15
            if (aa_col > col) {
                self.gridWriteStr(0, aa_col, "Aa", 130, 180, 130)
            }
        }

        // Row 1: Replace row (if active)
        if (overlay_rows >= 2) {
            self.gridFillBg(1, 0, self.viewport_cols, bar_bg_r, bar_bg_g, bar_bg_b)
            var rcol: i64 = 1
            rcol = self.gridWriteStr(1, rcol, "Replace: ", THEME_FG_R, THEME_FG_G, THEME_FG_B)
            const replace_start_col = rcol
            // Write replace text from List(u8)
            var ri: i64 = 0
            while (ri < self.search.replace_text.count) {
                if (rcol >= self.viewport_cols - 2) { break }
                const rch: i64 = self.search.replace_text.get(ri)
                const rc = self.render_grid.getCell(1, rcol)
                rc.codepoint = rch
                rc.fg_type = COLOR_RGB
                rc.fg_val = packRgb(THEME_FG_R, THEME_FG_G, THEME_FG_B)
                rcol += 1
                ri += 1
            }
            // Mark cursor position in replace field
            if (self.search.focus == SearchFocus.Replace) {
                const rcursor_col = replace_start_col + self.search.replace_cursor
                if (rcursor_col >= 0 and rcursor_col < self.viewport_cols) {
                    const rcc = self.render_grid.getCell(1, rcursor_col)
                    rcc.flags = rcc.flags | CELL_CURSOR
                }
            }
        }
    }

    /// Mark cells that fall within search matches with CELL_SEARCH_MATCH flag.
    /// Uses display coordinates for soft-wrapped rendering.
    fn renderSearchMatches(gutter_w: i64, row_offset: i64, content_rows: i64) void {
        const content_cols = self.viewport_cols - gutter_w
        if (content_cols <= 0) { return }
        var mi: i64 = 0
        while (mi < self.search.matches.count) {
            const m = self.search.matches.get(mi)
            const is_current = (mi == self.search.current_match)
            const from_line = self.offsetToLine(m.start)
            const from_col = m.start - self.document.buffer.lineStartOffset(from_line)
            const to_line = self.offsetToLine(m.end - 1)
            const to_col = m.end - self.document.buffer.lineStartOffset(to_line)
            // Iterate display rows spanned by match
            const from_dr = self.wrapBufToDisplayRow(from_line, from_col, content_cols)
            const to_dr = self.wrapBufToDisplayRow(to_line, to_col - 1, content_cols)
            var dr = from_dr
            while (dr <= to_dr) {
                const screen_row = dr - self.scroll_offset + row_offset
                if (screen_row < row_offset) { dr += 1; continue }
                if (screen_row >= self.viewport_rows) { break }
                const dr_line = self.wrapDisplayRowToLine(dr)
                const dr_base = self.wrapLineToDisplayRow(dr_line)
                const wrap_row = dr - dr_base
                const line_len = self.document.buffer.lineLength(dr_line)
                const wrap_start = wrap_row * content_cols
                var wrap_end = wrap_start + content_cols
                if (wrap_end > line_len) { wrap_end = line_len }
                var sel_start: i64 = 0
                if (dr_line == from_line) { sel_start = from_col }
                var sel_end = line_len
                if (dr_line == to_line) { sel_end = to_col }
                if (sel_start < wrap_start) { sel_start = wrap_start }
                if (sel_end > wrap_end) { sel_end = wrap_end }
                var col = sel_start
                while (col < sel_end) {
                    const screen_col = gutter_w + col - wrap_start
                    if (screen_col >= 0 and screen_col < self.viewport_cols) {
                        const c = self.render_grid.getCell(screen_row, screen_col)
                        c.flags = c.flags | CELL_SEARCH_MATCH
                        if (is_current) {
                            c.bg_type = COLOR_RGB
                            c.bg_val = packRgb(200, 150, 30)
                        } else {
                            c.bg_type = COLOR_RGB
                            c.bg_val = packRgb(120, 90, 0)
                        }
                    }
                    col += 1
                }
                dr += 1
            }
            mi += 1
        }
    }

    // ========================================================================
    // Soft Wrap Map (Zed: WrapMap)
    // ========================================================================

    /// Rebuild the wrap map by scanning the buffer once. O(buffer_size).
    /// Computes how many display rows each logical line occupies.
    fn rebuildWrapMap(content_cols: i64) void {
        var new_counts: List(i64) = .{}
        var new_cum: List(i64) = .{}
        const buf_len = self.document.buffer.len()
        var cumulative: i64 = 0
        var line_start: i64 = 0
        var i: i64 = 0
        while (i < buf_len) {
            if (self.document.buffer.charAt(i) == '\n') {
                const line_len = i - line_start
                new_cum.append(cumulative)
                var rows: i64 = 1
                if (content_cols > 0 and line_len > content_cols) {
                    rows = (line_len + content_cols - 1) / content_cols
                }
                new_counts.append(rows)
                cumulative += rows
                line_start = i + 1
            }
            i += 1
        }
        // Last line (may not end with newline)
        const last_len = buf_len - line_start
        new_cum.append(cumulative)
        var last_rows: i64 = 1
        if (content_cols > 0 and last_len > content_cols) {
            last_rows = (last_len + content_cols - 1) / content_cols
        }
        new_counts.append(last_rows)
        cumulative += last_rows
        self.wrap_counts = new_counts
        self.wrap_cum_rows = new_cum
        self.wrap_total_rows = cumulative
    }

    /// First display row index for a logical line.
    fn wrapLineToDisplayRow(line: i64) i64 {
        if (line < 0) { return 0 }
        if (line >= self.wrap_cum_rows.count) { return self.wrap_total_rows }
        return self.wrap_cum_rows.get(line)
    }

    /// Number of display rows for a logical line.
    fn wrapLineDisplayRows(line: i64) i64 {
        if (line < 0 or line >= self.wrap_counts.count) { return 1 }
        return self.wrap_counts.get(line)
    }

    /// Convert buffer (line, col) to display row index.
    fn wrapBufToDisplayRow(line: i64, col: i64, content_cols: i64) i64 {
        const base = self.wrapLineToDisplayRow(line)
        if (content_cols <= 0) { return base }
        return base + col / content_cols
    }

    /// Convert buffer col to display col within a wrapped row.
    fn wrapBufToDisplayCol(col: i64, content_cols: i64) i64 {
        if (content_cols <= 0) { return col }
        return col - (col / content_cols) * content_cols
    }

    /// Convert display row to logical line (binary search on prefix sums).
    fn wrapDisplayRowToLine(display_row: i64) i64 {
        if (display_row < 0) { return 0 }
        if (display_row >= self.wrap_total_rows) {
            if (self.wrap_cum_rows.count > 0) { return self.wrap_cum_rows.count - 1 }
            return 0
        }
        var lo: i64 = 0
        var hi: i64 = self.wrap_cum_rows.count - 1
        var result: i64 = 0
        while (lo <= hi) {
            const mid = (lo + hi) / 2
            if (self.wrap_cum_rows.get(mid) <= display_row) {
                result = mid
                lo = mid + 1
            } else {
                hi = mid - 1
            }
        }
        return result
    }

    /// Convert display (row, col) to buffer column within the logical line.
    fn wrapDisplayToBufferCol(display_row: i64, display_col: i64, content_cols: i64) i64 {
        const line = self.wrapDisplayRowToLine(display_row)
        const base = self.wrapLineToDisplayRow(line)
        const wrap_offset = display_row - base
        if (content_cols <= 0) { return display_col }
        return wrap_offset * content_cols + display_col
    }

    /// Render the entire editor grid: gutter, content, cursor.
    fn renderEditorGrid() void {
        if (self.viewport_rows <= 0 or self.viewport_cols <= 0) { return }

        // Validate buffer before rendering — catches delayed corruption
        if (g_buffer_debug) {
            if (!self.document.buffer.validate()) {
                self.document.buffer.dumpState("CORRUPT before renderEditorGrid")
                @trap()
            }
        }

        // Clear grid
        self.render_grid = TerminalGrid.init(self.viewport_rows, self.viewport_cols)

        // Layout
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        const overlay_rows = self.search.overlayRows()
        const content_rows = self.viewport_rows - overlay_rows

        // Rebuild wrap map for current content width
        self.rebuildWrapMap(content_cols)

        // Rebuild tree-sitter highlights (Phase 1: full text each frame)
        if (self.hasTreeSitter()) {
            const text = self.document.buffer.toString()
            tsRebuildHighlights(text, &self.hl_tokens)
        }

        // Search overlay at top of grid
        if (overlay_rows > 0) {
            self.renderSearchOverlay(overlay_rows)
        }

        // Render visible display rows (soft-wrapped)
        for row in 0..content_rows {
            const display_row = self.scroll_offset + row
            if (display_row >= self.wrap_total_rows) { break }
            const screen_row = row + overlay_rows

            // Map display row → logical line + wrap offset
            const doc_line = self.wrapDisplayRowToLine(display_row)
            const base_display_row = self.wrapLineToDisplayRow(doc_line)
            const wrap_row = display_row - base_display_row

            // Line number on first wrap row only
            if (wrap_row == 0) {
                self.renderLineNumber(screen_row, doc_line, gutter_w)
            }

            // Content for this wrap segment
            self.renderWrappedLineContent(screen_row, doc_line, wrap_row, gutter_w, content_cols)
        }

        // Search match highlights
        if (self.search.active and self.search.matches.count > 0) {
            self.renderSearchMatches(gutter_w, overlay_rows, content_rows)
        }

        // Selection highlight
        self.renderSelection(overlay_rows)

        // Cursor positions (all selection range heads)
        self.renderCursors(gutter_w, overlay_rows)

        // Bracket match highlight
        self.renderBracketMatch(gutter_w, overlay_rows)
    }

    /// Render a right-aligned line number in the gutter.
    fn renderLineNumber(screen_row: i64, doc_line: i64, gutter_w: i64) void {
        // Convert line number to string (1-based)
        const line_num = doc_line + 1
        var num_sb: StringBuilder = .{}
        num_sb.appendInt(line_num)
        const num_str = num_sb.toString()

        // Right-align: place digits so last digit is at gutter_w - 2
        const start_col = gutter_w - 1 - num_str.len
        if (start_col < 0) { return }

        // Color: bright for cursor line, dim for others
        var r: i64 = 100
        var g: i64 = 100
        var b: i64 = 110
        if (doc_line == self.cursor.line) {
            r = THEME_FG_R
            g = THEME_FG_G
            b = THEME_FG_B
        }
        self.gridWriteStr(screen_row, start_col, num_str, r, g, b)
    }

    /// Render a wrap segment of a buffer line.
    /// wrap_row 0 = first content_cols chars, wrap_row 1 = next content_cols, etc.
    fn renderWrappedLineContent(screen_row: i64, doc_line: i64, wrap_row: i64, gutter_w: i64, content_cols: i64) void {
        const line_len = self.document.buffer.lineLength(doc_line)
        const line_start = self.document.buffer.lineStartOffset(doc_line)
        const first_char = wrap_row * content_cols
        if (first_char >= line_len) { return }
        const remaining = line_len - first_char
        const max_chars = if (content_cols < remaining) { content_cols } else { remaining }
        const has_hl = self.hasTreeSitter()
        for col in 0..max_chars {
            const byte_offset = line_start + first_char + col
            const ch = self.document.buffer.charAt(byte_offset)
            if (ch >= 32) {
                const c = self.render_grid.getCell(screen_row, gutter_w + col)
                c.codepoint = ch
                c.fg_type = COLOR_RGB
                // Look up syntax token color
                var fg = packRgb(THEME_FG_R, THEME_FG_G, THEME_FG_B)
                if (has_hl) {
                    const tok = tsTokenAt(&self.hl_tokens, byte_offset)
                    const tok_color = tokenColor(tok)
                    if (tok_color != 0) {
                        fg = tok_color
                    }
                }
                c.fg_val = fg
            }
        }
    }

    /// Convert a byte offset to a line number by scanning lineStartOffset().
    fn offsetToLine(offset: i64) i64 {
        const total = self.document.buffer.lineCount()
        var line: i64 = 0
        while (line < total - 1) {
            const next_start = self.document.buffer.lineStartOffset(line + 1)
            if (offset < next_start) { return line }
            line += 1
        }
        return line
    }

    /// Convert a byte offset to a column within its line.
    fn offsetToCol(offset: i64) i64 {
        const line = self.offsetToLine(offset)
        return offset - self.document.buffer.lineStartOffset(line)
    }

    /// Set CELL_SELECTED flag on cells that fall within selection ranges.
    /// Uses display coordinates for soft-wrapped rendering.
    fn renderSelection(row_offset: i64) void {
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        if (content_cols <= 0) { return }
        var i: i64 = 0
        while (i < self.document.selection.ranges.count) {
            const r = self.document.selection.ranges.get(i)
            if (r.isEmpty()) { i += 1; continue }
            const sel_from = r.from()
            const sel_to = r.to()
            const from_line = self.offsetToLine(sel_from)
            const from_col = sel_from - self.document.buffer.lineStartOffset(from_line)
            const to_line = self.offsetToLine(sel_to)
            const to_col = sel_to - self.document.buffer.lineStartOffset(to_line)
            // Iterate display rows spanned by selection
            const from_dr = self.wrapBufToDisplayRow(from_line, from_col, content_cols)
            const to_dr = self.wrapBufToDisplayRow(to_line, to_col, content_cols)
            var dr = from_dr
            while (dr <= to_dr) {
                const screen_row = dr - self.scroll_offset + row_offset
                if (screen_row < row_offset) { dr += 1; continue }
                if (screen_row >= self.viewport_rows) { break }
                // Find logical line and wrap segment for this display row
                const dr_line = self.wrapDisplayRowToLine(dr)
                const dr_base = self.wrapLineToDisplayRow(dr_line)
                const wrap_row = dr - dr_base
                const line_len = self.document.buffer.lineLength(dr_line)
                // Buffer columns covered by this wrap segment
                const wrap_start = wrap_row * content_cols
                var wrap_end = wrap_start + content_cols
                if (wrap_end > line_len) { wrap_end = line_len }
                // Selection range on this logical line
                var sel_start: i64 = 0
                if (dr_line == from_line) { sel_start = from_col }
                var sel_end = line_len
                if (dr_line == to_line) { sel_end = to_col }
                // Intersect with wrap segment
                if (sel_start < wrap_start) { sel_start = wrap_start }
                if (sel_end > wrap_end) { sel_end = wrap_end }
                // Mark cells
                var col = sel_start
                while (col < sel_end) {
                    const screen_col = gutter_w + col - wrap_start
                    if (screen_col >= 0 and screen_col < self.viewport_cols) {
                        const c = self.render_grid.getCell(screen_row, screen_col)
                        c.flags = c.flags | CELL_SELECTED
                    }
                    col += 1
                }
                dr += 1
            }
            i += 1
        }
    }

    /// Mark all cursor positions (selection range heads) with CELL_CURSOR flag.
    /// Uses display coordinates for soft-wrapped rendering.
    fn renderCursors(gutter_w: i64, row_offset: i64) void {
        if (!self.cursor_visible) { return }
        const content_cols = self.viewport_cols - gutter_w
        var i: i64 = 0
        while (i < self.document.selection.ranges.count) {
            const r = self.document.selection.ranges.get(i)
            const head = r.head
            const cursor_line = self.offsetToLine(head)
            const cursor_col = head - self.document.buffer.lineStartOffset(cursor_line)
            const display_row = self.wrapBufToDisplayRow(cursor_line, cursor_col, content_cols)
            const display_col = self.wrapBufToDisplayCol(cursor_col, content_cols)
            const screen_row = display_row - self.scroll_offset + row_offset
            if (screen_row >= 0 and screen_row < self.viewport_rows) {
                const screen_col = gutter_w + display_col
                if (screen_col >= 0 and screen_col < self.viewport_cols) {
                    const c = self.render_grid.getCell(screen_row, screen_col)
                    c.flags = c.flags | CELL_CURSOR
                }
            }
            i += 1
        }
    }

    /// Highlight matching bracket at cursor position.
    /// Scans forward for opening brackets, backward for closing brackets.
    fn renderBracketMatch(gutter_w: i64, row_offset: i64) void {
        const buf_len = self.document.buffer.len()
        if (buf_len == 0) { return }
        // Check char at cursor and char before cursor for brackets
        var bracket_pos = -1
        var bracket_ch = 0
        if (self.cursor.offset < buf_len) {
            const ch = self.document.buffer.charAt(self.cursor.offset)
            if (closingBracketFor(ch) > 0 or openingBracketFor(ch) > 0) {
                bracket_pos = self.cursor.offset
                bracket_ch = ch
            }
        }
        if (bracket_pos < 0 and self.cursor.offset > 0) {
            const ch = self.document.buffer.charAt(self.cursor.offset - 1)
            if (closingBracketFor(ch) > 0 or openingBracketFor(ch) > 0) {
                bracket_pos = self.cursor.offset - 1
                bracket_ch = ch
            }
        }
        if (bracket_pos < 0) { return }
        // Find matching bracket
        var match_pos = -1
        const close = closingBracketFor(bracket_ch)
        if (close > 0) {
            // Opening bracket — scan forward
            var depth = 1
            var pos = bracket_pos + 1
            while (pos < buf_len and depth > 0) {
                const ch = self.document.buffer.charAt(pos)
                if (ch == bracket_ch) { depth += 1 }
                if (ch == close) { depth -= 1 }
                if (depth == 0) { match_pos = pos }
                pos += 1
            }
        } else {
            // Closing bracket — scan backward
            const open = openingBracketFor(bracket_ch)
            if (open > 0) {
                var depth = 1
                var pos = bracket_pos - 1
                while (pos >= 0 and depth > 0) {
                    const ch = self.document.buffer.charAt(pos)
                    if (ch == bracket_ch) { depth += 1 }
                    if (ch == open) { depth -= 1 }
                    if (depth == 0) { match_pos = pos }
                    pos -= 1
                }
            }
        }
        if (match_pos < 0) { return }
        // Mark both brackets in render grid
        self.markBracketCell(bracket_pos, gutter_w, row_offset)
        self.markBracketCell(match_pos, gutter_w, row_offset)
    }

    /// Mark a single buffer offset as bracket match in the render grid.
    fn markBracketCell(buf_offset: int, gutter_w: i64, row_offset: i64) void {
        const content_cols = self.viewport_cols - gutter_w
        const line = self.offsetToLine(buf_offset)
        const col = buf_offset - self.document.buffer.lineStartOffset(line)
        const display_row = self.wrapBufToDisplayRow(line, col, content_cols)
        const display_col = self.wrapBufToDisplayCol(col, content_cols)
        const screen_row = display_row - self.scroll_offset + row_offset
        const screen_col = gutter_w + display_col
        if (screen_row >= 0 and screen_row < self.viewport_rows) {
            if (screen_col >= 0 and screen_col < self.viewport_cols) {
                const c = self.render_grid.getCell(screen_row, screen_col)
                c.flags = c.flags | CELL_BRACKET_MATCH
            }
        }
    }

    /// Handle mouse click — position cursor at screen coordinates.
    /// Converts display (row, col) to buffer (line, col) via wrap map.
    fn editorClick(screen_row: i64, screen_col: i64) void {
        self.document.history.breakGroup()
        self.last_edit_kind = 0
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        if (screen_col < gutter_w) { return }
        const content_cols = self.viewport_cols - gutter_w
        const display_col = screen_col - gutter_w
        const display_row = screen_row + self.scroll_offset
        if (display_row < 0) { return }
        // Map display position to buffer position via wrap map
        var target_line = self.wrapDisplayRowToLine(display_row)
        if (target_line >= total_lines) { target_line = total_lines - 1 }
        if (target_line < 0) { target_line = 0 }
        var target_col = self.wrapDisplayToBufferCol(display_row, display_col, content_cols)
        const line_len = self.document.buffer.lineLength(target_line)
        if (target_col > line_len) { target_col = line_len }
        if (target_col < 0) { target_col = 0 }
        self.cursor.line = target_line
        self.cursor.col = target_col
        self.recomputeOffset()
        if (g_buffer_debug) {
            if (self.cursor.offset < 0 or self.cursor.offset > self.document.buffer.len()) {
                self.document.buffer.dumpState("editorClick: offset out of bounds")
                @trap()
            }
        }
        self.document.selection = Selection.point(self.cursor.offset)
        self.renderEditorGrid()
    }

    /// Handle double-click — select the word under the cursor.
    /// Uses charCategory from movement.cot for consistent word boundaries.
    fn editorSelectWord(screen_row: i64, screen_col: i64) void {
        self.document.history.breakGroup()
        self.last_edit_kind = 0
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        if (screen_col < gutter_w) { return }
        const content_cols = self.viewport_cols - gutter_w
        const display_col = screen_col - gutter_w
        const display_row = screen_row + self.scroll_offset
        if (display_row < 0) { return }
        var target_line = self.wrapDisplayRowToLine(display_row)
        if (target_line >= total_lines) { target_line = total_lines - 1 }
        if (target_line < 0) { target_line = 0 }
        const line_len = self.document.buffer.lineLength(target_line)
        var target_col = self.wrapDisplayToBufferCol(display_row, display_col, content_cols)
        if (target_col >= line_len) { target_col = line_len - 1 }
        if (target_col < 0) { target_col = 0 }
        if (line_len == 0) {
            // Empty line — just position cursor
            self.cursor.line = target_line
            self.cursor.col = 0
            self.recomputeOffset()
            self.document.selection = Selection.point(self.cursor.offset)
            self.renderEditorGrid()
            return
        }

        const line_start = self.document.buffer.lineStartOffset(target_line)
        const click_offset = line_start + target_col
        const click_ch = self.document.buffer.charAt(click_offset)
        const click_cat = charCategory(click_ch)

        // Expand left within line
        var left_col = target_col
        while (left_col > 0) {
            const prev_ch = self.document.buffer.charAt(line_start + left_col - 1)
            if (charCategory(prev_ch) != click_cat) { break }
            left_col -= 1
        }

        // Expand right within line
        var right_col = target_col + 1
        while (right_col < line_len) {
            const next_ch = self.document.buffer.charAt(line_start + right_col)
            if (charCategory(next_ch) != click_cat) { break }
            right_col += 1
        }

        const anchor = line_start + left_col
        const head = line_start + right_col
        self.cursor.line = target_line
        self.cursor.col = right_col
        self.cursor.offset = head
        self.document.selection = Selection.init(anchor, head)
        self.renderEditorGrid()
    }

    /// Handle triple-click — select the entire logical line.
    fn editorSelectLine(screen_row: i64) void {
        self.document.history.breakGroup()
        self.last_edit_kind = 0
        const total_lines = self.document.buffer.lineCount()
        const display_row = screen_row + self.scroll_offset
        if (display_row < 0) { return }
        var target_line = self.wrapDisplayRowToLine(display_row)
        if (target_line >= total_lines) { target_line = total_lines - 1 }
        if (target_line < 0) { target_line = 0 }

        const line_start = self.document.buffer.lineStartOffset(target_line)
        const line_len = self.document.buffer.lineLength(target_line)
        // Select through end of line including newline if present
        var line_end = line_start + line_len
        if (target_line < total_lines - 1) {
            line_end += 1  // include newline
        }

        self.cursor.line = target_line
        self.cursor.col = line_len
        self.cursor.offset = line_end
        self.document.selection = Selection.init(line_start, line_end)
        self.renderEditorGrid()
    }

    /// Handle mouse drag — extend selection via display coordinates.
    fn editorDrag(screen_row: i64, screen_col: i64) void {
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        const display_col = screen_col - gutter_w
        const display_row = screen_row + self.scroll_offset
        var target_line = self.wrapDisplayRowToLine(display_row)
        if (target_line >= total_lines) { target_line = total_lines - 1 }
        if (target_line < 0) { target_line = 0 }
        var target_col = self.wrapDisplayToBufferCol(display_row, display_col, content_cols)
        const line_len = self.document.buffer.lineLength(target_line)
        if (target_col > line_len) { target_col = line_len }
        if (target_col < 0) { target_col = 0 }
        const head_offset = self.document.buffer.lineStartOffset(target_line) + target_col
        self.cursor.line = target_line
        self.cursor.col = target_col
        self.cursor.offset = head_offset
        const primary = self.document.selection.primary()
        self.document.selection.replace(self.document.selection.primary_index,
            Range { anchor: primary.anchor, head: head_offset })
        self.renderEditorGrid()
    }

    /// Cursor screen row in display coordinates (accounts for soft wrapping).
    fn editorCursorScreenRow() i64 {
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        return self.wrapBufToDisplayRow(self.cursor.line, self.cursor.col, content_cols) - self.scroll_offset
    }

    /// Cursor screen col in display coordinates (accounts for soft wrapping).
    fn editorCursorScreenCol() i64 {
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        return gutter_w + self.wrapBufToDisplayCol(self.cursor.col, content_cols)
    }

    /// Set scroll offset (display rows) from scrollbar, clamped to valid range.
    fn setScrollOffset(offset: i64) void {
        const total_lines = self.document.buffer.lineCount()
        const gutter_w = self.gutterWidth(total_lines)
        const content_cols = self.viewport_cols - gutter_w
        self.rebuildWrapMap(content_cols)
        const max_offset = self.wrap_total_rows - self.viewport_rows
        if (offset < 0) { self.scroll_offset = 0 }
        else if (max_offset > 0 and offset > max_offset) { self.scroll_offset = max_offset }
        else { self.scroll_offset = offset }
        // Sync scroll anchor from display row
        const anchor_line = self.wrapDisplayRowToLine(self.scroll_offset)
        self.scroll_anchor = self.document.buffer.lineStartOffset(anchor_line)
        self.renderEditorGrid()
    }

    /// Handle scroll wheel input — same accumulator pattern as terminal.scrollEvent().
    /// delta: raw scroll delta in millipoints (points * 1000).
    /// precise: 1 for trackpad, 0 for discrete mouse wheel.
    /// cell_height: cell height in millipoints.
    /// multiplier: discrete scroll multiplier from config (default 3).
    fn scrollEvent(delta: i64, precise: i64, cell_height: i64, multiplier: i64) void {
        if (cell_height <= 0) { return }

        // Normalize delta to millipoints (Ghostty pattern from terminal.scrollEvent)
        var adjusted = delta
        if (precise == 0) {
            adjusted = delta * cell_height * multiplier / 1000
        }

        // Accumulate fractional scroll
        self.scroll_accumulator = self.scroll_accumulator + adjusted

        // Not enough for a full cell yet
        if (self.scroll_accumulator < 0) {
            if (self.scroll_accumulator > 0 - cell_height) { return }
        } else {
            if (self.scroll_accumulator < cell_height) { return }
        }

        // Calculate row delta
        const rows = self.scroll_accumulator / cell_height
        self.scroll_accumulator = self.scroll_accumulator - rows * cell_height

        // Apply as offset change
        self.setScrollOffset(self.scroll_offset + rows)
    }

    /// Set horizontal scroll offset — disabled with soft wrapping.
    fn setHScrollOffset(offset: i64) void {
        self.h_scroll_offset = 0
    }

    /// Handle horizontal scroll wheel — disabled with soft wrapping.
    fn hScrollEvent(delta: i64, precise: i64, cell_width: i64, multiplier: i64) void {
    }

    /// Recompute line/col from byte offset by scanning from start.
    fn recomputeLineCol() void {
        var line = 0
        var col = 0
        for i in 0..self.cursor.offset {
            if (self.document.buffer.charAt(i) == '\n') {
                line += 1
                col = 0
            } else {
                col += 1
            }
        }
        self.cursor.line = line
        self.cursor.col = col
    }

    /// Recompute byte offset from line/col.
    fn recomputeOffset() void {
        self.cursor.offset = self.document.buffer.lineStartOffset(self.cursor.line) + self.cursor.col
    }

    /// Render the surface content to a string (for testing/debugging).
    fn render() string {
        return self.document.buffer.toString()
    }

    /// Returns true if this surface is a terminal emulator.
    fn isTerminal() bool {
        return self.kind == SurfaceKind.Terminal
    }

    /// Set the render dirty flag (atomic). Called by IO thread after VT parse batch.
    fn markRenderDirty() void {
        @atomicStore(&self.render_dirty, 1)
    }

    /// Check and clear the render dirty flag (atomic). Called by Swift VSync callback.
    /// Returns 1 if dirty (needs render), 0 if clean.
    fn checkAndClearDirty() i64 {
        return @atomicExchange(&self.render_dirty, 0)
    }

    /// Mark child process as exited (atomic). Called by IO thread on EOF.
    fn markChildExited() void {
        @atomicStore(&self.child_exited, 1)
    }

    /// Return the title for this surface.
    fn title() string {
        if (self.kind == SurfaceKind.Terminal) {
            return "terminal"
        }
        if (self.document.filepath) |path| {
            return path
        }
        return "untitled"
    }
}

// ============================================================================
// Tests
// ============================================================================

test "surface init empty" {
    var s = Surface.init()
    @assertEq(s.kind, SurfaceKind.Editor)
    @assertEq(s.document.buffer.len(), 0)
    @assertEq(s.cursor.line, 0)
    @assertEq(s.cursor.col, 0)
    @assertEq(s.document.dirty, false)
    @assertEq(s.title(), "untitled")
    @assert(!s.isTerminal())
    @assertEq(s.mode, Mode.Insert)
}

test "surface handle insert" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'i')
    @assertEq(s.document.buffer.len(), 2)
    @assertEq(s.render(), "hi")
    @assertEq(s.document.dirty, true)
}

test "surface handle delete back" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.delete_back, 0)
    @assertEq(s.render(), "a")
}

test "surface handle move" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    @assertEq(s.cursor.offset, 2)
    s.handleInput(InputAction.move_left, 0)
    @assertEq(s.cursor.offset, 1)
    s.handleInput(InputAction.move_right, 0)
    @assertEq(s.cursor.offset, 2)
}

test "surface title with filepath" {
    var s = Surface.init()
    s.document.filepath = "test.cot"
    @assertEq(s.title(), "test.cot")
}

test "surface insert newline updates line col" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.insert_char, '\n')
    s.handleInput(InputAction.insert_char, 'c')
    @assertEq(s.cursor.line, 1)
    @assertEq(s.cursor.col, 1)
    @assertEq(s.cursor.offset, 4)
}

test "surface delete back newline recomputes" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.insert_char, '\n')
    s.handleInput(InputAction.insert_char, 'c')
    // cursor at line 1, col 1, offset 4
    // delete 'c' — stays on line 1
    s.handleInput(InputAction.delete_back, 0)
    @assertEq(s.cursor.line, 1)
    @assertEq(s.cursor.col, 0)
    @assertEq(s.cursor.offset, 3)
    // delete '\n' — recompute: back to line 0
    s.handleInput(InputAction.delete_back, 0)
    @assertEq(s.cursor.line, 0)
    @assertEq(s.cursor.col, 2)
    @assertEq(s.cursor.offset, 2)
}

test "surface move left across newline" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, '\n')
    s.handleInput(InputAction.insert_char, 'b')
    // cursor at line 1, col 1, offset 3
    s.handleInput(InputAction.move_left, 0)
    // now at line 1, col 0, offset 2
    @assertEq(s.cursor.line, 1)
    @assertEq(s.cursor.col, 0)
    @assertEq(s.cursor.offset, 2)
    // move left again — cross newline to line 0
    s.handleInput(InputAction.move_left, 0)
    @assertEq(s.cursor.line, 0)
    @assertEq(s.cursor.col, 1)
    @assertEq(s.cursor.offset, 1)
}

test "surface move right across newline" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, '\n')
    s.handleInput(InputAction.insert_char, 'b')
    // Go back to start
    s.cursor.offset = 0
    s.cursor.line = 0
    s.cursor.col = 0
    s.document.selection = Selection.point(0)
    // move right: 'a' -> col 1
    s.handleInput(InputAction.move_right, 0)
    @assertEq(s.cursor.col, 1)
    @assertEq(s.cursor.offset, 1)
    // move right: '\n' -> line 1, col 0
    s.handleInput(InputAction.move_right, 0)
    @assertEq(s.cursor.line, 1)
    @assertEq(s.cursor.col, 0)
    @assertEq(s.cursor.offset, 2)
}

test "surface move up down clamps col" {
    var s = Surface.init()
    // "hello\nhi\nworld"
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, '\n')
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'i')
    s.handleInput(InputAction.insert_char, '\n')
    s.handleInput(InputAction.insert_char, 'w')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, 'r')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'd')
    // cursor at line 2, col 5, offset 14
    @assertEq(s.cursor.line, 2)
    @assertEq(s.cursor.col, 5)
    // move up — line 1 "hi" has len 2, clamp col to 2
    s.handleInput(InputAction.move_up, 0)
    @assertEq(s.cursor.line, 1)
    @assertEq(s.cursor.col, 2)
    @assertEq(s.cursor.offset, 8)
    // move up — line 0 "hello" has len 5, goal_col restores to 5
    s.handleInput(InputAction.move_up, 0)
    @assertEq(s.cursor.line, 0)
    @assertEq(s.cursor.col, 5)
    @assertEq(s.cursor.offset, 5)
}

test "surface move line end" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, '\n')
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'i')
    // cursor at line 1, col 2
    // move to line start
    s.handleInput(InputAction.move_line_start, 0)
    @assertEq(s.cursor.col, 0)
    @assertEq(s.cursor.offset, 6)
    // move to line end
    s.handleInput(InputAction.move_line_end, 0)
    @assertEq(s.cursor.col, 2)
    @assertEq(s.cursor.offset, 8)
}

test "surface move down from last line no-op" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    @assertEq(s.cursor.line, 0)
    s.handleInput(InputAction.move_down, 0)
    @assertEq(s.cursor.line, 0)
}

test "terminal surface kind" {
    var s = Surface.initTerminal(24, 80)
    @assertEq(s.kind, SurfaceKind.Terminal)
    @assert(s.isTerminal())
    @assertEq(s.title(), "terminal")
    @assertEq(s.terminal.grid.rows, 24)
    @assertEq(s.terminal.grid.cols, 80)
    s.shell.close()
    fd_close(s.notify_pipe_read)
    fd_close(s.notify_pipe_write)
    s.terminal_mutex.destroy()
}

test "editor surface has inactive terminal" {
    var s = Surface.init()
    @assertEq(s.kind, SurfaceKind.Editor)
    @assertEq(s.terminal.grid.rows, 0)
    @assertEq(s.terminal.grid.cols, 0)
    @assertEq(s.shell.master_fd, -1)
}

test "surface undo insert" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    // Break undo group with a move
    s.handleInput(InputAction.move_left, 0)
    s.handleInput(InputAction.move_right, 0)
    s.handleInput(InputAction.insert_char, 'b')
    @assertEq(s.render(), "ab")
    // Undo second insert
    s.handleInput(InputAction.undo, 0)
    @assertEq(s.render(), "a")
    @assertEq(s.cursor.offset, 1)
    // Undo first insert
    s.handleInput(InputAction.undo, 0)
    @assertEq(s.render(), "")
    @assertEq(s.cursor.offset, 0)
}

test "surface redo after undo" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'x')
    s.handleInput(InputAction.move_left, 0)
    s.handleInput(InputAction.move_right, 0)
    s.handleInput(InputAction.insert_char, 'y')
    @assertEq(s.render(), "xy")
    s.handleInput(InputAction.undo, 0)
    @assertEq(s.render(), "x")
    s.handleInput(InputAction.redo, 0)
    @assertEq(s.render(), "xy")
    @assertEq(s.cursor.offset, 2)
}

test "surface undo delete back" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.insert_char, 'c')
    s.handleInput(InputAction.delete_back, 0)
    @assertEq(s.render(), "ab")
    // Undo the delete — should restore 'c'
    s.handleInput(InputAction.undo, 0)
    @assertEq(s.render(), "abc")
    @assertEq(s.cursor.offset, 3)
}

test "surface undo at root is no-op" {
    var s = Surface.init()
    s.handleInput(InputAction.undo, 0)
    @assertEq(s.render(), "")
    @assertEq(s.cursor.offset, 0)
}

test "surface redo at leaf is no-op" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.redo, 0)
    @assertEq(s.render(), "a")
    @assertEq(s.cursor.offset, 1)
}

test "surface undo redo preserves cursor" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    // Break group with movement, then insert last char
    s.handleInput(InputAction.move_left, 0)
    s.handleInput(InputAction.move_right, 0)
    s.handleInput(InputAction.insert_char, 'o')
    @assertEq(s.cursor.offset, 5)
    @assertEq(s.cursor.col, 5)
    // Undo just the 'o'
    s.handleInput(InputAction.undo, 0)
    @assertEq(s.cursor.offset, 4)
    @assertEq(s.cursor.col, 4)
    s.handleInput(InputAction.redo, 0)
    @assertEq(s.cursor.offset, 5)
    @assertEq(s.cursor.col, 5)
}

test "surface undo delete forward" {
    var s = Surface.init()
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    // Move cursor to start
    s.handleInput(InputAction.move_left, 0)
    s.handleInput(InputAction.move_left, 0)
    // Delete forward ('a')
    s.handleInput(InputAction.delete_forward, 0)
    @assertEq(s.render(), "b")
    @assertEq(s.cursor.offset, 0)
    // Undo — should restore 'a'
    s.handleInput(InputAction.undo, 0)
    @assertEq(s.render(), "ab")
    @assertEq(s.cursor.offset, 0)
}

// Vim mode tests removed — standard editor only (vim motions are a future extension)

test "surface word forward" {
    var s = Surface.init()
    // "hello world"
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, ' ')
    s.handleInput(InputAction.insert_char, 'w')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, 'r')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'd')
    // cursor at 11, move to start
    s.cursor.offset = 0
    s.cursor.line = 0
    s.cursor.col = 0
    s.document.selection = Selection.point(0)
    // w → skip "hello", skip space, land on "world"
    s.handleInput(InputAction.move_word_forward, 0)
    @assertEq(s.cursor.offset, 6)
    @assertEq(s.cursor.col, 6)
}

test "surface word backward" {
    var s = Surface.init()
    // "hello world"
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, ' ')
    s.handleInput(InputAction.insert_char, 'w')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, 'r')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'd')
    // cursor at end (11)
    // b → skip "world" back, skip space, land on start of "hello"?
    // Actually from offset 11 (past end), b goes to: pos-1=10 'd', cat=1 word,
    // skip word backward: 'd','l','r','o','w' → pos=6. Then prev_cat at pos-1=5=' ' cat=0 ≠ 1, stop.
    s.handleInput(InputAction.move_word_backward, 0)
    @assertEq(s.cursor.offset, 6)
    // b again → skip from 6: pos-1=5=' ' cat=0, skip whitespace: pos=5→cat=0, pos>0
    // then pos=4 'o' cat=1, skip while prev (pos-1) same cat
    s.handleInput(InputAction.move_word_backward, 0)
    @assertEq(s.cursor.offset, 0)
}

test "surface word end" {
    var s = Surface.init()
    // "hello world"
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, ' ')
    s.handleInput(InputAction.insert_char, 'w')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, 'r')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'd')
    // cursor at start
    s.cursor.offset = 0
    s.cursor.line = 0
    s.cursor.col = 0
    s.document.selection = Selection.point(0)
    // move_word_end mapped to move_word_forward: skips "hello" + space → "world" at offset 6
    s.handleInput(InputAction.move_word_end, 0)
    @assertEq(s.cursor.offset, 6)
}

test "char category" {
    @assertEq(charCategory(' '), 0)
    @assertEq(charCategory('\t'), 0)
    @assertEq(charCategory('\n'), 0)
    @assertEq(charCategory('a'), 1)
    @assertEq(charCategory('Z'), 1)
    @assertEq(charCategory('0'), 1)
    @assertEq(charCategory('_'), 1)
    @assertEq(charCategory('.'), 2)
    @assertEq(charCategory('('), 2)
    @assertEq(charCategory('+'), 2)
}

test "multi-cursor add and collapse" {
    var s = Surface.init()
    // "hello world"
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, ' ')
    s.handleInput(InputAction.insert_char, 'w')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, 'r')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'd')
    // Add a second cursor at offset 0
    s.addCursorAt(0)
    @assertEq(s.document.selection.ranges.count, 2)
    // Collapse to single cursor
    s.collapseToPrimaryCursor()
    @assertEq(s.document.selection.ranges.count, 1)
}

test "multi-cursor move right" {
    var s = Surface.init()
    // "abc"
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.insert_char, 'c')
    // Place cursors at 0 and 2
    s.document.selection = Selection.point(0)
    s.addCursorAt(2)
    @assertEq(s.document.selection.ranges.count, 2)
    // Move right
    s.moveAllCursors(InputAction.move_right)
    // Cursor 0→1, cursor 2→3
    const r0 = s.document.selection.ranges.get(0)
    const r1 = s.document.selection.ranges.get(1)
    @assertEq(r0.head, 1)
    @assertEq(r1.head, 3)
}

test "multi-cursor insert" {
    var s = Surface.init()
    // "abc"
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.insert_char, 'c')
    // Place cursors at 1 and 3 (after 'a' and after 'c')
    s.document.selection = Selection.point(1)
    s.addCursorAt(3)
    s.syncCursorFromPrimary()
    // Insert 'X' at both
    s.insertAtAllCursors('X')
    // Result: "aXbcX" — inserted at positions 1 and 3, became 1 and 4 (shifted)
    @assertEq(s.document.buffer.len(), 5)
    @assertEq(s.document.buffer.charAt(0), 'a')
    @assertEq(s.document.buffer.charAt(1), 'X')
    @assertEq(s.document.buffer.charAt(2), 'b')
    @assertEq(s.document.buffer.charAt(3), 'c')
    @assertEq(s.document.buffer.charAt(4), 'X')
}

test "multi-cursor delete back" {
    var s = Surface.init()
    // "abcd"
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.insert_char, 'c')
    s.handleInput(InputAction.insert_char, 'd')
    // Place cursors at 2 and 4 (after 'b' and after 'd')
    s.document.selection = Selection.point(2)
    s.addCursorAt(4)
    s.syncCursorFromPrimary()
    // Delete back at both
    s.deleteBackAtAllCursors()
    // Should delete 'b' (at offset 1) and 'd' (at offset 3→2 after shift)
    // Result: "ac"
    @assertEq(s.document.buffer.len(), 2)
    @assertEq(s.document.buffer.charAt(0), 'a')
    @assertEq(s.document.buffer.charAt(1), 'c')
}

test "add next occurrence" {
    var s = Surface.init()
    // "hello world hello"
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, ' ')
    s.handleInput(InputAction.insert_char, 'w')
    s.handleInput(InputAction.insert_char, 'o')
    s.handleInput(InputAction.insert_char, 'r')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'd')
    s.handleInput(InputAction.insert_char, ' ')
    s.handleInput(InputAction.insert_char, 'h')
    s.handleInput(InputAction.insert_char, 'e')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'l')
    s.handleInput(InputAction.insert_char, 'o')
    // Select first "hello" (0..5)
    s.document.selection = Selection.init(0, 5)
    s.syncCursorFromPrimary()
    // Add next occurrence
    s.addNextOccurrence()
    // Should now have 2 selections: first "hello" (0..5) and second "hello" (12..17)
    @assertEq(s.document.selection.ranges.count, 2)
    const r0 = s.document.selection.ranges.get(0)
    const r1 = s.document.selection.ranges.get(1)
    @assertEq(r0.from(), 0)
    @assertEq(r0.to(), 5)
    @assertEq(r1.from(), 12)
    @assertEq(r1.to(), 17)
}

test "escape collapses selection" {
    var s = Surface.init()
    // "abc"
    s.handleInput(InputAction.insert_char, 'a')
    s.handleInput(InputAction.insert_char, 'b')
    s.handleInput(InputAction.insert_char, 'c')
    // Select all
    s.document.selection = Selection.init(0, 3)
    s.syncCursorFromPrimary()
    // Escape collapses selection
    s.handleInput(InputAction.collapse_cursors, 0)
    const primary = s.document.selection.primary()
    @assertEq(primary.isEmpty(), true)
}
