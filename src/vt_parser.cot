// ============================================================================
// Tests — Phase 2: Single shifts
// ============================================================================

test "ESC N single shift G2" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    p.feedEsc(t, "N")
    @assertEq(t.single_shift, 2)
    // Next printable resets single_shift
    p.feedBytes(t, "A")
    @assertEq(t.single_shift, 0)
}

test "ESC O single shift G3" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    p.feedEsc(t, "O")
    @assertEq(t.single_shift, 3)
    // Next printable resets single_shift
    p.feedBytes(t, "A")
    @assertEq(t.single_shift, 0)
}

// ============================================================================
// Tests — Phase 2: DECRQM
// ============================================================================

test "DECRQM reports mode set" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // Query mode 7 (wraparound, default on) — should report 1 (set)
    const result = t.queryDecMode(7)
    @assertEq(result, 1)
    // Query mode 6 (origin, default off) — should report 2 (reset)
    const result2 = t.queryDecMode(6)
    @assertEq(result2, 2)
    // Query unknown mode — should report 0
    const result3 = t.queryDecMode(9999)
    @assertEq(result3, 0)
}

// ============================================================================
// Tests — Phase 3: DCS State Machine
// ============================================================================

test "DCS state transitions" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // Send DCS $ q m ST — DECRQSS for SGR
    // ESC P $ q m ESC \
    p.feed(t, 0x1B)   // ESC
    @assertEq(p.state, VtState.Escape)
    p.feed(t, 'P')    // DCS start
    @assertEq(p.state, VtState.DcsEntry)
    p.feed(t, '$')    // intermediate
    @assertEq(p.dcs_intermediates, '$')
    p.feed(t, 'q')    // final
    @assertEq(p.state, VtState.DcsString)
    @assertEq(p.dcs_final, 'q')
    p.feed(t, 'm')    // payload
    @assertEq(p.dcs_buf.count, 1)
    p.feed(t, 0x1B)   // ESC (starts ST)
    // After ESC in DcsString, dispatch happens
    @assertEq(p.state, VtState.Escape)
    p.feed(t, '\\')   // ST complete
    @assertEq(p.state, VtState.Ground)
}

test "DCS DECRQSS SGR" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // Set bold + italic
    t.bold = true
    t.italic = true
    // DCS $ q m ST — but pty_fd=-1 so no actual output
    // Just verify parsing doesn't crash
    p.feed(t, 0x1B)
    p.feed(t, 'P')
    p.feed(t, '$')
    p.feed(t, 'q')
    p.feed(t, 'm')
    p.feed(t, 0x1B)
    p.feed(t, '\\')
    @assertEq(p.state, VtState.Ground)
}

test "DCS XTGETTCAP TN" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // DCS + q 544E ST — request terminal name (TN in hex = 54 4E)
    p.feed(t, 0x1B)
    p.feed(t, 'P')
    p.feed(t, '+')
    p.feed(t, 'q')
    // Hex-encoded "TN" = 544E
    p.feed(t, '5')
    p.feed(t, '4')
    p.feed(t, '4')
    p.feed(t, 'E')
    p.feed(t, 0x1B)
    p.feed(t, '\\')
    @assertEq(p.state, VtState.Ground)
}

test "DCS BEL terminator" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // DCS $ q m BEL — BEL as string terminator
    p.feed(t, 0x1B)
    p.feed(t, 'P')
    p.feed(t, '$')
    p.feed(t, 'q')
    p.feed(t, 'm')
    p.feed(t, 0x07)  // BEL terminates
    @assertEq(p.state, VtState.Ground)
}

// ============================================================================
// Tests — Phase 3: Kitty Keyboard Protocol (parser)
// ============================================================================

test "kitty keyboard push pop" {
    var t = TerminalState.init(3, 10)
    @assertEq(t.kittyKeyboardFlags(), 0)
    // Push flags=1 (disambiguate)
    t.kittyKeyboardPush(1)
    @assertEq(t.kittyKeyboardFlags(), 1)
    // Push flags=3 (disambiguate + report_events)
    t.kittyKeyboardPush(3)
    @assertEq(t.kittyKeyboardFlags(), 3)
    @assertEq(t.kitty_kbd_idx, 2)
    // Pop 1
    t.kittyKeyboardPop(1)
    @assertEq(t.kittyKeyboardFlags(), 1)
    @assertEq(t.kitty_kbd_idx, 1)
    // Pop 1
    t.kittyKeyboardPop(1)
    @assertEq(t.kittyKeyboardFlags(), 0)
    @assertEq(t.kitty_kbd_idx, 0)
}

test "kitty keyboard query" {
    var t = TerminalState.init(3, 10)
    t.kittyKeyboardPush(5)  // disambiguate + report_alternates
    @assertEq(t.kittyKeyboardFlags(), 5)
    // sendKittyKeyboardReport would write CSI ? 5 u — but pty_fd=-1
}

test "kitty keyboard set or" {
    var t = TerminalState.init(3, 10)
    t.kittyKeyboardPush(1)  // disambiguate
    // OR mode (2): add report_events (bit 1 = 2)
    t.kittyKeyboardSetFlags(2, 2)
    @assertEq(t.kittyKeyboardFlags(), 3)  // 1 | 2 = 3
    // Replace mode (1): set to 8
    t.kittyKeyboardSetFlags(1, 8)
    @assertEq(t.kittyKeyboardFlags(), 8)
}

test "kitty keyboard stack overflow" {
    var t = TerminalState.init(3, 10)
    // Push 9 entries (stack holds 8) — oldest should be evicted
    var i: i64 = 0
    while (i < 9) {
        t.kittyKeyboardPush(i + 1)
        i += 1
    }
    @assertEq(t.kitty_kbd_idx, 8)
    // Top should be 9 (last pushed)
    @assertEq(t.kittyKeyboardFlags(), 9)
    // Bottom should be 2 (1 was evicted)
    @assertEq(t.kittyKbdGet(0), 2)
}

test "kitty keyboard reset in soft reset" {
    var t = TerminalState.init(3, 10)
    t.kittyKeyboardPush(5)
    @assertEq(t.kittyKeyboardFlags(), 5)
    t.softReset()
    @assertEq(t.kittyKeyboardFlags(), 0)
    @assertEq(t.kitty_kbd_idx, 0)
}

test "CSI u push via parser" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // CSI > 3 u — push flags=3
    p.feedEsc(t, "[>3u")
    @assertEq(t.kittyKeyboardFlags(), 3)
    // CSI > 1 u — push flags=1
    p.feedEsc(t, "[>1u")
    @assertEq(t.kittyKeyboardFlags(), 1)
    @assertEq(t.kitty_kbd_idx, 2)
    // CSI < 1 u — pop 1
    p.feedEsc(t, "[<1u")
    @assertEq(t.kittyKeyboardFlags(), 3)
    @assertEq(t.kitty_kbd_idx, 1)
}

// ============================================================================
// Tests — Batch 1: Missing Modes & ESC Sequences
// ============================================================================

test "ESC Z returns to ground (DECID → DA1 path)" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    p.feed(t, 0x1B)
    p.feed(t, 'Z')
    @assertEq(p.state, VtState.Ground)
    // sendPrimaryDeviceAttributes would write to pty_fd=-1, just verify state
}

test "DEL ignored in ground state" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // Put a character, then send DEL
    p.feed(t, 'A')
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.cursor_col, 1)
    p.feed(t, 0x7F)  // DEL
    // Cursor should not move, cell should not change
    @assertEq(t.cursor_col, 1)
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
}

test "OSC title via ST terminator" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 40)
    // OSC 0 ; long title ESC \ (ST terminator)
    p.feedEsc(t, "]0;user@host:~/cot-land/cotty")
    p.feed(t, 0x1B)  // ESC
    p.feed(t, '\\')  // \ — ST
    @assertEq(t.title_len, 26)
    @assertEq(p.state, VtState.Ground)
}

test "OSC 1 does not overwrite window title" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // Set window title via OSC 2
    p.feedEsc(t, "]2;long window title")
    p.feed(t, 0x07)
    @assertEq(t.title_len, 17)
    // OSC 1 (icon/tab title) should NOT overwrite it
    p.feedEsc(t, "]1;short")
    p.feed(t, 0x07)
    @assertEq(t.title_len, 17)
}

test "mode 66 controls app keypad" {
    var t = TerminalState.init(3, 10)
    @assert(!t.mode_app_keypad)
    t.setDecMode(66, true)
    @assert(t.mode_app_keypad)
    t.setDecMode(66, false)
    @assert(!t.mode_app_keypad)
}

test "mode 67 controls backspace sends BS" {
    var t = TerminalState.init(3, 10)
    @assert(!t.mode_backspace_sends_bs)
    t.setDecMode(67, true)
    @assert(t.mode_backspace_sends_bs)
    @assertEq(t.queryDecMode(67), 1)
    t.setDecMode(67, false)
    @assert(!t.mode_backspace_sends_bs)
    @assertEq(t.queryDecMode(67), 2)
}

test "DECCOLM stub clears screen and resets cursor" {
    var t = TerminalState.init(3, 10)
    t.putChar('X')
    t.cursor_row = 2
    t.cursor_col = 5
    t.setDecMode(3, true)
    @assertEq(t.cursor_row, 0)
    @assertEq(t.cursor_col, 0)
    // Screen should be cleared
    @assertEq(t.grid.getCell(0, 0).codepoint, 0)
}

test "DECBI at col 0 shifts right" {
    var t = TerminalState.init(3, 5)
    // Put 'A' at col 0
    t.putChar('A')
    t.cursor_col = 0
    t.backIndex()
    // 'A' should have shifted to col 1
    @assertEq(t.grid.getCell(0, 0).codepoint, 0)
    @assertEq(t.grid.getCell(0, 1).codepoint, 'A')
    @assertEq(t.cursor_col, 0)
}

test "DECBI at col > 0 moves left" {
    var t = TerminalState.init(3, 5)
    t.cursor_col = 3
    t.backIndex()
    @assertEq(t.cursor_col, 2)
}

test "DECFI at right margin shifts left" {
    var t = TerminalState.init(3, 5)
    // Put chars at cols 0-4
    t.putChar('A')
    t.putChar('B')
    t.putChar('C')
    t.putChar('D')
    t.putChar('E')
    // Cursor is at col 4 with pending_wrap
    t.cursor_col = 4
    t.pending_wrap = false
    t.forwardIndex()
    // 'A' should be gone, 'B' at col 0, etc.
    @assertEq(t.grid.getCell(0, 0).codepoint, 'B')
    @assertEq(t.grid.getCell(0, 3).codepoint, 'E')
    @assertEq(t.grid.getCell(0, 4).codepoint, 0)
    @assertEq(t.cursor_col, 4)
}

test "DECFI at col < max moves right" {
    var t = TerminalState.init(3, 5)
    t.cursor_col = 2
    t.forwardIndex()
    @assertEq(t.cursor_col, 3)
}

test "UK charset maps # to pound sign" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // ESC ( A — select UK charset for G0
    p.feed(t, 0x1B)
    p.feed(t, '(')
    p.feed(t, 'A')
    // Now type '#' — should map to £ (0x00A3)
    p.feed(t, '#')
    @assertEq(t.grid.getCell(0, 0).codepoint, 0x00A3)
}

test "LS2 LS3 activate G2 G3" {
    var t = TerminalState.init(3, 10)
    // Designate G2 as DEC Special Graphics
    t.charset_g2 = 1
    t.charset_g3 = 1
    // LS2 — activate G2
    t.active_charset = 2
    // Type 'q' (0x71) — should map to ─ (0x2500)
    t.putChar('q')
    @assertEq(t.grid.getCell(0, 0).codepoint, 0x2500)
    // LS3 — activate G3
    t.active_charset = 3
    t.putChar('q')
    @assertEq(t.grid.getCell(0, 1).codepoint, 0x2500)
}

test "G2 G3 designation via parser" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // ESC * 0 — designate G2 as DEC Special Graphics
    p.feed(t, 0x1B)
    p.feed(t, '*')
    p.feed(t, '0')
    @assertEq(t.charset_g2, 1)
    // ESC + A — designate G3 as UK
    p.feed(t, 0x1B)
    p.feed(t, '+')
    p.feed(t, 'A')
    @assertEq(t.charset_g3, 2)
}

test "SGR 58;2;r;g;b sets underline color on cell" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // SGR 58;2;255;128;0 — set underline color to orange
    p.feedEsc(t, "[58;2;255;128;0m")
    @assertEq(t.ul_type, COLOR_RGB)
    @assertEq(t.ul_val, packRgb(255, 128, 0))
    // Write a char — cell should have underline color
    p.feed(t, 'A')
    @assertEq(t.grid.getCell(0, 0).ul_type, COLOR_RGB)
    @assertEq(t.grid.getCell(0, 0).ul_val, packRgb(255, 128, 0))
    @assert((t.grid.getCell(0, 0).flags & CELL_CUSTOM_UL_COLOR) != 0)
}

test "SGR 58;5;n sets underline color from palette" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // SGR 58;5;1 — set underline color to palette index 1 (red)
    p.feedEsc(t, "[58;5;1m")
    @assertEq(t.ul_type, COLOR_PALETTE)
    @assertEq(t.ul_val, 1)
}

test "SGR 59 resets underline color" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // Set then reset
    p.feedEsc(t, "[58;2;100;200;50m")
    @assertEq(t.ul_type, COLOR_RGB)
    p.feedEsc(t, "[59m")
    @assertEq(t.ul_type, COLOR_NONE)
    @assertEq(t.ul_val, 0)
    // Write a char — cell should NOT have custom underline color flag
    p.feed(t, 'B')
    @assert((t.grid.getCell(0, 0).flags & CELL_CUSTOM_UL_COLOR) == 0)
}

test "mode 2027 grapheme cluster stub" {
    var t = TerminalState.init(3, 10)
    t.setDecMode(2027, true)
    @assert(t.mode_grapheme_cluster)
    @assertEq(t.queryDecMode(2027), 1)
    t.setDecMode(2027, false)
    @assertEq(t.queryDecMode(2027), 2)
}

// ============================================================================
// Tests — Batch 3: OSC 133 Semantic Prompts
// ============================================================================

test "OSC 133;A marks row as SEMANTIC_PROMPT" {
    var p = VtParser.init()
    var t = TerminalState.init(5, 10)
    // OSC 133 ; A BEL
    p.feedEsc(t, "]133;A")
    p.feed(t, 0x07)
    @assertEq(t.grid.getRowSemantic(0), SEMANTIC_PROMPT)
}

test "OSC 133;B marks row as SEMANTIC_INPUT" {
    var p = VtParser.init()
    var t = TerminalState.init(5, 10)
    p.feedEsc(t, "]133;B")
    p.feed(t, 0x07)
    @assertEq(t.grid.getRowSemantic(0), SEMANTIC_INPUT)
}

test "OSC 133;C marks row as SEMANTIC_OUTPUT" {
    var p = VtParser.init()
    var t = TerminalState.init(5, 10)
    p.feedEsc(t, "]133;C")
    p.feed(t, 0x07)
    @assertEq(t.grid.getRowSemantic(0), SEMANTIC_OUTPUT)
}

test "jump to previous prompt finds correct row" {
    var t = TerminalState.init(5, 10)
    // Mark row 1 as prompt
    t.grid.setRowSemantic(1, SEMANTIC_PROMPT)
    // Place cursor at row 3
    t.cursor_row = 3
    const result = t.jumpToPreviousPrompt()
    @assertEq(result, 1)
    @assertEq(t.cursor_row, 1)
    @assertEq(t.cursor_col, 0)
}

test "jump to next prompt finds correct row" {
    var t = TerminalState.init(5, 10)
    // Mark row 3 as prompt
    t.grid.setRowSemantic(3, SEMANTIC_PROMPT)
    // Place cursor at row 1
    t.cursor_row = 1
    const result = t.jumpToNextPrompt()
    @assertEq(result, 3)
    @assertEq(t.cursor_row, 3)
    @assertEq(t.cursor_col, 0)
}

test "jump to previous prompt returns -1 when none" {
    var t = TerminalState.init(5, 10)
    t.cursor_row = 0
    const result = t.jumpToPreviousPrompt()
    @assertEq(result, -1)
}

test "jump to next prompt returns -1 when none" {
    var t = TerminalState.init(5, 10)
    t.cursor_row = 4
    const result = t.jumpToNextPrompt()
    @assertEq(result, -1)
}

test "PROMPT_SP via VT parser: exact zsh bytes" {
    var t = TerminalState.init(24, 80)
    var p = VtParser.init()
    // ESC[1m = bold
    p.feed(t, 0x1B); p.feed(t, '['); p.feed(t, '1'); p.feed(t, 'm')
    // ESC[7m = reverse
    p.feed(t, 0x1B); p.feed(t, '['); p.feed(t, '7'); p.feed(t, 'm')
    // %
    p.feed(t, '%')
    // ESC[27m = no reverse
    p.feed(t, 0x1B); p.feed(t, '['); p.feed(t, '2'); p.feed(t, '7'); p.feed(t, 'm')
    // ESC[1m = bold
    p.feed(t, 0x1B); p.feed(t, '['); p.feed(t, '1'); p.feed(t, 'm')
    // ESC[0m = reset
    p.feed(t, 0x1B); p.feed(t, '['); p.feed(t, '0'); p.feed(t, 'm')
    // 79 spaces
    for si in 0..79 { p.feed(t, ' ') }
    // CR, space (overwrites %), CR
    p.feed(t, 0x0D)
    p.feed(t, ' ')
    p.feed(t, 0x0D)
    // Cell at (0,0) should be space, NOT '%'
    const c = t.grid.getCell(0, 0)
    @assertEq(c.codepoint, ' ')
}
