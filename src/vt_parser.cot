// ============================================================================
// Tests — Phase 2: CSI backtick HPA, CSI a HPR, CSI e VPR
// ============================================================================

test "CSI backtick HPA" {
    var p = VtParser.init()
    var t = TerminalState.init(24, 80)
    // HPA: CSI 10 ` -> col 9 (1-indexed)
    p.feedEsc(t, "[10`")
    @assertEq(t.cursor_col, 9)
}

test "CSI a HPR" {
    var p = VtParser.init()
    var t = TerminalState.init(24, 80)
    t.setCursorPos(0, 5)
    // HPR: CSI 3 a -> move right 3
    p.feedEsc(t, "[3a")
    @assertEq(t.cursor_col, 8)
}

test "CSI e VPR" {
    var p = VtParser.init()
    var t = TerminalState.init(24, 80)
    t.setCursorPos(5, 0)
    // VPR: CSI 3 e -> move down 3
    p.feedEsc(t, "[3e")
    @assertEq(t.cursor_row, 8)
}

