// ============================================================================
// Tests — Integration
// ============================================================================

test "mixed text and formatting" {
    var p = VtParser.init()
    var t = TerminalState.init(24, 80)
    // Write "Hi" in bold red, then reset
    p.feedEsc(t, "[1;31m")
    p.feedBytes(t, "Hi")
    p.feedEsc(t, "[0m")
    p.feedBytes(t, "!")
    @assertEq(t.grid.getCell(0, 0).codepoint, 'H')
    @assertEq(t.grid.getCell(0, 0).fg_type, COLOR_PALETTE)
    @assertEq(t.grid.getCell(0, 0).fg_val, 9)  // Bold-as-bright: palette 1 → 9
    @assertEq(t.grid.getCell(0, 0).flags & CELL_BOLD, CELL_BOLD)
    @assertEq(t.grid.getCell(0, 2).codepoint, '!')
    @assertEq(t.grid.getCell(0, 2).fg_type, t.default_fg_type)
    @assertEq(t.grid.getCell(0, 2).flags, 0)
}

// ============================================================================
// Tests — Insert mode (IRM)
// ============================================================================

test "insert mode shifts cells" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 6)
    p.feedBytes(t, "ABCD")
    t.setCursorPos(0, 1)
    // Enable insert mode via ANSI mode 4
    p.feedEsc(t, "[4h")
    @assertEq(t.mode_insert, true)
    // Insert 'X' — should shift BCD right
    p.feedBytes(t, "X")
    @assertEq(t.grid.getCell(0, 0).codepoint, 'A')
    @assertEq(t.grid.getCell(0, 1).codepoint, 'X')
    @assertEq(t.grid.getCell(0, 2).codepoint, 'B')
    @assertEq(t.grid.getCell(0, 3).codepoint, 'C')
    @assertEq(t.grid.getCell(0, 4).codepoint, 'D')
    // Disable insert mode
    p.feedEsc(t, "[4l")
    @assertEq(t.mode_insert, false)
}

// ============================================================================
// Tests — Reverse wrap (mode 45)
// ============================================================================

test "reverse wrap moves to previous row" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 4)
    // Write "ABCD" which fills row 0 and causes soft-wrap flag
    p.feedBytes(t, "ABCD")
    // Wrap flag should be set on row 0 after writing at last col
    t.grid.setRowWrap(0, 1)
    // Move to start of row 1
    t.setCursorPos(1, 0)
    // Enable reverse wrap
    p.feedEsc(t, "[?45h")
    @assertEq(t.mode_reverse_wrap, true)
    // Backspace should wrap to end of row 0
    t.backspace()
    @assertEq(t.cursor_row, 0)
    @assertEq(t.cursor_col, 3)
}

test "reverse wrap no wrap without soft-wrap flag" {
    var t = TerminalState.init(3, 4)
    t.mode_reverse_wrap = true
    t.setCursorPos(1, 0)
    // Row 0 has no soft-wrap flag (default = 0)
    t.backspace()
    // Should stay at row 1, col 0
    @assertEq(t.cursor_row, 1)
    @assertEq(t.cursor_col, 0)
}

