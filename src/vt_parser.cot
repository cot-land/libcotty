// ============================================================================
// Tests — Word/line selection
// ============================================================================

test "select word boundary" {
    var t = TerminalState.init(3, 20)
    // Write "hello world" at row 0
    var p = VtParser.init()
    p.feedBytes(t, "hello world")
    // Select word at col 2 (inside "hello")
    t.selectWord(0, 2)
    @assertEq(t.sel_active, true)
    @assertEq(t.sel_start_col, 0)
    @assertEq(t.sel_end_col, 4)
    @assertEq(t.sel_start_row, 0)
}

test "select word with punctuation" {
    var t = TerminalState.init(3, 20)
    var p = VtParser.init()
    p.feedBytes(t, "foo(bar)baz")
    // Select word at col 4 (inside "bar", bounded by parens)
    t.selectWord(0, 4)
    @assertEq(t.sel_start_col, 4)
    @assertEq(t.sel_end_col, 6)
}

test "select line" {
    var t = TerminalState.init(5, 10)
    var p = VtParser.init()
    p.feedBytes(t, "hello")
    t.selectLine(0)
    @assertEq(t.sel_active, true)
    @assertEq(t.sel_start_row, 0)
    @assertEq(t.sel_start_col, 0)
    @assertEq(t.sel_end_row, 0)
    @assertEq(t.sel_end_col, 9)
}

// ============================================================================
// Tests — Base64 decode
// ============================================================================

test "base64 decode" {
    // "SGVsbG8=" decodes to "Hello"
    var buf: List(i64) = .{}
    buf.append('S')
    buf.append('G')
    buf.append('V')
    buf.append('s')
    buf.append('b')
    buf.append('G')
    buf.append('8')
    buf.append('=')
    const out = alloc(0, 8)
    const len = base64Decode(buf, 0, 8, out)
    @assertEq(len, 5)
    @assertEq(@intToPtr(*u8, out).*, 'H')
    @assertEq(@intToPtr(*u8, out + 1).*, 'e')
    @assertEq(@intToPtr(*u8, out + 2).*, 'l')
    @assertEq(@intToPtr(*u8, out + 3).*, 'l')
    @assertEq(@intToPtr(*u8, out + 4).*, 'o')
}

// ============================================================================
// Tests — Color spec parsing
// ============================================================================

test "parse color spec hex format" {
    var buf: List(i64) = .{}
    // "#FF8800"
    buf.append('#')
    buf.append('F')
    buf.append('F')
    buf.append('8')
    buf.append('8')
    buf.append('0')
    buf.append('0')
    const r, g, b = parseColorSpec(buf, 0, 7)
    @assertEq(r, 255)
    @assertEq(g, 136)
    @assertEq(b, 0)
}

test "parse color spec rgb format" {
    var buf: List(i64) = .{}
    // "rgb:ff/88/00"
    buf.append('r')
    buf.append('g')
    buf.append('b')
    buf.append(':')
    buf.append('f')
    buf.append('f')
    buf.append('/')
    buf.append('8')
    buf.append('8')
    buf.append('/')
    buf.append('0')
    buf.append('0')
    const r, g, b = parseColorSpec(buf, 0, 12)
    @assertEq(r, 255)
    @assertEq(g, 136)
    @assertEq(b, 0)
}

// ============================================================================
// Tests — CSI t (XTWINOPS)
// ============================================================================

test "CSI t save restore title" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 10)
    // Set title via OSC 0
    p.feedEsc(t, "]0;MyTitle\x07")
    @assertEq(t.title_len, 7)
    // Save title: CSI 22;0 t
    p.feedEsc(t, "[22;0t")
    @assertEq(t.title_stack_len, 7)
    // Change title
    p.feedEsc(t, "]0;New\x07")
    @assertEq(t.title_len, 3)
    // Restore title: CSI 23;0 t
    p.feedEsc(t, "[23;0t")
    @assertEq(t.title_len, 7)
}

// ============================================================================
// Tests — Soft reset clears new modes
// ============================================================================

test "soft reset clears new modes" {
    var p = VtParser.init()
    var t = TerminalState.init(3, 4)
    t.mode_insert = true
    t.mode_reverse_video = true
    t.mode_cursor_blinking = true
    t.mode_reverse_wrap = true
    t.mode_app_keypad = true
    t.single_shift = 2
    t.blink = true
    t.hidden = true
    t.overline = true
    t.double_underline = true
    t.softReset()
    @assertEq(t.mode_insert, false)
    @assertEq(t.mode_reverse_video, false)
    @assertEq(t.mode_cursor_blinking, false)
    @assertEq(t.mode_reverse_wrap, false)
    @assertEq(t.mode_app_keypad, false)
    @assertEq(t.single_shift, 0)
    @assertEq(t.blink, false)
    @assertEq(t.hidden, false)
    @assertEq(t.overline, false)
    @assertEq(t.double_underline, false)
}

