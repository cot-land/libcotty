}

/// Set the root URL from raw bytes.
export fn cotty_workspace_set_root_url(ws: i64, ptr: *u8, len: i64) void {
    getWorkspacePtr(ws).setRootUrl(ptr, len)
}

// ============================================================================
// Split Panes (tree storage is in FFI globals, not in Tab struct)
// ============================================================================

/// Split the current tab's focused pane. Returns the new surface handle.
/// direction: 1=horizontal (left/right), 2=vertical (top/bottom).
export fn cotty_workspace_split(ws: i64, direction: i64, rows: i64, cols: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return -1 }
    const tab_handle = @ptrToInt(wptr.tabs.get(wptr.selected_index).surface)
    const tree = findOrCreateSplitTree(tab_handle)
    // Create new terminal surface
    const new_surface = wptr.app.addTerminalSurface(rows, cols)
    const new_handle = @ptrToInt(new_surface)
    tree.split(direction, new_handle)
    // Wire inspector + start IO thread (same as addTerminalTab)
    const sptr = getSurfacePtr(new_handle)
    sptr.parser.inspector_ptr = @ptrToInt(&sptr.inspector)
    sptr.startIoThread()
    return new_handle
}

/// Close the focused split pane. Returns the closed surface handle.
/// Returns -1 if only one pane (caller should close the tab instead).
export fn cotty_workspace_close_split(ws: i64) i64 {
    const tree = currentSplitTreeForWs(getWorkspacePtr(ws))
    return tree.closeFocused()
}

/// Move focus between split panes.
/// direction: 1=right, 2=down, 3=left, 4=up.
export fn cotty_workspace_split_move_focus(ws: i64, direction: i64) void {
    currentSplitTreeForWs(getWorkspacePtr(ws)).moveFocus(direction)
}

/// Set the ratio for a split node in the current tab.
export fn cotty_workspace_split_set_ratio(ws: i64, node_idx: i64, ratio: i64) void {
    currentSplitTreeForWs(getWorkspacePtr(ws)).setRatio(node_idx, ratio)
}

/// Return 1 if the current tab has split panes, 0 otherwise.
export fn cotty_workspace_is_split(ws: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 0 }
    if (currentSplitTreeForWs(wptr).leafCount() > 1) { return 1 }
    return 0
}

/// Return the focused surface handle in the current tab.
export fn cotty_workspace_focused_surface(ws: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 0 }
    const tree = currentSplitTreeForWs(wptr)
    const focused = tree.focused
    if (focused < 0 or focused >= tree.nodes.count) { return 0 }
    return tree.getNode(focused).surface_handle
}

// ---- Split tree queries (for Swift layout) ----

/// Return the split tree node count for the current tab.
export fn cotty_workspace_split_node_count(ws: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 0 }
    return currentSplitTreeForWs(wptr).nodeCount()
}

/// Return 1 if the node at index is a leaf.
export fn cotty_workspace_split_node_is_leaf(ws: i64, idx: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 1 }
    if (currentSplitTreeForWs(wptr).getNode(idx).is_leaf) { return 1 }
    return 0
}

/// Return the surface handle of a leaf node.
export fn cotty_workspace_split_node_surface(ws: i64, idx: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 0 }
    return currentSplitTreeForWs(wptr).getNode(idx).surface_handle
}

/// Return the direction of a split node (1=horizontal, 2=vertical).
export fn cotty_workspace_split_node_direction(ws: i64, idx: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 0 }
    return currentSplitTreeForWs(wptr).getNode(idx).direction
}

/// Return the ratio of a split node (0–1000).
export fn cotty_workspace_split_node_ratio(ws: i64, idx: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 500 }
    return currentSplitTreeForWs(wptr).getNode(idx).ratio
}

/// Return the left child index of a split node.
export fn cotty_workspace_split_node_left(ws: i64, idx: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return -1 }
    return currentSplitTreeForWs(wptr).getNode(idx).left
}

/// Return the right child index of a split node.
export fn cotty_workspace_split_node_right(ws: i64, idx: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return -1 }
    return currentSplitTreeForWs(wptr).getNode(idx).right
}

/// Return the root node index of the split tree.
export fn cotty_workspace_split_root(ws: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 0 }
    return currentSplitTreeForWs(wptr).root
}

/// Return the focused node index of the split tree.
export fn cotty_workspace_split_focused(ws: i64) i64 {
    const wptr = getWorkspacePtr(ws)
    if (wptr.selected_index < 0 or wptr.selected_index >= wptr.tabs.count) { return 0 }
    return currentSplitTreeForWs(wptr).focused
}

// ============================================================================
// Command Palette
// ============================================================================

/// Toggle the command palette open/closed.
export fn cotty_palette_toggle() void {
    g_palette.toggle()
}

/// Return 1 if the palette is active, 0 otherwise.
export fn cotty_palette_active() i64 {
    if (g_palette.active) { return 1 }
    return 0
}

/// Dismiss the palette.
export fn cotty_palette_dismiss() void {
    g_palette.dismiss()
}

/// Set the query string from raw bytes and re-filter.
export fn cotty_palette_set_query(ptr: *u8, len: i64) void {
    g_palette.setQuery(ptr, len)
}

/// Return the number of filtered results.
export fn cotty_palette_result_count() i64 {
    return g_palette.resultCount()
}

/// Return a pointer to the title bytes of the result at index.
export fn cotty_palette_result_title(index: i64) i64 {
    const action = g_palette.resultAction(index)
    return action.title_ptr
}

/// Return the byte length of the title at index.
export fn cotty_palette_result_title_len(index: i64) i64 {
    const action = g_palette.resultAction(index)
    return action.title_len
}

/// Return the action tag of the result at index.
export fn cotty_palette_result_tag(index: i64) i64 {
    const action = g_palette.resultAction(index)
    return action.tag
}

/// Return the currently selected index.
export fn cotty_palette_selected() i64 {
    return g_palette.selected
}

/// Move selection up.
export fn cotty_palette_move_up() void {
    g_palette.moveUp()
}

/// Move selection down.
export fn cotty_palette_move_down() void {
    g_palette.moveDown()
}

// ============================================================================
// Theme Palette
// ============================================================================

/// Toggle the theme palette open/closed.
export fn cotty_theme_toggle() void {
    g_theme_palette.toggle()
}

/// Return 1 if the theme palette is active, 0 otherwise.
export fn cotty_theme_active() i64 {
    if (g_theme_palette.active) { return 1 }
    return 0
}

/// Dismiss the theme palette.
export fn cotty_theme_dismiss() void {
    g_theme_palette.dismiss()
}

/// Set the query string from raw bytes and re-filter.
export fn cotty_theme_set_query(ptr: *u8, len: i64) void {
    g_theme_palette.setQuery(ptr, len)
}

/// Return the number of filtered results.
export fn cotty_theme_result_count() i64 {
    return g_theme_palette.resultCount()
}

/// Return a pointer to the title bytes of the result at index.
export fn cotty_theme_result_title(index: i64) i64 {
    return g_theme_palette.resultTitle(index)
}

/// Return the byte length of the title at index.
export fn cotty_theme_result_title_len(index: i64) i64 {
    return g_theme_palette.resultTitleLen(index)
}

/// Return the currently selected index.
export fn cotty_theme_selected() i64 {
    return g_theme_palette.selected
}

/// Move selection up.
export fn cotty_theme_move_up() void {
    g_theme_palette.moveUp()
}

/// Move selection down.
export fn cotty_theme_move_down() void {
    g_theme_palette.moveDown()
}

/// Apply the theme at the given filtered index.
/// Copies colors into g_app.config, updates global theme defaults, saves to disk.
/// Updates all active terminal surfaces with new colors (Ghostty-style propagation).
export fn cotty_theme_apply(index: i64) void {
    const entry = g_theme_palette.getSelectedTheme(index)
    applyThemeToConfig(entry, g_app.config)
    saveToFile(g_app.config, configPath())

    // Propagate to all active terminal surfaces (under lock — IO thread reads palette)
    for i in 0..g_app.surfaces.count {
        const s = g_app.surfaces.get(i)
        if (s.kind == SurfaceKind.Terminal) {
            s.terminal_mutex.lock()
            s.terminal.updateThemeColors()
            s.terminal_mutex.unlock()
        }
    }
}

// ============================================================================
// File Tree
// ============================================================================

/// Cast an opaque file tree handle to a *FileTree pointer.
fn getFileTreePtr(handle: i64) *FileTree {
    return @intToPtr(*FileTree, handle)
}

/// Create a new file tree rooted at the given path. Returns opaque handle.
export fn cotty_filetree_new(root_ptr: *u8, root_len: i64) i64 {
    const root = @string(@ptrToInt(root_ptr), root_len)
    var tree = FileTree.init(root)
    const ptr = alloc(0, @sizeOf(FileTree))
    const dst = @intToPtr(*FileTree, ptr)
    dst.* = tree
    return ptr
}

/// Free a file tree.
export fn cotty_filetree_free(tree: i64) void {
    const tptr = getFileTreePtr(tree)
    tptr.entries.free()
    tptr.visible_rows.free()
    tptr.name_buf.free()
    tptr.path_buf.free()
    dealloc(tree)
}

/// Set a new root path and reload.
export fn cotty_filetree_set_root(tree: i64, ptr: *u8, len: i64) void {
    getFileTreePtr(tree).setRootPath(ptr, len)
}

/// Return the number of visible rows.
export fn cotty_filetree_row_count(tree: i64) i64 {
    return getFileTreePtr(tree).rowCount()
}

/// Toggle expand/collapse for a directory at the given visible row.
export fn cotty_filetree_toggle_expand(tree: i64, row: i64) void {
    getFileTreePtr(tree).toggleExpand(row)
}

/// Select a visible row.
export fn cotty_filetree_select_row(tree: i64, row: i64) void {
    getFileTreePtr(tree).selectRow(row)
}

/// Return the selected row index (-1 if none).
export fn cotty_filetree_selected_row(tree: i64) i64 {
    return getFileTreePtr(tree).selected_row
}

/// Copy the name of the entry at visible row into name_buf, return pointer.
export fn cotty_filetree_row_name(tree: i64, row: i64) i64 {
    const tptr = getFileTreePtr(tree)
    tptr.rowName(row)
    return tptr.name_buf.items
}

/// Return the byte length of the name at visible row.
export fn cotty_filetree_row_name_len(tree: i64, row: i64) i64 {
    return getFileTreePtr(tree).rowName(row)
}

/// Return the depth of the entry at visible row.
export fn cotty_filetree_row_depth(tree: i64, row: i64) i64 {
    return getFileTreePtr(tree).rowDepth(row)
}

/// Return 1 if the entry at visible row is a directory, 0 otherwise.
export fn cotty_filetree_row_is_dir(tree: i64, row: i64) i64 {
    return getFileTreePtr(tree).rowIsDir(row)
}

/// Return 1 if the entry at visible row is expanded, 0 otherwise.
export fn cotty_filetree_row_is_expanded(tree: i64, row: i64) i64 {
    return getFileTreePtr(tree).rowIsExpanded(row)
}

/// Copy the full path of the entry at visible row into path_buf, return pointer.
export fn cotty_filetree_row_path(tree: i64, row: i64) i64 {
    const tptr = getFileTreePtr(tree)
    tptr.rowPath(row)
    return tptr.path_buf.items
}

/// Return the byte length of the full path at visible row.
export fn cotty_filetree_row_path_len(tree: i64, row: i64) i64 {
    return getFileTreePtr(tree).rowPath(row)
}

