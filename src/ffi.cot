}

/// Set the font size. Clamped to 6–72.
export fn cotty_config_set_font_size(size: i64) void {
    var s = size
    if (s < 6) { s = 6 }
    if (s > 72) { s = 72 }
    g_app.config.font_size = s
}

/// Reload config from disk. Re-reads ~/.config/cotty/config.json and updates globals.
export fn cotty_config_reload() void {
    g_app.config = Config.loadFromFile(configPath())
    initThemeDefaults(&g_app.config)
}

// ============================================================================
// Mouse tracking
// ============================================================================

/// Return 1 if alt screen is active, 0 otherwise.
export fn cotty_terminal_alt_screen(surface: i64) i64 {
    if (getSurfacePtr(surface).terminal.mode_alt_screen) { return 1 }
    return 0
}

/// Return the current mouse tracking mode (0=off, 1000/1002/1003).
export fn cotty_terminal_mouse_mode(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.mode_mouse_tracking
}

/// Return the current mouse format (0=normal, 1006=SGR).
export fn cotty_terminal_mouse_format(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.mode_mouse_format
}

/// Send a mouse event to the terminal's PTY.
/// No-ops if mouse tracking is disabled.
/// button: 0=left, 1=middle, 2=right, 32=drag, 64=wheel up, 65=wheel down.
/// col, row: 1-indexed. pressed: 1=press/wheel, 0=release.
export fn cotty_terminal_mouse_event(surface: i64, button: i64, col: i64, row: i64, pressed: i64, mods: i64) void {
    const sptr = getSurfacePtr(surface)
    if (sptr.terminal.mode_mouse_tracking == 0) { return }
    mouseToTerminalBytes(sptr.shell.master_fd, button, col, row, pressed, sptr.terminal.mode_mouse_format, mods)
}

/// Handle a scroll wheel event. All logic lives in Cot (ported from Ghostty).
/// Swift just forwards raw deltas — no logic in the platform layer.
export fn cotty_terminal_scroll(surface: i64, delta: i64, precise: i64, cell_height: i64, col: i64, row: i64) void {
    const sptr = getSurfacePtr(surface)
    sptr.terminal.scrollEvent(sptr.shell.master_fd, delta, precise, cell_height, col, row)
}

// ============================================================================
// Terminal cursor shape
// ============================================================================

/// Return the cursor shape (0=default, 1=blinking block, 2=steady block,
/// 3=blinking underline, 4=steady underline, 5=blinking bar, 6=steady bar).
export fn cotty_terminal_cursor_shape(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.cursor_shape
}

// ============================================================================
// Terminal title
// ============================================================================

/// Return a pointer to the terminal title bytes.
export fn cotty_terminal_title(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.title_buf
}

/// Return the byte length of the terminal title.
export fn cotty_terminal_title_len(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.title_len
}

/// Return a pointer to the terminal PWD bytes (OSC 7 URI).
export fn cotty_terminal_pwd(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.pwd_buf
}

/// Return the byte length of the terminal PWD.
export fn cotty_terminal_pwd_len(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.pwd_len
}

// ============================================================================
// Terminal bell
// ============================================================================

/// Return 1 if a bell is pending and clear the flag, 0 otherwise.
export fn cotty_terminal_bell(surface: i64) i64 {
    const sptr = getSurfacePtr(surface)
    if (sptr.terminal.bell_pending) {
        sptr.terminal.bell_pending = false
        return 1
    }
    return 0
}

// ============================================================================
// Terminal bracketed paste and focus events
// ============================================================================

/// Return 1 if bracketed paste mode is enabled, 0 otherwise.
export fn cotty_terminal_bracketed_paste_mode(surface: i64) i64 {
    if (getSurfacePtr(surface).terminal.mode_bracketed_paste) { return 1 }
    return 0
}

/// Return 1 if focus event mode is enabled, 0 otherwise.
export fn cotty_terminal_focus_event_mode(surface: i64) i64 {
    if (getSurfacePtr(surface).terminal.mode_focus_events) { return 1 }
    return 0
}

/// Return 1 if reverse video mode (DECSCNM) is active, 0 otherwise.
/// Renderer uses this to swap fg/bg for all cells.
export fn cotty_terminal_reverse_video(surface: i64) i64 {
    if (getSurfacePtr(surface).terminal.mode_reverse_video) { return 1 }
    return 0
}

/// Return 1 if cursor blinking is enabled (mode 12), 0 otherwise.
export fn cotty_terminal_cursor_blinking(surface: i64) i64 {
    if (getSurfacePtr(surface).terminal.mode_cursor_blinking) { return 1 }
    return 0
}

/// Return 1 if application keypad mode is active, 0 otherwise.
export fn cotty_terminal_app_keypad(surface: i64) i64 {
    if (getSurfacePtr(surface).terminal.mode_app_keypad) { return 1 }
    return 0
}

/// Send a focus gained/lost event to the terminal.
/// focused: 1 = gained, 0 = lost.
export fn cotty_terminal_focus(surface: i64, focused: i64) void {
    const sptr = getSurfacePtr(surface)
    sptr.terminal.sendFocusEvent(focused == 1)
}

/// Paste text into the terminal with bracketed paste wrapping.
/// Wraps with ESC[200~ / ESC[201~ when mode 2004 is active.
export fn cotty_terminal_paste(surface: i64, ptr: i64, len: i64) void {
    const sptr = getSurfacePtr(surface)
    const fd = sptr.shell.master_fd
    if (fd < 0) { return }

    if (sptr.terminal.mode_bracketed_paste) {
        writeStr(fd, "\x1b[200~")
    }
    fd_write(fd, ptr, len)
    if (sptr.terminal.mode_bracketed_paste) {
        writeStr(fd, "\x1b[201~")
    }
}

// ============================================================================
// Word/line selection
// ============================================================================

/// Select the word at (row, col). Called on double-click.
export fn cotty_terminal_select_word(surface: i64, row: i64, col: i64) void {
    getSurfacePtr(surface).terminal.selectWord(row, col)
}

/// Select the entire line at row. Called on triple-click.
export fn cotty_terminal_select_line(surface: i64, row: i64) void {
    getSurfacePtr(surface).terminal.selectLine(row)
}

// ============================================================================
// Clipboard (OSC 52)
// ============================================================================

const ACTION_CLIPBOARD_SET: i64 = 5

/// Return and clear the clipboard request type: 0=none, 1=set, 2=query.
export fn cotty_terminal_clipboard_request(surface: i64) i64 {
    const sptr = getSurfacePtr(surface)
    const req = sptr.terminal.clipboard_request
    sptr.terminal.clipboard_request = 0
    return req
}

/// Return pointer to the decoded clipboard data buffer.
export fn cotty_terminal_clipboard_data(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.clipboard_buf
}

/// Return length of the decoded clipboard data.
export fn cotty_terminal_clipboard_data_len(surface: i64) i64 {
    return getSurfacePtr(surface).terminal.clipboard_len
}

/// Send clipboard contents back to the terminal as an OSC 52 response.
/// Called by Swift after a clipboard query (request type 2).
export fn cotty_terminal_clipboard_response(surface: i64, ptr: i64, len: i64) void {
    const sptr = getSurfacePtr(surface)
    const fd = sptr.shell.master_fd
    if (fd < 0) { return }
    // Send OSC 52 response: ESC ] 52 ; c ; <base64> ESC \.
    // For simplicity, send raw data — Swift should base64-encode before calling.
    writeStr(fd, "\x1b]52;c;")
    fd_write(fd, ptr, len)
    writeStr(fd, "\x1b\\")
}

