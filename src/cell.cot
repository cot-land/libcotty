/// Terminal cell: a single character with foreground/background colors and flags.

import "config"

/// Cell flags
const CELL_BOLD: i64 = 1
const CELL_UNDERLINE: i64 = 2
const CELL_INVERSE: i64 = 4
const CELL_SELECTED: i64 = 8
const CELL_DIM: i64 = 16
const CELL_ITALIC: i64 = 32
const CELL_STRIKETHROUGH: i64 = 64
const CELL_BLINK: i64 = 128
const CELL_HIDDEN: i64 = 256
const CELL_OVERLINE: i64 = 512
const CELL_DOUBLE_UNDERLINE: i64 = 1024
const CELL_CUSTOM_UL_COLOR: i64 = 2048

struct Cell {
    codepoint: i64,
    fg_r: i64,
    fg_g: i64,
    fg_b: i64,
    bg_r: i64,
    bg_g: i64,
    bg_b: i64,
    flags: i64,
    ul_r: i64,
    ul_g: i64,
    ul_b: i64,

    /// Create an empty cell with default colors.
    static fn init() Cell {
        ensureThemeReady()
        return Cell {
            codepoint: 0,
            fg_r: THEME_FG_R, fg_g: THEME_FG_G, fg_b: THEME_FG_B,
            bg_r: THEME_BG_R, bg_g: THEME_BG_G, bg_b: THEME_BG_B,
            flags: 0,
            ul_r: -1, ul_g: -1, ul_b: -1,
        }
    }

    /// Create a cell with the given codepoint and default colors.
    static fn initChar(cp: i64) Cell {
        ensureThemeReady()
        return Cell {
            codepoint: cp,
            fg_r: THEME_FG_R, fg_g: THEME_FG_G, fg_b: THEME_FG_B,
            bg_r: THEME_BG_R, bg_g: THEME_BG_G, bg_b: THEME_BG_B,
            flags: 0,
            ul_r: -1, ul_g: -1, ul_b: -1,
        }
    }

    /// Return true if this cell has no visible content.
    fn isBlank() bool {
        return self.codepoint == 0 or self.codepoint == ' '
    }
}

// ============================================================================
// Tests
// ============================================================================

test "cell init is blank" {
    var c = Cell.init()
    @assert(c.isBlank())
    @assertEq(c.codepoint, 0)
    @assertEq(c.flags, 0)
}

test "cell initChar stores codepoint" {
    var c = Cell.initChar('A')
    @assertEq(c.codepoint, 'A')
    @assert(!c.isBlank())
}

test "cell default fg color" {
    var c = Cell.init()
    @assertEq(c.fg_r, 217)
    @assertEq(c.fg_g, 217)
    @assertEq(c.fg_b, 217)
}

test "cell default bg color" {
    var c = Cell.init()
    @assertEq(c.bg_r, 12)
    @assertEq(c.bg_g, 12)
    @assertEq(c.bg_b, 12)
}

test "cell space is blank" {
    var c = Cell.initChar(' ')
    @assert(c.isBlank())
}

test "cell flags" {
    var c = Cell.init()
    c.flags = CELL_BOLD | CELL_UNDERLINE
    @assertEq(c.flags, 3)
}
